"Crea los usuarios de las bases de datos (comun, sv, sf) y genera passwords "
"para los ficheros .inc."
msgstr ""
"Crea els usuaris de les bases de dades (comun, sv, sf) i genera contrasenyes "
"per als fitxers .inc."

#: frontend/devel_db_admin/view/db_crear_esquema_que.phtml:82
msgid "dl de referencia"
msgstr "dl de referència"

#: frontend/devel_db_admin/view/db_crear_esquema_que.phtml:89
msgid "Para las bases de datos"
msgstr "Per les bases de dades"

#: frontend/devel_db_admin/view/db_crear_esquema_que.phtml:99
