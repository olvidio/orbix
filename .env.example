# Copiar este fichero como `.env` en la raíz del proyecto (`cp .env.example .env`).
# `.env` no debe subirse a git (contiene secretos).

# Directorio de ficheros `*.inc` (passwords/conexión) al ejecutar scripts CLI en el host
# (en Docker suele ser /var/www/conf montado desde docker_images/.../conf).
# ORBIX_DIR_PWD=/home/dani/docker_images/orbix/web/html/conf

# Firma de enlaces GET `tk` (frontend\shared\helpers\SignedDownloadToken).
# En producción usar al menos ~32 caracteres aleatorios (p. ej. `openssl rand -hex 32`).
ORBIX_SIGNED_DOWNLOAD_TOKEN_SECRET=
