<div id='condiciones' class='no_print'>
    <?php if (!empty($perm_mod_txt)) { ?>
        <ul>
            <li>
                <span class="link" onclick="fnjs_update_div('#main', <?= json_encode($url_com_txt) ?>)">
                    <?= htmlspecialchars($i18n['modificar_textos'], ENT_QUOTES, 'UTF-8') ?>
                </span>
            </li>
        </ul>
    <?php } ?>

    <form id="seleccion" name="seleccion" onsubmit="return false;">
        <h3 class="subtitulo">
            <?= htmlspecialchars($Qque === 'un_sacd' ? $i18n['titulo_un_sacd'] : $i18n['titulo_periodo'], ENT_QUOTES, 'UTF-8') ?>
        </h3>
        <?= $oHash->getCamposHtml() ?>
        <?= $oFormP->getHtml() ?>
    </form>
</div>

<!--
    El atributo `refe` lo lee libs/export/export.php como clave para
    elegir el XSLT (html2ootext_com_sacd.xslt). Mantengo el string legacy
    para preservar la exportacion a ODF/ODT.
-->
<div id="exportar" refe="actividadessacd/view/com_sacd_activ_print.phtml"></div>

<script type="text/javascript">
    var URL_COM_DATA = <?= json_encode($url_data) ?>;
    var URL_COM_ENVIAR = <?= json_encode($url_enviar) ?>;
    var I18N_COM = <?= json_encode($i18n, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
    var AUTO_CARGAR = <?= !empty($auto_cargar) ? 'true' : 'false' ?>;

    fnjs_parse_rta_txt = function (rta) {
        if (!rta || rta.success !== true) {
            var msg = (rta && rta.mensaje) ? rta.mensaje : I18N_COM.err_desconocido;
            alert(I18N_COM.respuesta + ': ' + msg);
            return null;
        }
        try {
            return (typeof rta.data === 'string') ? JSON.parse(rta.data) : rta.data;
        } catch (e) {
            return null;
        }
    };

    // Escape para insertar texto en HTML (no reescribo '>' ni '&').
    fnjs_esc_html = function (s) {
        if (s === null || s === undefined) { return ''; }
        return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    };

    /**
     * Construye el bloque HTML para una lista de sacds (array de
     * `{id_nom, nom_ap, txt, actividades}`). Reproduce
     * `apps/actividadessacd/view/com_sacd_activ_print.phtml`.
     */
    fnjs_pintar_sacds = function (lista, meta) {
        if (!Array.isArray(lista) || lista.length === 0) {
            return '';
        }
        var propuesta = (meta.propuesta === 't' || meta.propuesta === 'true');
        var out = '';
        for (var i = 0; i < lista.length; i++) {
            var persona = lista[i];
            var txt = persona.txt || {};
            var acts = persona.actividades || [];

            out += '<div class="salta_pag" id="sacd_' + persona.id_nom + '">';
            out += '<br>';
            out += '<div class="cabecera-pag">';
            out += '<span class="izquierda">' + fnjs_esc_html(persona.nom_ap) + '</span>';
            if (!propuesta) {
                if (meta.que === 'nagd') {
                    out += '<span class="derecha">vc-' + fnjs_esc_html(meta.mi_dele) + '</span>';
                }
                out += '</div>';
                out += '<div class="comunicacion">' + (txt.com_sacd || '') + '</div>';
            } else {
                out += '</div>';
            }

            out += '<table class="enc" border="1"><tr>';
            out += '<td class="cabecera_izq">' + fnjs_esc_html(txt.t_f_ini) + '</td>';
            out += '<td class="cabecera_izq">' + fnjs_esc_html(txt.t_f_fin) + '</td>';
            out += '<td class="cabecera">' + fnjs_esc_html(txt.t_nombre_ubi) + '</td>';
            out += '<td class="cabecera">' + fnjs_esc_html(txt.t_sfsv) + '</td>';
            out += '<td class="cabecera">' + fnjs_esc_html(txt.t_actividad) + '</td>';
            out += '<td class="cabecera">' + fnjs_esc_html(txt.t_asistentes) + '</td>';
            out += '<td class="cabecera">' + fnjs_esc_html(txt.t_encargado) + '</td>';
            out += '<td class="cabecera">' + fnjs_esc_html(txt.t_observ) + '</td>';
            out += '<td class="cabecera">' + fnjs_esc_html(txt.t_nom_tipo) + '</td>';
            out += '</tr>';

            for (var j = 0; j < acts.length; j++) {
                var act = acts[j];
                var marca = (act.propio === 't' || act.propio === true || act.propio === 'true') ? '*' : '';
                var cargo_observ = act.cargo ? (act.cargo + '. ' + (act.observ || '')) : (act.observ || '');
                out += '<tr>';
                out += '<td>' + marca + fnjs_esc_html(act.f_ini) + '</td>';
                out += '<td>' + fnjs_esc_html(act.f_fin) + '</td>';
                out += '<td class="centro">' + fnjs_esc_html(act.nombre_ubi) + '</td>';
                out += '<td class="centro">' + fnjs_esc_html(act.sfsv) + '</td>';
                out += '<td class="centro">' + fnjs_esc_html(act.actividad) + '</td>';
                out += '<td class="centro">' + fnjs_esc_html(act.asistentes) + '</td>';
                out += '<td class="centro">' + fnjs_esc_html(act.encargado) + '</td>';
                out += '<td class="centro">' + fnjs_esc_html(cargo_observ) + '</td>';
                out += '<td class="centro">' + fnjs_esc_html(act.nom_tipo) + '</td>';
                out += '</tr>';
            }
            out += '</table>';

            if (!propuesta) {
                out += '<div class="pie-pag">';
                out += '<span class="izquierda">*) ' + fnjs_esc_html(txt.t_propio) + '</span>';
                out += '<span class="derecha">' + fnjs_esc_html(meta.lugar_fecha) + '</span>';
                out += '</div>';
            }
            out += '</div>';
        }
        return out;
    };

    fnjs_construir_listado = function (data) {
        var html = '<span id="span_exportar" title="comunicacion_sacd">';
        html += fnjs_pintar_sacds(data.sacds || [], data);
        if (Array.isArray(data.sacds_paso) && data.sacds_paso.length > 0) {
            html += '<div id="sacds_paso_titulo">' + fnjs_esc_html(I18N_COM.sacd_paso_titulo) + '</div>';
            html += fnjs_pintar_sacds(data.sacds_paso, data);
        }
        html += '</span>';

        if ((!data.sacds || data.sacds.length === 0) &&
            (!data.sacds_paso || data.sacds_paso.length === 0)) {
            html = '<p>' + fnjs_esc_html(I18N_COM.sin_datos) + '</p>';
        }
        return html;
    };

    fnjs_ver = function () {
        var parametros = $('#seleccion').serialize();
        $.ajax({
            url: URL_COM_DATA,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (rta) {
            var data = fnjs_parse_rta_txt(rta);
            if (data === null) { return; }
            if (data.mensaje_periodo) {
                alert(data.mensaje_periodo);
                return;
            }
            $('#exportar').html(fnjs_construir_listado(data));
        }).fail(function () {
            alert(I18N_COM.err_comunicacion);
        });
    };

    fnjs_enviar_mails = function () {
        var msg = I18N_COM.aviso1 + "\r\n" + I18N_COM.aviso2 + "\r\n" + I18N_COM.aviso3 + "\r\n";
        alert(msg);
        var parametros = $('#seleccion').serialize();
        $.ajax({
            url: URL_COM_ENVIAR,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (rta) {
            if (!rta || rta.success !== true) {
                var m = (rta && rta.mensaje) ? rta.mensaje : I18N_COM.err_desconocido;
                alert(I18N_COM.respuesta + ': ' + m);
                return;
            }
            alert(I18N_COM.ok_mails);
        }).fail(function () {
            alert(I18N_COM.err_comunicacion);
        });
    };

    fnjs_cancelar = function () {
        <?= $oPosicion->js_atras(1) ?>
    };

    fnjs_left_side_hide();
    $(function () { if (AUTO_CARGAR) { fnjs_ver(); } });
</script>
