<?php
/**
 * Vista unificada para la comunicacion de actividades a los sacd.
 *
 * Renderiza:
 *  - el form de seleccion de periodo (`oFormP` + hidden inputs `oHash`);
 *  - los botones "buscar" / "enviar mail";
 *  - un `<div id='exportar'>` que el JS rellena con las tablas por sacd
 *    a partir del JSON que devuelven los endpoints
 *    `/src/actividadessacd/comunicacion_activ_sacd_data`
 *    `/src/actividadessacd/comunicacion_activ_sacd_enviar`.
 *
 * Si el controlador detecta `que=un_sacd` (posteo desde personas_select),
 * la pagina auto-dispara `fnjs_ver()` al cargar.
 *
 * @var frontend\shared\web\Posicion   $oPosicion
 * @var web\Hash       $oHash
 * @var frontend\shared\web\PeriodoQue $oFormP
 * @var string         $Qque
 * @var bool           $perm_mod_txt
 * @var string         $url_data
 * @var string         $url_enviar
 * @var string         $url_com_txt
 * @var bool           $auto_cargar
 */

$i18n = [
    'titulo_periodo' => _("lista con la atención de actividades para mandar a los sacd"),
    'titulo_un_sacd' => _("atención de actividades del sacd seleccionado"),
    'modificar_textos' => _("click para modificar los textos de las comunicaciones"),
    'cancelar' => _("cancelar"),
    'aviso1' => _("- Se enviará a las 14:30 y a las 21:00."),
    'aviso2' => _("- Se enviará una copia al jefe del calendario y al ctr del sacd."),
    'aviso3' => _("- No se enviará a los sacd que no tengan actividades"),
    'respuesta' => _("respuesta"),
    'err_comunicacion' => _("error de comunicación con el servidor"),
    'err_desconocido' => _("error desconocido"),
    'ok_mails' => _("mails encolados correctamente"),
    'sin_datos' => _("sin datos para el periodo seleccionado"),
    'sacd_paso_titulo' => _("Sacd de paso"),
];
?>
