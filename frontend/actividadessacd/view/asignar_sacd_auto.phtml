<?php
/**
 * Vista auxiliar "Auto asignar sacd a actividades".
 *
 * Texto explicativo + boton que invoca por AJAX el endpoint
 * `/src/actividadessacd/sacd_asignar_auto`. Pinta el mensaje resultado
 * en el propio contenedor sin recargar la pagina.
 *
 * @var string $inicurs_des      Inicio de curso des (formato local).
 * @var string $inicurs_des_iso  Inicio de curso des (YYYY-MM-DD).
 * @var string $url_asignar_auto URL firmada del endpoint.
 */

$i18n = [
    'desc_1' => ucfirst(_("esto asignará el sacd titular del centro a las actividades que tengan un centro encargado")),
    'desc_2' => ucfirst(sprintf(_("limitado a las actividades de sr y sg a partir de %s y marcadas como actuales"), $inicurs_des)),
    'desc_3' => ucfirst(_("en el campo observaciones aparece la palabra 'auto' para indicar la asignación automática")),
    'continuar' => _("continuar"),
    'procesando' => _("procesando..."),
    'resultado' => _("Ya está. Se ha asignado %s actividades. Quedan %s por asignar (el centro)."),
    'respuesta' => _("respuesta"),
    'err_comunicacion' => _("error de comunicación con el servidor"),
    'err_desconocido' => _("error desconocido"),
];
?>
<script>
    var URL_ASIGNAR_AUTO = <?= json_encode($url_asignar_auto) ?>;
    var F_INI_ISO = <?= json_encode($inicurs_des_iso) ?>;
    var I18N_ASAUTO = <?= json_encode($i18n, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;

    fnjs_esc_asauto = function (txt) {
        if (txt === null || txt === undefined) { return ''; }
        return String(txt)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    };

    fnjs_asignar_sacd_auto = function () {
        var btn = $('#btn_confirm');
        btn.prop('disabled', true);
        $('#rta_asauto').html('<em>' + fnjs_esc_asauto(I18N_ASAUTO.procesando) + '</em>');
        $.ajax({
            url: URL_ASIGNAR_AUTO,
            type: 'post',
            data: { f_ini_iso: F_INI_ISO },
            dataType: 'json'
        }).done(function (rta) {
            if (!rta || rta.success !== true) {
                var msg = (rta && rta.mensaje) ? rta.mensaje : I18N_ASAUTO.err_desconocido;
                alert(I18N_ASAUTO.respuesta + ': ' + msg);
                btn.prop('disabled', false);
                $('#rta_asauto').html('');
                return;
            }
            var data = (typeof rta.data === 'string') ? JSON.parse(rta.data) : rta.data;
            if (!data) { data = { asignadas: 0, sin_asignar: 0 }; }
            var txt = I18N_ASAUTO.resultado
                .replace('%s', data.asignadas)
                .replace('%s', data.sin_asignar);
            $('#rta_asauto').html(fnjs_esc_asauto(txt));
        }).fail(function () {
            alert(I18N_ASAUTO.err_comunicacion);
            btn.prop('disabled', false);
            $('#rta_asauto').html('');
        });
    };
</script>
<div id="asignar_sacd_auto">
    <p><?= $i18n['desc_1'] ?>.</p>
    <p><?= $i18n['desc_2'] ?>.</p>
    <p><?= $i18n['desc_3'] ?>.</p>
    <br>
    <input type="button" id="btn_confirm"
           value="<?= htmlspecialchars($i18n['continuar'], ENT_QUOTES, 'UTF-8') ?>"
           onclick="fnjs_asignar_sacd_auto();">
    <div id="rta_asauto" style="margin-top:1em;"></div>
</div>
