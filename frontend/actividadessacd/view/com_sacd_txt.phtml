<?php
/**
 * Vista del editor de textos de comunicacion a los sacd.
 *
 * Form con dos desplegables y un `<textarea>`. Los botones "cancelar"
 * y "guardar" no envian el form: "guardar" hace un POST AJAX al
 * endpoint `/src/actividadessacd/texto_comunicacion_guardar` y pinta el
 * mensaje si hay error. El cambio en cualquier desplegable dispara
 * `fnjs_get_texto()` que consulta
 * `/src/actividadessacd/texto_comunicacion_data` y rellena el textarea.
 *
 * @var frontend\shared\web\Desplegable $oDesplClaves
 * @var frontend\shared\web\Desplegable $oDesplIdiomas
 * @var string          $comunicacion
 * @var string          $url_data
 * @var string          $url_guardar
 * @var frontend\shared\web\Posicion    $oPosicion
 */

$i18n = [
    'titulo' => _("textos para las comunicaciones de las actividades"),
    'cancelar' => _("cancelar"),
    'guardar' => _("guardar"),
    'respuesta' => _("respuesta"),
    'guardado' => _("testo guardado"),
    'err_comunicacion' => _("error de comunicación con el servidor"),
    'err_desconocido' => _("error desconocido"),
];
?>
<script type="text/javascript">
    var URL_TXT_DATA = <?= json_encode($url_data) ?>;
    var URL_TXT_GUARDAR = <?= json_encode($url_guardar) ?>;
    var I18N_TXT = <?= json_encode($i18n, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;

    fnjs_parse_rta_txt = function (rta) {
        if (!rta || rta.success !== true) {
            var msg = (rta && rta.mensaje) ? rta.mensaje : I18N_TXT.err_desconocido;
            alert(I18N_TXT.respuesta + ': ' + msg);
            return null;
        }
        try {
            return (typeof rta.data === 'string') ? JSON.parse(rta.data) : rta.data;
        } catch (e) {
            return null;
        }
    };

    fnjs_get_texto = function () {
        var clave = $('#clave').val();
        var idioma = $('#idioma').val();
        $.ajax({
            url: URL_TXT_DATA,
            type: 'post',
            data: { clave: clave, idioma: idioma },
            dataType: 'json'
        }).done(function (rta) {
            var data = fnjs_parse_rta_txt(rta);
            if (data === null) { return; }
            $('#comunicacion').val(data.texto || '');
        }).fail(function () {
            alert(I18N_TXT.err_comunicacion);
        });
    };

    fnjs_guardar = function () {
        var clave = $('#clave').val();
        var idioma = $('#idioma').val();
        var texto = $('#comunicacion').val();
        $.ajax({
            url: URL_TXT_GUARDAR,
            type: 'post',
            data: { clave: clave, idioma: idioma, texto: texto },
            dataType: 'json'
        }).done(function (rta) {
            if (!rta || rta.success !== true) {
                var msg = (rta && rta.mensaje) ? rta.mensaje : I18N_TXT.err_desconocido;
                alert(I18N_TXT.respuesta + ': ' + msg);
            }
            if (rta && rta.success === true) {
                alert(I18N_TXT.guardado);
            }
        }).fail(function () {
            alert(I18N_TXT.err_comunicacion);
        });
    };

    fnjs_cancelar = function () {
        <?= $oPosicion->jsNavAtras(1) ?>
    };
</script>

<h1><?= htmlspecialchars($i18n['titulo'], ENT_QUOTES, 'UTF-8') ?></h1>

<form id="textos" name="textos" onsubmit="return false;">
    <table>
        <tr>
            <td><?= $oDesplClaves->desplegable() ?></td>
            <td><?= $oDesplIdiomas->desplegable() ?></td>
        </tr>
        <tr>
            <td colspan="2">
                <textarea id="comunicacion" name="comunicacion" cols="100" rows="5"><?= htmlspecialchars($comunicacion, ENT_QUOTES, 'UTF-8') ?></textarea>
            </td>
        </tr>
        <tr>
            <td>
                <input type="button" onclick="fnjs_cancelar();"
                       value="<?= htmlspecialchars($i18n['cancelar'], ENT_QUOTES, 'UTF-8') ?>">
                <input type="button" onclick="fnjs_guardar();"
                       value="<?= htmlspecialchars($i18n['guardar'], ENT_QUOTES, 'UTF-8') ?>">
            </td>
        </tr>
    </table>
</form>
