<script>
    fnjs_trasladar = function (formulario) {
        $(formulario).attr('action', "frontend/ubis/controller/trasladar_ubis.php");
        fnjs_enviar_formulario(formulario);
    }
    fnjs_modificar = function (formulario) {
        rta = fnjs_solo_uno(formulario);
        if (rta == 1) {
            $(formulario).attr('action', "frontend/ubis/controller/home_ubis.php");
            fnjs_enviar_formulario(formulario);
        }
    }
    fnjs_borrar = function (formulario) {
        var seguro;
        seguro = confirm(<?= json_encode(_("¿Está seguro que desea borrar este ubi?")) ?>);
        if (seguro) {
            $(formulario).one("submit", function () {
                fnjs_ajax_json_alert({
                    url: $(this).attr('action'),
                    data: $(this).serialize()
                });
                return false;
            });
            $(formulario).trigger("submit");
            $(formulario).off();
        }
    }

</script>
