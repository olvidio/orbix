<script>
fnjs_cerrar=function(){
    $('#div_modificar').html('');
    $('#div_modificar').width('0');
    $('#div_modificar').height('0');
    $('#div_modificar').removeClass('ventana');
    document.getElementById("overlay").style.display = "none";
}

fnjs_modificar=function(id_ubi,tipo){
    $('#div_modificar').addClass('ventana');
    $('#div_modificar').width('auto');
    $('#div_modificar').height('auto');
    document.getElementById("overlay").style.display = "block";

    if (id_ubi) {
        var url = '';
        var parametros = 'id_ubi=' + id_ubi;
        switch (tipo) {
            case 'labor':
                url = '<?= $url_form_labor ?>';
                parametros = parametros + '<?= $h_form_labor ?>';
                break;
            case 'num':
                url = '<?= $url_form_num ?>';
                parametros = parametros + '<?= $h_form_num ?>';
                break;
            case 'plazas':
                url = '<?= $url_form_plazas ?>';
                parametros = parametros + '<?= $h_form_plazas ?>';
                break;
        }
        fnjs_update_div('#div_modificar', url + '?' + parametros);
    } else {
        // compat: no se usa activamente aquí
    }
}

fnjs_ver=function(){
    pata = $('#seleccion').serialize();
    var accion = $('#que').val();
    var url = '';
    var hash_params = '';
    switch (accion) {
        case 'get_labor':
            url = '<?= $url_get_labor ?>';
            hash_params = '<?= $param_ajax_labor ?>';
            break;
        case 'get_num':
            url = '<?= $url_get_num ?>';
            hash_params = '<?= $param_ajax_num ?>';
            break;
        case 'get_plazas':
            url = '<?= $url_get_plazas ?>';
            hash_params = '<?= $param_ajax_plazas ?>';
            break;
        default:
            url = '<?= $url_get_labor ?>';
            hash_params = '<?= $param_ajax_labor ?>';
            break;
    }
    var parametros=pata + '&' + hash_params;
    fnjs_ajax_json_html({ url: url, data: parametros, target: '#exportar' });
}

fnjs_guardar=function(formulario) {
    fnjs_ajax_json({
        url: $(formulario).attr('action'),
        data: $(formulario).serialize(),
        onSuccess: function () {
            fnjs_cerrar();
            fnjs_ver();
        }
    });
}
</script>
<form id=seleccion name=seleccion action="">
<?= $oDesplOpciones->desplegable() ?>
<input type=button name="buscar" value="<?= _("buscar") ?>" onclick="fnjs_ver();">
</form>
<div id='exportar'></div>
<div id='div_modificar'></div>
<div id='overlay'></div>
