<script>
    fnjs_guardar = function (formulario) {
        let url = $(formulario).attr('action');
        let parametros = $(formulario).serialize();
        let request = $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        });
        request.done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta")) ?> + ': ' + json.mensaje);
            } else {
                <?= $oPosicion->jsNavAtras(1); ?>
                fnjs_lista_menus();
            }
        });
    }
</script>
