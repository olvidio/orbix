{{ oPosicion.mostrarNavAtras(1)|raw }}

{% if aviso is defined and aviso %}
<div class="certificado-aviso-config" role="alert" style="max-width: 42rem; padding: 1rem 1.25rem; margin: 1rem 0; border: 1px solid #c9a227; background: #fffbea; color: #3d3500; line-height: 1.5;">
    <div style="margin: 0;">{{ aviso|raw }}</div>
</div>
{% endif %}

{{ "Añadir un certificado para"|trans|raw }}: {{ nom }}
<br>
<br>
<form id='frm_upload' action="" method="post" enctype="multipart/form-data">
    {{ oHashCertificadoPdf.getCamposHtml()|raw }}
    <br>
    <label>
        {{ "Número de certificado"|trans|raw }}:
        <input type="text" name="certificado" value="{{ certificado }}"/>
    </label>
    <br>
    <label>
        {{ "Fecha del certificado"|trans|raw }}:
        <input type="text" id="f_certificado" name="f_certificado" value="{{ f_certificado }}"/>
    </label>
    <br>
    <label>
        {{ "idioma del certificado"|trans|raw }}:
        {{ oDesplIdiomas.desplegable|raw }}
        ({{ "blanco = latín"|trans|raw }})
    </label>
    <br>
    <label>
        {{ "Firmado digitalmente"|trans|raw }}:
        <input type="checkbox" name="firmado" {{ chk_firmado }}/>
    </label>
    <br>
    <label>
        {{ "Fecha enviado"|trans|raw }}:
        <input type="text" id="f_enviado" name="f_enviado" value="{{ f_recibido }}"/>
    </label>
    <br>
    <br>
    <input type="button" onclick="fnjs_guardar();" value="{{ "Guardar"|trans|raw }}">
    <br>
    <br>
    {{ "Fichero"|trans|raw }}:
    <input type="file" name="certificado_pdf" id="fileToUpload"/>
    <br>
    <br>
    <input type="button" onclick="fnjs_upload_pdf();" value="{{ "subir pdf"|trans|raw }}">
</form>


<script type="text/javascript">
    fnjs_guardar = function () {
        if (!fnjs_comprobar_fecha('#f_certificado', '{{ locale_us }}')) {
            return;
        }

        if (!fnjs_comprobar_fecha('#f_enviado', '{{ locale_us }}')) {
            //return;
        }

        if (typeof event !== 'undefined') {
            event.preventDefault();
        }

        let datos = $('#frm_upload').serialize();
        let request = $.ajax({
            data: datos,
            url: 'src/certificados/certificado_emitido_guardar',
            method: 'POST',
            dataType: 'json'
        });
        request.done(function (json) {
            if (json.success !== true) {
                alert("{{ "respuesta"|trans|raw }}: " + json.mensaje);
            } else {
                {{ oPosicion.jsNavAtras(1)|raw }}
            }
        });
    }

    fnjs_upload_pdf = function () {
        if (!fnjs_comprobar_fecha('#f_certificado', '{{ locale_us }}')) {
            return;
        }
        if (!fnjs_comprobar_fecha('#f_recibido', '{{ locale_us }}')) {
            return;
        }

        if (typeof event !== 'undefined') {
            event.preventDefault();
        }
        //datos = $('#frm_upload').serialize();
        let datos = new FormData(document.getElementById("frm_upload"));

        let request = $.ajax({
            data: datos,
            url: 'src/certificados/certificado_emitido_pdf_upload',
            method: 'POST',
            dataType: 'json',
            cache: false,
            contentType: false,
            processData: false
        });
        request.done(function (json) {
            if (json.success !== true) {
                alert("{{ "respuesta"|trans|raw }}: " + json.mensaje);
            } else {
                {{ oPosicion.jsNavAtras(1)|raw }}
            }
        });
        request.fail(function (xhr) {
            var msg = '';
            try {
                var j = xhr.responseJSON || JSON.parse(xhr.responseText || '{}');
                if (j && j.mensaje) {
                    msg = j.mensaje;
                }
            } catch (e) {
            }
            if (!msg) {
                msg = xhr.status === 413
                    ? "{{ "El servidor rechazó la subida: archivo o petición demasiado grandes."|trans|e('js') }}"
                    : ("{{ "Error al subir el archivo."|trans|e('js') }}" + (xhr.status ? " (" + xhr.status + ")" : ""));
            }
            alert("{{ "respuesta"|trans|raw }}: " + msg);
        });
    }


    $(function () {
        $("#f_certificado").datepicker({
            numberOfMonths: 3,
            showButtonPanel: true
        });
        $("#f_recibido").datepicker({
            numberOfMonths: 3,
            showButtonPanel: true
        });

    });
</script>