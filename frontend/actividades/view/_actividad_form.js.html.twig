{% block scripts %}
<script>
// Para que no de error al crear una nueva. Al cambiar tipo sv/sf, cambia la dl_org y dispara
// esta función y no la encuentra.
fnjs_actualizar_fases=function(){

}

$(function() {
    $("#f_ini").datepicker({
        numberOfMonths: 3,
        showButtonPanel: true
    });

});

$(function() {
    $("#f_fin").datepicker({
        numberOfMonths: 3,
        showButtonPanel: true
    });

});

// Para poner por defecto en el mismo día que el inicio de actividad
$("#f_fin").on("click", function() {
    var fin = '';
    var ini = $( "#f_ini" ).val();

    fin = $( "#f_fin" ).val();
    if (ini && !fin) {
        $(this).datepicker('setDate',ini);
    }
});

/*
* Para enviar los parámetros por POST
* @type jQuery
*/
fnjs_cambiar_ubi=function(){
    var dl_org=$('#dl_org').val();
    var ssfsv=$('#ssfsv').val();
    var isfsv=$('#isfsv_val option:selected').val();
    if (!isfsv) isfsv='';
    var array_org=dl_org.split('#');
    var winPrefs="dependent=yes,width=950,height=700,screenX=200,screenY=200,titlebar=yes,scrollbars=yes";
    var url = "{{ web }}/frontend/actividades/controller/actividad_select_ubi.php";
    var param_json = {dl_org : array_org[0], ssfsv: ssfsv, isfsv: isfsv};
    var decodeQP = function (s) {
        try {
            return decodeURIComponent(String(s).replace(/\+/g, ' '));
        } catch (e) {
            return s;
        }
    };
    // linkSinVal() devuelve "?hnov=1&h=..."; si el primer trozo es "?hnov=1",
    // validatePost no recibe hnov y el hash no cuadra → redirección a inicio.
    var h_param = "{{ h|raw }}".replace(/^[?&]/, '');
    var params = h_param.split('&');
    for (var i = 0; i < params.length; i++) {
        if (!params[i]) continue;
        var eq = params[i].indexOf('=');
        if (eq === -1) continue;
        var k = decodeQP(params[i].substring(0, eq));
        var v = decodeQP(params[i].substring(eq + 1));
        param_json[k] = v;
    }
    $.post(url,param_json, function(result){
        WinId = window.open('', 'sele', winPrefs);
        WinId.document.open();
        WinId.document.write(result);
        WinId.document.close();
        WinId.focus();
    });
};

fnjs_guardar=function(tipo='') {
    var err = 0;
    if (!fnjs_comprobar_fecha('#f_ini','{{ locale_us }}')) {err=1;}
    if (!fnjs_comprobar_fecha('#f_fin','{{ locale_us }}')) {err=1;}
    if (!fnjs_comprobar_hora('#h_ini')) {err=1;}
    if (!fnjs_comprobar_hora('#h_fin')) {err=1;}
    var dl_org=$('#dl_org').val();
    var estado = $('#status').val();

    // comprobar si el id_tipo_actividad está completo
    var id_sfsv_val=$('#isfsv_val').val();
    var id_asistentes_val=$('#iasistentes_val').val();
    var id_actividad_val=$('#iactividad_val').val();
    var id_nom_tipo_val=$('#inom_tipo_val').val();

    if (id_sfsv_val === '.') {alert("{{ "debe concretar la sección en el tipo de actividad"|trans|raw }}"); err=1;}
    if (id_asistentes_val === '.') {alert("{{ "debe concretar los asistentes en el tipo de actividad"|trans|raw }}"); err=1;}
    if (id_actividad_val === '.') {alert("{{ "debe concretar la actividad en el tipo de actividad"|trans|raw }}"); err=1;}
    if (id_nom_tipo_val === '...') {alert("{{ "debe concretar el tipo de actividad"|trans|raw }}"); err=1;}
    // fin de tipo

    if (!dl_org) {
        alert("{{ "debe llenar el campo de Organiza"|trans|raw }}"); err=1;
    }

    if (tipo==='cambiar_tipo') {
        // Ojo: mantener err numérico (0/1). `err = !confirm()` lo pondría booleano y
        // `if (err===0)` (comparación estricta) fallaría con `false === 0` → no guardaría.
        if (!confirm("{{ "continúa si has ajustado el nombre de la actividad"|trans|raw }}")) {
            err = 1;
        } else {
            {% if procesos_installed %}
            alert("{{ "La actividad pasará a proyecto, y se deberá volver a marcar las fases correspondientes"|trans|raw }}");
            {% endif %}
        }
    }

    if (err===0) {
        // Solo recomponer id_tipo_activ desde el widget si éste existe (modos nuevo/cambiar_tipo).
        // En 'datos' (editar) el tipo se muestra como texto y el hidden id_tipo_activ ya trae el valor;
        // sobrescribirlo con '' rompería el hash de campos hidden (hh).
        if ($('#isfsv_val').length) {
            $('#id_tipo_activ').val(
                String($('#isfsv_val').val() || '') +
                String($('#iasistentes_val').val() || '') +
                String($('#iactividad_val').val() || '') +
                String($('#inom_tipo_val').val() || '')
            );
        }
        $('#mod').val(tipo);
        var urlUpdate = '{{ web }}/frontend/actividades/controller/actividad_mutacion_ajax.php';

        $.ajax({
            url: urlUpdate,
            type: 'post',
            data: $('#modifica').serialize(),
            dataType: 'json'
        }).done(function (respuesta) {
            if (respuesta.success !== true) {
                alert("{{ "respuesta"|trans|raw }}: " + (respuesta.mensaje || 'Error desconocido'));
            } else if (tipo !== 'nuevo') {
                // En el caso de nuevo, me quedo en el formulario.
                {{ oPosicion.jsNavAtras(1)|raw }}
            } else {
                $('#modifica')[0].reset();
                fnjs_asistentes();
                var txt = "{{ "sin determinar"|trans|raw }}";
                $('#id_ubi').val("");
                $('#span_nom_ubi').html(txt);
                $('#lugar_esp').val("");
            }
        }).fail(function (xhr, status, error) {
            let detalle = error;
            if (xhr.responseText) {
                try {
                    let json = JSON.parse(xhr.responseText);
                    if (json.mensaje) {
                        detalle = json.mensaje;
                    }
                } catch (e) {
                    detalle = xhr.responseText.trim().substring(0, 300);
                }
            }
            alert('Error en la conexión con el servidor: ' + detalle);
        });
    }
};

</script>
{% endblock %}
