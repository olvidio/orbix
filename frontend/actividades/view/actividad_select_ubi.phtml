<script>
    fnjs_enviar_form = function (id_form, bloque) {
    if (!bloque) {
    bloque = '#main';
}
    var url = '<?= AppUrlConfig::getPublicAppBaseUrl() . '/frontend/ubis/controller/ubis_lista.php' ?>';
    fnjs_ajax_json_html({
    url: url,
    data: $(id_form).serialize(),
    target: bloque
});
}

    fnjs_lugar = function () {
    var extendida=$('#extendida').val();
    var isfsv = <?= $isfsv ?>;
    var filtro_lugar = $('#filtro_lugar').val();
    var url = '<?= htmlspecialchars(AppUrlConfig::getPublicAppBaseUrl() . '/src/actividades/actividad_tipo_get', ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8') ?>';
    var parametros = 'extendida=' + extendida + '&modo=buscar&salida=lugar&entrada=' + filtro_lugar + '&isfsv=' + isfsv + '<?= $h ?>';
    $.ajax({
    url: url,
    type: 'post',
    data: parametros,
    dataType: 'json'
})
    .done(function (json) {
    if (!json || json.success !== true) {return;}
    try {
    var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
    $('#lst_lugar').html(fnjs_construir_desplegable(data));
} catch (e) {}
});
}

    // Construye un <select> a partir del payload JSON devuelto por el endpoint
    // /src/actividades/actividad_select_ubi_desplegable. Si el backend envia
    // mensaje, se muestra en lugar del desplegable.
    fnjs_construir_desplegable = function (data) {
        if (!data) {return '';}
        if (data.mensaje) {
        return $('<span></span>').text(data.mensaje).prop('outerHTML');
    }
        var $sel = $('<select></select>').attr({id: data.id, name: data.id});
        if (data.action) {
        $sel.attr('onchange', data.action);
    }
        // opcion en blanco.
        $sel.append($('<option></option>').val('').text(''));
        var opciones = data.opciones || {};
        $.each(opciones, function (value, label) {
        var $opt = $('<option></option>').val(value).text(label);
        if (data.selected && String(data.selected) === String(value)) {
        $opt.prop('selected', true);
    }
        $sel.append($opt);
    });
        return $sel.prop('outerHTML');
    }

    // Carga el desplegable (freq/region) via endpoint backend JSON.
    fnjs_cargar_desplegable = function (tipo, contenedor, cb) {
        var url = '<?= $url_desplegable ?>';
        var isfsv = <?= $isfsv ?>;
        var dl_org = '<?= addslashes($dl_org) ?>';
        var parametros = 'tipo=' + tipo + '&dl_org=' + encodeURIComponent(dl_org) + '&isfsv=' + isfsv + '<?= $h_desplegable ?>';
        $.ajax({
        url: url,
        type: 'post',
        data: parametros,
        dataType: 'json'
    }).done(function (json) {
        if (!json || json.success !== true) {
        $(contenedor).html('');
        return;
    }
        try {
        var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
        $(contenedor).html(fnjs_construir_desplegable(data));
    } catch (e) {
        $(contenedor).html('');
    }
        if (typeof cb === 'function') {cb();}
    });
    }
    $(function () {
        fnjs_cargar_desplegable('freq', '#td_despl_freq');
        // Tras cargar el desplegable de region disparamos fnjs_lugar() para
        // poblar el listado de lugares asociado al filtro inicial.
        fnjs_cargar_desplegable('region', '#td_despl_region', function () {
        if (typeof fnjs_lugar === 'function') {fnjs_lugar();}
    });
    });

    fnjs_buscar = function (formulario, id) {
