<script>
    fnjs_enviar_form = function (id_form, bloque) {
        if (!bloque) {
            bloque = '#main';
        }
        var url = '<?= ConfigGlobal::getWeb() . '/frontend/ubis/controller/ubis_lista.php' ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: $(id_form).serialize()
        })
        .done(function (rta_txt) {
            $(bloque).html(rta_txt);
        });
    }

    fnjs_lugar = function () {
        var extendida=$('#extendida').val();
        var isfsv = <?= $isfsv ?>;
        var filtro_lugar = $('#filtro_lugar').val();
        var url = '<?= rtrim(ConfigGlobal::getWeb(), '/') . '/src/actividades/actividad_tipo_get' ?>';
        var parametros = 'extendida=' + extendida + '&modo=buscar&salida=lugar&entrada=' + filtro_lugar + '&isfsv=' + isfsv + '<?= $h ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'html'
        })
            .done(function (rta_txt) {
                $('#lst_lugar').html(rta_txt);
            });
    }

    // Carga inicial de los desplegables "frequentes" y "region" via endpoint backend.
    fnjs_cargar_desplegable = function (tipo, contenedor) {
        var url = '<?= $url_desplegable ?>';
        var isfsv = <?= $isfsv ?>;
        var dl_org = '<?= addslashes($dl_org) ?>';
        var parametros = 'tipo=' + tipo + '&dl_org=' + encodeURIComponent(dl_org) + '&isfsv=' + isfsv + '<?= $h_desplegable ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'html'
        }).done(function (rta_txt) {
            $(contenedor).html(rta_txt);
        });
    }
    $(function () {
        fnjs_cargar_desplegable('freq', '#td_despl_freq');
        // Tras cargar el desplegable de region disparamos fnjs_lugar() para
        // poblar el listado de lugares asociado al filtro inicial.
        var url_region = '<?= $url_desplegable ?>';
        var isfsv_region = <?= $isfsv ?>;
        var dl_org_region = '<?= addslashes($dl_org) ?>';
        var params_region = 'tipo=region&dl_org=' + encodeURIComponent(dl_org_region) + '&isfsv=' + isfsv_region + '<?= $h_desplegable ?>';
        $.ajax({ url: url_region, type: 'post', data: params_region, dataType: 'html' })
            .done(function (rta_txt) {
                $('#td_despl_region').html(rta_txt);
                if (typeof fnjs_lugar === 'function') { fnjs_lugar(); }
            });
    });

    fnjs_buscar = function (formulario, id) {
        var form_name = $(formulario).attr('name');
        var opcion = form_name.substr(-1);
        if (opcion == 1) {
            var lista = $('#id_ubi_1').val();
            var txt = $('#id_ubi_1 :selected').text();
            if (!lista) {
                alert("<?= _("tiene que seleccionar una casa") ?>");
                return;
            }
            window.opener.$('#id_ubi').val(lista);
            window.opener.$('#nombre_ubi').val(txt);
            window.opener.$('#span_nom_ubi').html(txt);
            alert("<?= $txt_alert ?>");
            window.close();

        }
        if (opcion == 2) {
            /* OJO. este id_ubi no puede tener otro nombre, porque viene de una página
            *  "actividad_tipo_get.php" que también da los datos a otros programas.
            */
            var lista = $('#id_ubi').val();
            var txt = $('#id_ubi :selected').text();
            if (!lista) {
                alert("<?= _("tiene que seleccionar una casa") ?>");
                return;
            }
            window.opener.$('#id_ubi').val(lista);
            window.opener.$('#nombre_ubi').val(txt);
            window.opener.$('#span_nom_ubi').html(txt);
            alert("<?= $txt_alert ?>");
            window.close();

        }
        if (opcion == 3) {
            var lista = id;
            var txt = $('#' + id).html();
            if (!lista) {
                alert("<?= _("tiene que seleccionar una casa") ?>");
                return;
            }
            window.opener.$('#id_ubi').val(lista);
            window.opener.$('#nombre_ubi').val(txt);
            window.opener.$('#span_nom_ubi').html(txt);
            alert("<?= $txt_alert ?>");
            window.close();
        }
        if (opcion == 4) {
            /* OJO. este id_ubi no puede tener otro nombre, porque viene de una página
            *  "actividad_tipo_get.php" que también da los datos a otros programas.
            */
            var txt = document.frm_buscar_4.frm_4_nombre_ubi.value;
            if (!txt) {
                alert("<?= _("tiene que escribir un lugar") ?>");
                return;
            }
            window.opener.$('#id_ubi').val(1);
            window.opener.$('#span_nom_ubi').html(txt);
            window.opener.$('#lugar_esp').val(txt);
            alert("<?= $txt_alert ?>");
            window.close();
        }
        if (opcion == 5) {
            /* OJO. este id_ubi no puede tener otro nombre, porque viene de una página
            *  "actividad_tipo_get.php" que también da los datos a otros programas.
            */
            var txt = "<?= _("sin determinar") ?>";
            if (!txt) {
                alert("<?= _("tiene que escribir un lugar") ?>");
                return;
            }
            window.opener.$('#id_ubi').val("");
            window.opener.$('#span_nom_ubi').html(txt);
            window.opener.$('#lugar_esp').val("");
            alert("<?= $txt_alert ?>");
            window.close();
        }
    }
</script>
