{% block scripts %}
    <script>
        //Para que no de error al crear una nueva. Al cambiar tipo sv/sf, cambia la dl_org y dispara
        //esta función y no la encuentra.
        fnjs_actualizar_fases = function () {

        }

        $(function () {
            $("#f_ini").datepicker({
                numberOfMonths: 3,
                showButtonPanel: true
            });

        });

        $(function () {
            $("#f_fin").datepicker({
                numberOfMonths: 3,
                showButtonPanel: true
            });

        });

        // Para poner por defecto en el mismo dia que el inicio de actividad
        $("#f_fin").on("click", function () {
            let ini = $("#f_ini").val();
            let fin = $("#f_fin").val();
            if (ini && !fin) {
                $(this).datepicker('setDate', ini);
            }
        });

        /*
         * Para enviar los parámetros por POST
         * @type jQuery
         */
        fnjs_cambiar_ubi = function () {
            let dl_org = $('#dl_org').val();
            let ssfsv = $('#ssfsv').val();
            let isfsv = $('#isfsv_val option:selected').val();
            if (!isfsv) isfsv = '';
            let array_org = dl_org.split('#');
            let winPrefs = "dependent=yes,width=950,height=700,screenX=200,screenY=200,titlebar=yes,scrollbars=yes";
            let url = "{{ web }}/frontend/actividades/controller/actividad_select_ubi.php";
            let param_json = {dl_org: array_org[0], ssfsv: ssfsv, isfsv: isfsv};
            const decodeQP = (s) => {
                try {
                    return decodeURIComponent(String(s).replace(/\+/g, ' '));
                } catch (e) {
                    return s;
                }
            };
            let h_param = "{{ h|raw }}".replace(/^[?&]/, '');
            let params = h_param.split('&');
            for (let i = 0; i < params.length; i++) {
                if (!params[i]) continue;
                let eq = params[i].indexOf('=');
                if (eq === -1) continue;
                let k = decodeQP(params[i].substring(0, eq));
                let v = decodeQP(params[i].substring(eq + 1));
                param_json[k] = v;
            }
            $.post(url, param_json, function (result) {
                let WinId = window.open('', 'sele', winPrefs);
                WinId.document.open();
                WinId.document.write(result);
                WinId.document.close();
                $(WinId).trigger("focus");
            });
        }

        // Construye el body del POST a partir de la lista de campos firmados por el hash.
        // Importante: el hash de HashFront compara EXACTAMENTE los nombres de campo. Un
        // serialize() normal OMITE selects vacíos (p. ej. id_tarifa sin tarifas) y radios
        // sin marcar (publicado/status), dejando el campo fuera del POST → el hash falla y
        // el servidor redirige a index.php (HTML). Aquí forzamos que TODOS los campos de
        // datos vayan siempre (con '' si faltan) y solo añadimos los meta-hash presentes.
        fnjs_serialize_calendario_hash = function () {
            var allow = {{ calendario_hash_allow|default('{}')|raw }};
            var metaKeys = {h: 1, hh: 1, hhc: 1, hno: 1, hchk: 1, hnov: 1, horig: 1, hhorig: 1};
            var parts = [];
            Object.keys(allow).forEach(function (name) {
                var $el = $('#modifica [name="' + name + '"]');
                if (metaKeys[name] && !$el.length) {
                    return; // meta-hash no presente en este formulario: no enviar
                }
                var value = '';
                if ($el.length) {
                    if ($el.is(':radio') || $el.is(':checkbox')) {
                        var $chk = $el.filter(':checked');
                        value = $chk.length ? $chk.val() : '';
                    } else {
                        var v = $el.first().val();
                        value = (v == null ? '' : v);
                    }
                }
                parts.push(encodeURIComponent(name) + '=' + encodeURIComponent(String(value)));
            });
            return parts.join('&');
        };

        fnjs_guardar = function (tipo = '') {
            let err = 0;
            if (!fnjs_comprobar_fecha('#f_ini',{{ locale_us }})) {
                err = 1;
            }
            if (!fnjs_comprobar_fecha('#f_fin',{{ locale_us }})) {
                err = 1;
            }
            if (!fnjs_comprobar_hora('#h_ini')) {
                err = 1;
            }
            if (!fnjs_comprobar_hora('#h_fin')) {
                err = 1;
            }
            let dl_org = $('#dl_org').val();
            let estado = $('#status').val();

            /* comprobar si el id_tipo_actividad está completo */
            let id_sfsv_val = $('#isfsv_val').val();
            let id_asistentes_val = $('#iasistentes_val').val();
            let id_actividad_val = $('#iactividad_val').val();
            let id_nom_tipo_val = $('#inom_tipo_val').val();

            if (id_sfsv_val === '.') {
                alert("{{ "debe concretar la sección en el tipo de actividad"|trans|raw }}");
                err = 1;
            }
            if (id_asistentes_val === '.') {
                alert("{{ "debe concretar los asistentes en el tipo de actividad"|trans|raw }}");
                err = 1;
            }
            if (id_actividad_val === '.') {
                alert("{{ "debe concretar la actividad en el tipo de actividad"|trans|raw }}");
                err = 1;
            }
            if (id_nom_tipo_val === '...') {
                alert("{{ "debe concretar el tipo de actividad"|trans|raw }}");
                err = 1;
            }
            /* fin de tipo */

            if (!dl_org) {
                alert("{{ "debe llenar el campo de Organiza"|trans|raw }}");
                err = 1;
            }

            if (err === 0) {
                if ($('#isfsv_val').length) {
                    $('#id_tipo_activ').val(
                        String($('#isfsv_val').val() || '') +
                        String($('#iasistentes_val').val() || '') +
                        String($('#iactividad_val').val() || '') +
                        String($('#inom_tipo_val').val() || '')
                    );
                }
                $('#mod').val(tipo);
                let url = '{{ web }}/frontend/actividades/controller/actividad_mutacion_ajax.php';
                let data = fnjs_serialize_calendario_hash();

                $.ajax({
                    data: data,
                    url: url,
                    type: 'post',
                    dataType: 'json'
                }).done(function (respuesta) {
                    if (respuesta.success !== true) {
                        alert('{{ "respuesta"|trans|raw }}: ' + (respuesta.mensaje || ''));
                    } else {
                        // Esta función está en planning_casa_select.phtml
                        fnjs_cerrar();
                        fnjs_ver();
                    }
                }).fail(function (xhr, status, error) {
                    let detalle = error;
                    if (xhr.responseText) {
                        try {
                            let json = JSON.parse(xhr.responseText);
                            if (json.mensaje) {
                                detalle = json.mensaje;
                            }
                        } catch (e) {
                            detalle = xhr.responseText.trim().substring(0, 300);
                        }
                    }
                    alert('{{ "Error en la conexión con el servidor"|trans|raw }}: ' + detalle);
                });
            }
        }

        fnjs_tipo_actividad = function () {
            $('#modifica').attr('action', 'programas/actividad_nueva.php');
            $('#mod').val('cambiar_tipo');
            fnjs_enviar_formulario('#modifica');
        }
    </script>
{% endblock %}
