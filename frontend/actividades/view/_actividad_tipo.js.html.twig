<script>
{% include "@shared/_fnjs_construir_desplegable.inc.html.twig" %}
    // Parsea la respuesta JSON estandar de /src/actividades/actividad_tipo_get.
    // Devuelve la cadena `content` o '' si algo falla.
    fnjs_actividad_tipo_get_content = function (json) {
        if (!json || json.success !== true) {
            return '';
        }
        try {
            var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
            return data.content || '';
        } catch (e) {
            return '';
        }
    }

    // Construye el HTML de un `<select>` a partir del payload JSON estandar
    // de /src/actividades/actividad_tipo_get para salidas desplegable
    // (id, opciones, selected, blanco, val_blanco, action).
    /**
     * Ajusta el desplegable nivel_stgr al valor por defecto que calcularía
     * {@see ActividadVerDatos::nivelStgrPorDefectoParaIdTipoActividad} (vía salida AJAX).
     */
    fnjs_actualizar_nivel_stgr = function () {
        if (!$('#nivel_stgr').length) {
            return;
        }
        var id_tipo_activ = $('#id_tipo_activ').val() || '';
        if (!id_tipo_activ || id_tipo_activ.indexOf('.') !== -1) {
            return;
        }
        var url = '{{ url }}';
        var extendida = $('#extendida').val();
        var parametros = 'extendida=' + extendida + '&modo=buscar&salida=nivel_stgr_defecto&entrada=' + id_tipo_activ + '{{ h|raw }}';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (json) {
            var nivel = fnjs_actividad_tipo_get_content(json);
            if (nivel === '') {
                return;
            }
            var $sel = $('#nivel_stgr');
            if ($sel.length && $sel.find('option[value="' + nivel + '"]').length) {
                $sel.val(nivel);
            }
        });
    };

    fnjs_asistentes = function () {
        var url = '{{ url }}';
        var extendida = $('#extendida').val();
        var isfsv = $('#isfsv_val').val();
        if (isfsv == 3) {
            $('#iasistentes_val').hide();
            $('#iactividad_val').hide();
            fnjs_nom_tipo();
        } else {
            var parametros = 'extendida='+extendida+'&modo=buscar&salida=asistentes&entrada=' + isfsv + '{{ h|raw }}';

            $.ajax({
                url: url,
                type: 'post',
                data: parametros,
                dataType: 'json'
            })
                .done(function (json) {
                    $('#lst_asistentes').html(fnjs_construir_desplegable(json));
                    {% if procesos_installed %}
                    fnjs_actualizar_fases();
                    {% endif %}
                });
            // borrar el resto.
            $('#iasistentes_val').val(".");
            if (extendida === "1") {
                $('#iactividad_val').val("..");
                $('#inom_tipo_val').val("..");
            } else {
                $('#iactividad_val').val(".");
                $('#inom_tipo_val').val("...");
            }
        }
        // Si está el campo dl_org, Al cambiar sf/sv, también debe
        // cambiarse el desplegable de dl_org.
        var dl_org = $('#dl_org').val
        if (dl_org) {
            var parametros = 'extendida='+extendida+'&modo=buscar&salida=dl_org&entrada=' + isfsv + '{{ h|raw }}';

            $.ajax({
                url: url,
                type: 'post',
                data: parametros,
                dataType: 'json'
            })
                .done(function (json) {
                    var html = fnjs_construir_desplegable(json);
                    if (html) { $('#dl_org').replaceWith(html); }
                });
        }
        // y ya puestos el del filtro lugar:
        var filtro_lugar = $('#filtro_lugar').val
        if (filtro_lugar) {
            var parametros = 'extendida='+extendida+'&modo=buscar&salida=filtro_lugar&entrada=' + isfsv + '{{ h|raw }}';

            $.ajax({
                url: url,
                type: 'post',
                data: parametros,
                dataType: 'json'
            })
                .done(function (json) {
                    var html = fnjs_construir_desplegable(json);
                    if (html) { $('#filtro_lugar').replaceWith(html); }
                });
        }
    }
    fnjs_actividad = function () {
        var url = '{{ url }}';
        var extendida = $('#extendida').val();
        var isfsv = $('#isfsv_val').val();
        var iasistentes = $('#iasistentes_val').val();
        var salida = 'actividad';
        var parametros = 'extendida='+extendida+'&modo=buscar&salida=' + salida + '&entrada=' + isfsv + iasistentes + '{{ h|raw }}';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        })
            .done(function (json) {
                $('#lst_actividad').html(fnjs_construir_desplegable(json));
                {% if procesos_installed %}
                fnjs_actualizar_fases();
                {% endif %}
            });
    }
    fnjs_nom_tipo = function () {
        var url = '{{ url }}';
        var extendida = $('#extendida').val();
        var isfsv = $('#isfsv_val').val();
        var iasistentes = $('#iasistentes_val').val();
        var iactividad = $('#iactividad_val').val();
        var parametros = 'extendida='+extendida+'&modo=buscar&salida=nom_tipo&entrada=' + isfsv + iasistentes + iactividad + '{{ h|raw }}';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        })
            .done(function (json) {
                $('#lst_nom_tipo').html(fnjs_construir_desplegable(json));
                {% if procesos_installed %}
                fnjs_actualizar_fases();
                {% endif %}
            });
    }
    fnjs_id_activ = function () {
        var url = '{{ url }}';
        var que = $('#que').val();
        var extendida = $('#extendida').val();
        var isfsv = $('#isfsv_val').val();
        var iasistentes = $('#iasistentes_val').val();
        var iactividad = $('#iactividad_val').val();
        var inom_tipo = $('#inom_tipo_val').val();
        var id_tipo_activ = isfsv + iasistentes + iactividad + inom_tipo;

        $('#id_tipo_activ').val(id_tipo_activ);
        // buscar la id_tarifa para este tipo de actividad
        var parametros = 'extendida='+extendida+'&modo=buscar&salida=id_tarifa&entrada=' + id_tipo_activ + '{{ h|raw }}';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        })
            .done(function (json) {
                $('#id_tarifa').val(fnjs_actividad_tipo_get_content(json));
                {% if procesos_installed %}
                fnjs_actualizar_fases();
                {% endif %}
                fnjs_actualizar_nivel_stgr();
            });
    }
    fnjs_act_id_activ = function () {
        var url = '{{ url }}';
        var que = $('#que').val();
        var extendida = $('#extendida').val();
        var isfsv = $('#isfsv_val').val();
        var iasistentes = $('#iasistentes_val').val();
        var iactividad = $('#iactividad_val').val();
        var inom_tipo = $('#inom_tipo_val').val();
        var id_tipo_activ = isfsv + iasistentes + iactividad + inom_tipo;

        $('#id_tipo_activ').val(id_tipo_activ);
        // buscar la id_tarifa para este tipo de actividad
        var parametros = 'extendida='+extendida+'&modo=buscar&salida=id_tarifa&entrada=' + id_tipo_activ + '{{ h|raw }}';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        })
            .done(function (json) {
                $('#id_tarifa').val(fnjs_actividad_tipo_get_content(json));
                {% if not procesos_installed %}
                fnjs_actualizar_nivel_stgr();
                {% endif %}
            });
        // buscar el desplegable dl_org segun permisos en procesos
        // Como también afecta al status de la actividad, mejor rehacer toda la página.
        {% if procesos_installed %}
        if ($('#modifica').closest('#div_modificar').length === 0) {
            url = '{{ url_act }}';
            var parametros = 'refresh=1&id_tipo_activ=' + id_tipo_activ + '{{ h_act|raw }}';
            fnjs_ajax_json_html({ url: url, data: parametros, target: '#main' });
        } else {
            fnjs_actualizar_nivel_stgr();
        }
        {% endif %}

        if (que == "cambiar_tipo" && confirm("{{ "¿Quiere cambiar el nombre de la actividad?"|trans|raw }}")) {
            fnjs_generarNomActiv('#modifica');
        }
    }
</script>
