</table>
<br>
    <input TYPE="button" onclick="fnjs_buscar('{{ accion }}')" id="btn_ok" name="btn_ok"
           value="{{ "buscar"|trans|raw }}" class="btn_ok">
        <input TYPE="reset" VALUE="borrar" onclick="fnjs_update_div('#main','{{ Link_borrar|raw }}')">
        </form>
        <script>
            /*fnjs_lugar();*/
        </script>
    </div>
