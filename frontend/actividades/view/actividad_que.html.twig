{% block scripts %}
<script>

    fnjs_comprobar_fase_no_duplicadas=function() {
    var fases_on=[];
    $('input[name="fases_on[]"]:checked').each(function() {
    fases_on.push(parseInt($(this).val()));
});
    var fases_off=[];
    $('input[name="fases_off[]"]:checked').each(function() {
    fases_off.push(parseInt($(this).val()));
});

    $.arrayIntersect = function(a, b) {
    return $.grep(a, function(i) {
    return $.inArray(i, b) > -1;
});
};

    rta = $.arrayIntersect(fases_on, fases_off);

    if (rta.length === 0) {
    return true;
} else {
    return false;
}
}

    fnjs_actualizar_fases=function(selected_on, selected_off){
    var dl_org=$('#dl_org').val();
    if (dl_org == '{{ mi_dele }}' ) {
    dl_propia = 't';
} else {
    dl_propia = 'f';
}
    var extendida=$('#extendida').val();
    var isfsv=$('#isfsv_val').val();
    var iasistentes=$('#iasistentes_val').val();
    var iactividad=$('#iactividad_val').val();
    var inom_tipo=$('#inom_tipo_val').val();

    if (!iasistentes) iasistentes='.';
    if(!extendida) {
    if (!iactividad) iactividad = '.';
    if (!inom_tipo) inom_tipo = '...';
} else {
    if (!iactividad || iactividad === '.') iactividad = '..';
    if (!inom_tipo || inom_tipo === '...') inom_tipo = '..';
}

    id_tipo_activ=isfsv+iasistentes+iactividad+inom_tipo;

    // Si no se pasa el estado a preservar explicito, lo recuperamos de los checkboxes actuales.
    if (typeof selected_on === 'undefined') {
    selected_on = $('input[name="fases_on[]"]:checked').map(function(){return $(this).val();}).get().join(',');
}
    if (typeof selected_off === 'undefined') {
    selected_off = $('input[name="fases_off[]"]:checked').map(function(){return $(this).val();}).get().join(',');
}

    var url='{{ url_actualizar_fases }}';
    var params_on='dl_propia='+dl_propia+'&id_tipo_activ='+id_tipo_activ+'&selected='+encodeURIComponent(selected_on)+'{{ h_actualizar_fases|raw }}';
    var params_off='dl_propia='+dl_propia+'&id_tipo_activ='+id_tipo_activ+'&selected='+encodeURIComponent(selected_off)+'{{ h_actualizar_fases|raw }}';
    fnjs_construir_cuadro_fases(url, params_on, 'fases_on', '#td_fases_on');
    fnjs_construir_cuadro_fases(url, params_off, 'fases_off', '#td_fases_off');
}

    fnjs_construir_cuadro_fases=function(url, params, name, selector){
    $.ajax({
    url: url,
    type: 'post',
    data: params,
    dataType: 'json'
})
    .done(function (json) {
    if (!json || json.success !== true) { return; }
    var payload = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
    var aFases = (payload && payload.a_fases) ? payload.a_fases : [];
    var html = '';
    $.each(aFases, function (_i, fase) {
    var chk = fase.checked ? ' checked' : '';
    html += "<input type='checkbox' name='"+name+"[]' value='"+fase.id+"'"+chk+" /> "+fase.nom;
});
    $(selector).html(html);
});
}

    fnjs_buscar=function(act){
    var err = 0;
    var f=$('#periodo').val();
    if (f=='otro') {
    if (!fnjs_comprobar_fecha('#empiezamin',{{ locale_us }})) {
    err=1;
    alert("{{ "debe inrtoducir la fecha inicio del periodo"|trans|raw }}");
}
    if (!fnjs_comprobar_fecha('#empiezamax',{{ locale_us }})) {
    err=1;
    alert("{{ "debe introducir la fecha fin del periodo"|trans|raw }}");
}
}
    // coprobar que no exista la misma fase en condición 'on' y 'off'
    {% if proceso_installed %}
    if (!fnjs_comprobar_fase_no_duplicadas()) {
    err=1;
    alert("{{ "No puede seleccionar la misma fase como 'marcada' y 'sin marcar'"|trans|raw }}");
}
    {% endif %}

    if (err != 1) {
    /* genero el id_tipo_actividad */
    var extendida=$('#extendida').val();
    var isfsv=$('#isfsv_val').val();
    var iasistentes=$('#iasistentes_val').val();
    var iactividad=$('#iactividad_val').val();
    var inom_tipo=$('#inom_tipo_val').val();
    if (!isfsv) isfsv=".";
    if (!iasistentes) iasistentes=".";
    if(!extendida) {
    if (!iactividad) iactividad = '.';
    if (!inom_tipo) inom_tipo = '...';
} else {
    if (!iactividad || iactividad === '.') iactividad = '..';
    if (!inom_tipo || inom_tipo === '...') inom_tipo = '..';
}
    var id=isfsv+iasistentes+iactividad+inom_tipo;

    $('#id_tipo_activ').val(id);
    $('#modifica').attr('action',act);
    fnjs_enviar_formulario('#modifica');
}
}
    // Payload ya parseado (actividad_que_filtros / actividad_tipo_get tras JSON.parse).
    // Nombre distinto de fnjs_construir_desplegable en _actividad_tipo.js (espera el envelope JSON).
    fnjs_construir_desplegable_payload = function (data) {
        if (!data) { return ''; }
        var $sel = $('<select></select>').attr({ id: data.id, name: data.id });
        if (data.action) { $sel.attr('onchange', data.action); }
        if (data.blanco !== false) {
            var vb = (data.val_blanco !== undefined && data.val_blanco !== null) ? data.val_blanco : '';
            $sel.append($('<option></option>').val(vb).text(''));
        }
        var opcionNo = {};
        if (data.opcion_no && data.opcion_no.length) {
            data.opcion_no.forEach(function (v) { opcionNo[String(v)] = true; });
        }
        $.each(data.opciones || {}, function (value, label) {
            if (opcionNo[String(value)]) { return; }
            var $opt = $('<option></option>').val(value).text(label);
            if (data.selected !== undefined && data.selected !== '' && String(data.selected) === String(value)) {
                $opt.prop('selected', true);
            }
            $sel.append($opt);
        });
        return $sel.prop('outerHTML');
    };

    fnjs_construir_filtros_extra = function (data) {
        if (!data || !data.visible) { return ''; }
        var labels = data.labels || {};
        var esc = function (s) { return $('<div/>').text(s || '').html(); };
        var html = '<tr>';
        html += '<td class="etiqueta">' + esc(labels.lugar_pais_dl) + ':</td>';
        html += '<td colspan="3">' + fnjs_construir_desplegable_payload(data.filtro_lugar) + '</td>';
        html += '<td class="etiqueta">' + esc(labels.lugar) + '</td>';
        html += '<td id="lst_lugar" colspan="1">' + (data.lugar ? fnjs_construir_desplegable_payload(data.lugar) : '') + '</td>';
        html += '</tr>';
        html += '<tr>';
        html += '<td class="etiqueta">' + esc(labels.organiza) + ':</td>';
        html += '<td colspan="3">' + fnjs_construir_desplegable_payload(data.dl_org) + '</td>';
        var pub = data.publicado || {};
        if (pub.show) {
            var chk1 = pub.value === 1 ? "checked='true'" : '';
            var chk2 = pub.value === 2 ? "checked='true'" : '';
            var chk3 = (pub.value !== 1 && pub.value !== 2) ? "checked='true'" : '';
            html += '<td>' + esc(labels.publicada) + ':';
            html += '<input type="radio" name="publicado" value="1" ' + chk1 + ' />' + esc(labels.si);
            html += '<input type="radio" name="publicado" value="2" ' + chk2 + ' />' + esc(labels.no);
            html += '<input type="radio" name="publicado" value="3" ' + chk3 + ' />' + esc(labels.todas);
            html += '</td>';
        }
        html += '</tr>';
        return html;
    };

    fnjs_lugar=function(){
    var opcion_sel='{{ Qid_ubi }}';
    var extendida=$('#extendida').val();
    var isfsv=$('#isfsv_val').val();
    var filtro_lugar=$('#filtro_lugar').val();
    var url='src/actividades/actividad_tipo_get';
    var parametros='extendida=' + extendida + '&modo=buscar&salida=lugar&entrada='+filtro_lugar+'&opcion_sel='+opcion_sel+'&isfsv='+isfsv+'{{ h|raw }}';
    $.ajax({
    url: url,
    type: 'post',
    data: parametros,
    dataType: 'json'
})
    .done(function (json) {
    if (!json || json.success !== true) { return; }
    try {
        var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
        $('#lst_lugar').html(fnjs_construir_desplegable_payload(data));
    } catch (e) {}
});
}
    fnjs_left_side_hide();

    fnjs_cargar_filtros_extra=function(){
    $.ajax({
        url: '{{ url_filtros }}',
        type: 'post',
        data: 'sfsv={{ Qsfsv }}&modo={{ modo }}&dl_org={{ Qdl_org }}&filtro_lugar={{ Qfiltro_lugar }}&id_ubi={{ Qid_ubi }}&publicado={{ Qpublicado }}{{ h_filtros|raw }}',
        dataType: 'json'
    })
            .done(function (json) {
                if (!json || json.success !== true) { return; }
                try {
                    var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                    $('#filtros_extra').html(fnjs_construir_filtros_extra(data));
                } catch (e) {}
            });
}

    $(function(){
    fnjs_cargar_filtros_extra();
    {% if proceso_installed %}
    fnjs_actualizar_fases('{{ fases_on_csv }}', '{{ fases_off_csv }}');
    {% endif %}
});
</script>
{% endblock %}
