$incremento_txt = '';
$prevision_txt = '';
foreach ($a_tarifas_actual as $id_tarifa => $aTarifa) {
    $tar_txt .= '<td>' . htmlspecialchars((string)$aTarifa['letra']) . '</td>';
    $cantidad_txt .= '<td>' . htmlspecialchars((string)$aTarifa['cantidad']) . '</td>';
    $cantidad_actual = (float)($aTarifa['cantidad'] ?? 0);
    $cantidad_prev = (float)($a_tarifas_prev[$id_tarifa]['cantidad'] ?? 0);
    $inc = $cantidad_actual == 0.0 ? _("no disponible") : round((($cantidad_prev / $cantidad_actual) - 1) * 100);
    $incremento_txt .= '<td>' . $inc . '%</td>';
}
foreach ($a_tarifas_prev as $id_tarifa => $aTarifa) {
    $valor = (string)($aTarifa['cantidad'] ?? '');
    $id_item = (int)($aTarifa['id_item'] ?? 0);
    $index = "$id_tarifa#$id_item";
    $prevision_txt .= "<td><input type=\"text\" name=\"inc_cantidad[$index]\" size=\"4\" value=\"$valor\"></td>";
}
