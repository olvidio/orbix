<?php
/**
 * Vista principal de los grupos de casas (padre ↔ hijo).
 *
 * Shell con `#ficha` (lista) + `#div_modificar` (form) + `#overlay`.
 * El listado se carga via AJAX HTML desde `grupo_lista.php`; el form
 * desde `grupo_form.php`. Las mutaciones llaman a
 * `/src/casas/grupo_update` y `/src/casas/grupo_eliminar`.
 *
 * @var string $url_lista
 * @var string $url_form
 * @var string $url_update
 * @var string $url_eliminar
 * @var string $txt_eliminar
 */
?>
<script>
    var URL_LISTA = <?= json_encode($url_lista) ?>;
    var URL_FORM = <?= json_encode($url_form) ?>;
    var URL_UPDATE = <?= json_encode($url_update) ?>;
    var URL_ELIMINAR = <?= json_encode($url_eliminar) ?>;
    var TXT_ELIMINAR = <?= json_encode($txt_eliminar) ?>;
    var TXT_ERR_COMUNICACION = <?= json_encode(_("error de comunicación con el servidor")) ?>;
    var TXT_DEBE_CASAS = <?= json_encode(_("debe indicar las dos casas")) ?>;
    var TXT_NO_MISMA_CASA = <?= json_encode(_("No puede ser la misma casa")) ?>;

    fnjs_cerrar = function () {
        $('#div_modificar').html('');
        $('#div_modificar').width('0');
        $('#div_modificar').height('0');
        $('#div_modificar').removeClass('ventana');
        document.getElementById("overlay").style.display = "none";
    };

    fnjs_ver = function () {
        $.ajax({ url: URL_LISTA, type: 'post' }).done(function (rta_txt) {
            if (rta_txt) { $('#ficha').html(rta_txt); }
        });
        document.getElementById("overlay").style.display = "none";
    };

    fnjs_modificar = function (id_item) {
        $('#div_modificar').addClass('ventana');
        $('#div_modificar').width('auto');
        $('#div_modificar').height('auto');
        document.getElementById("overlay").style.display = "block";
        var sep = URL_FORM.indexOf('?') === -1 ? '?' : '&';
        fnjs_update_div('#div_modificar', URL_FORM + sep + 'id_item=' + encodeURIComponent(id_item));
    };

    fnjs_eliminar = function (id_item) {
        if (!confirm(TXT_ELIMINAR)) { return; }
        $.ajax({
            url: URL_ELIMINAR,
            type: 'post',
            data: { id_item: id_item },
            dataType: 'json'
        }).done(function (rta) {
            if (!rta || rta.success !== true) {
                alert((rta && rta.mensaje) ? rta.mensaje : '');
                return;
            }
            fnjs_ver();
        }).fail(function () { alert(TXT_ERR_COMUNICACION); });
    };

    fnjs_guardar = function (formulario) {
        var madre = $('#id_ubi_padre').val();
        var hija = $('#id_ubi_hijo').val();
        if (!madre || !hija) {
            alert(TXT_DEBE_CASAS);
            return;
        }
        if (madre === hija) {
            alert(TXT_NO_MISMA_CASA);
            return;
        }
        $('#' + formulario).attr('action', URL_UPDATE);
        $('#' + formulario).one("submit", function () {
            $.ajax({
                url: $(this).attr('action'),
                type: 'post',
                data: $(this).serialize(),
                dataType: 'json'
            }).done(function (rta) {
                if (!rta || rta.success !== true) {
                    alert((rta && rta.mensaje) ? rta.mensaje : '');
                    return;
                }
                fnjs_cerrar();
                fnjs_ver();
            }).fail(function () { alert(TXT_ERR_COMUNICACION); });
            return false;
        });
        $('#' + formulario).trigger("submit");
        $('#' + formulario).off();
    };

    $(document).ready(function () { fnjs_ver(); });
</script>

<h1><?= _("grupos de casas") ?></h1>
<div id="ficha"></div>
<div id="div_modificar"></div>
<div id="overlay"></div>
