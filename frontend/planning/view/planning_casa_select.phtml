<?php

use frontend\shared\config\AppUrlConfig;

?>
<script>
    fnjs_nueva_activ = function (id_ubi) {
        $('#div_modificar').addClass('ventana');
        $('#div_modificar').width('auto');
        $('#div_modificar').height('auto');
        document.getElementById("overlay").style.display = "block";

        var url = '<?= AppUrlConfig::getPublicAppBaseUrl() ?>/frontend/actividades/controller/planning_casa_nueva.php';
        var parametros = 'id_ubi=' + id_ubi + "&<?= $param_new ?>";

        fnjs_update_div('#div_modificar', url + '?' + parametros, 1);
    }
    fnjs_cambiar_activ = function (id_activ) {
        $('#div_modificar').addClass('ventana');
        $('#div_modificar').width('auto');
        $('#div_modificar').height('auto');
        document.getElementById("overlay").style.display = "block";

        var url = '<?= AppUrlConfig::getPublicAppBaseUrl() ?>/frontend/actividades/controller/planning_casa_modificar.php';
        var parametros = 'id_activ=' + id_activ + "&<?= $param_mod ?>";

        fnjs_update_div('#div_modificar', url + '?' + parametros, 1);
    }
    fnjs_cerrar = function () {
        $('#div_modificar').html('');
        $('#div_modificar').width('0');
        $('#div_modificar').height('0');
        $('#div_modificar').removeClass('ventana');
        document.getElementById("overlay").style.display = "none";
    }

    fnjs_planning_ajustar_viewport = function () {
        var exportar = document.getElementById('exportar');
        if (!exportar) {
            return;
        }
        var marginRight = 20;
        var marginBottom = 20;
        var rect = exportar.getBoundingClientRect();
        exportar.style.overflow = 'auto';
        exportar.style.width = Math.max(window.innerWidth - rect.left - marginRight, 200) + 'px';
        exportar.style.height = Math.max(window.innerHeight - rect.top - marginBottom, 200) + 'px';
    }

    fnjs_ver = function () {
        var url = '<?= AppUrlConfig::getPublicAppBaseUrl() ?>/frontend/planning/controller/planning_casa_ver.php';
        var parametros = "<?= $param_ver ?>";

        $('#ficha').html('');
        $(window).off('resize.planningCasaVer');
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            complete: function (respuesta) {
                var html = fnjs_extract_html_from_ajax_body(respuesta.responseText || '');
                $('#ficha').html(html);
                fnjs_planning_ajustar_viewport();
                $(window).on('resize.planningCasaVer', fnjs_planning_ajustar_viewport);
                document.getElementById("overlay").style.display = "none";
            },
            error: function () {
                alert(<?= json_encode(_('Error de página devuelta'), JSON_UNESCAPED_UNICODE) ?>);
                document.getElementById("overlay").style.display = "none";
            }
        });
    }
</script>
<?= $oPosicion->mostrarNavAtras(1) ?>

<div id='ficha'></div>
<div id='div_modificar'></div>
<div id='overlay'></div>
<script>fnjs_ver();</script>
