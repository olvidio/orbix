<script>
    <?php
    if (!empty($plazas_installed)) {
    ?>
    <?php require __DIR__ . '/../../shared/view/_fnjs_construir_desplegable.inc.phtml'; ?>
    fnjs_construir_desplegable_propietario = fnjs_construir_desplegable;
    fnjs_cmb_propietario = function () {
        var id_nom = $('#id_nom').val();
        var url = '<?= $url_ajax ?>';
        var parametros = 'id_nom=' + id_nom + '&id_activ=<?= $id_activ ?><?= $h1 ?>';

        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (json) {
            if (!json || json.success !== true) { return; }
            try {
                var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                $('#lst_propietarios').html(fnjs_construir_desplegable_propietario(data));
            } catch (e) {}
        });
    }

    <?php
    }
    ?>
    fnjs_guardar = function (formulario, repetir) {
        $(formulario).attr('action', "<?= $url_guardar ?>");
        $(formulario).one("submit", function () {
            $.ajax({
                url: $(this).attr('action'),
                type: 'post',
                dataType: 'json',
                data: $(this).serialize()
            }).done(function (rta) {
                if (rta && rta.success) {
                    if (repetir === 1) {
                        $('#id_nom').val(0);
                        $('#propio').prop('checked', true);
                        $('#falta').prop('checked', false);
                        $('#est_ok').prop('checked', false);
                        $('#observ').html('');
                        $('#observ_est').html('');
                        $('#plaza').val(1);
                        $('propietario').val(0);
                        $('#actualizar').val(1);
                    } else {
                                                <?= \frontend\shared\helpers\ListNavSupport::jsAtrasToDossiersParent($oPosicion); ?>
                    }
                } else {
                    var msg = (rta && rta.mensaje) ? rta.mensaje : <?= json_encode(_("error desconocido")) ?>;
                    alert(<?= json_encode(_("respuesta") . ": ") ?> + msg);
                }
            }).fail(function () {
                alert(<?= json_encode(_("error de comunicación con el servidor")) ?>);
            });
            return false;
        });
        $(formulario).trigger("submit");
        $(formulario).off();
    }

    fnjs_nuevo = function (formulario) {
        $(formulario).attr('action', "<?= $url_self ?>");
        fnjs_enviar_formulario(formulario, '#ficha3101');
    }
</script>
