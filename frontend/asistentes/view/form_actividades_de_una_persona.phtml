<script>
    <?php
    use core\ConfigGlobal;if (ConfigGlobal::is_app_installed('actividadplazas')) {
    ?>
    fnjs_construir_desplegable_propietario = function (data) {
        if (!data) { return ''; }
        var id = data.id || 'propietario';
        var $sel = $('<select></select>').attr({ id: id, name: id });
        if (data.action) { $sel.attr('onchange', data.action); }
        if (data.blanco) {
            var vb = (data.val_blanco !== undefined && data.val_blanco !== null) ? data.val_blanco : '';
            $sel.append($('<option></option>').val(vb).text(''));
        }
        var opciones = data.opciones || {};
        $.each(opciones, function (value, label) {
            var $opt = $('<option></option>').val(value).text(label);
            if (data.selected !== undefined && data.selected !== '' && String(data.selected) === String(value)) {
                $opt.prop('selected', true);
            }
            $sel.append($opt);
        });
        return $sel.prop('outerHTML');
    };
    fnjs_cmb_propietario = function () {
        var id_activ = $('#id_activ').val();
        var url = '<?= $url_ajax ?>';
        var parametros = 'id_nom=<?= $id_nom ?>&id_activ=' + id_activ + '<?= $h1 ?>';

        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (json) {
            if (!json || json.success !== true) { return; }
            try {
                var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                $('#lst_propietarios').html(fnjs_construir_desplegable_propietario(data));
            } catch (e) {}
        });
    }

    <?php
    }
    ?>
    fnjs_guardar = function (formulario) {
        id_activ = $('#id_activ').val();
        if (!id_activ) {
            alert("<?= _("debe indicar una actividad") ?>");
            return;
        }
        var rr = fnjs_comprobar_campos(formulario, '<?= addslashes($obj) ?>');
        if (rr === 'ok') {
            $(formulario).attr('action', "<?= $url_guardar ?>");
            $(formulario).one("submit", function () {
                $.ajax({
                    url: $(this).attr('action'),
                    type: 'post',
                    dataType: 'json',
                    data: $(this).serialize()
                }).done(function (rta) {
                    if (rta && rta.success) {
                        <?= $oPosicion->js_atras(1); ?>
                    } else {
                        var msg = (rta && rta.mensaje) ? rta.mensaje : '<?= _("error desconocido") ?>';
                        alert('<?= _("respuesta") ?>: ' + msg);
                    }
                }).fail(function () {
                    alert('<?= _("error de comunicación con el servidor") ?>');
                });
                return false;
            });
            $(formulario).trigger("submit");
            $(formulario).off();
        }
    }
</script>
