<script>
    fnjs_modificar = function (formulario) {
        rta = fnjs_solo_uno(formulario);
        if (rta == 1) {
            $('#mod').val("editar");
            $(formulario).attr('action', "<?= $url_form ?>");
            fnjs_enviar_formulario(formulario, '<?= $bloque ?>');
        }
    }
    fnjs_borrar = function (formulario) {
        rta = fnjs_solo_uno(formulario);
        if (rta == 1) {
            if (confirm(<?= json_encode((string)$txt_eliminar) ?>)) {
                $('#mod').val("eliminar");
                $(formulario).attr('action', "<?= $url_eliminar ?>");
                $(formulario).one("submit", function () {
                    $.ajax({
                        url: $(this).attr('action'),
                        type: 'post',
                        dataType: 'json',
                        data: $(this).serialize()
                    }).done(function (rta) {
                        if (rta && rta.success) {
                            fnjs_actualizar(formulario);
                        } else {
                            var msg = (rta && rta.mensaje) ? rta.mensaje : <?= json_encode(_("error desconocido")) ?>;
                            alert(<?= json_encode(_("respuesta") . ": ") ?> + msg);
                        }
                    }).fail(function () {
                        alert(<?= json_encode(_("error de comunicación con el servidor")) ?>);
                    });
                    return false;
                });
                $(formulario).trigger("submit");
                $(formulario).off();
            }
        }
    }
    fnjs_actualizar = function (formulario) {
        var campo = '<input type="hidden" name="refresh" value=1>';
        $(formulario).attr('action', "frontend/dossiers/controller/dossiers_ver.php");
        $(formulario).append(campo);
        fnjs_enviar_formulario(formulario, '#main');
    }
</script>
