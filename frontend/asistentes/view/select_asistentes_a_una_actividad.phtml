    fnjs_cmb_plaza = function (formulario, plaza) {
        var form = $(formulario).attr('id');
        var lista_json = JSON.stringify($('#' + form + ' input.sel:checked').serializeArray());
        var url = '<?= htmlspecialchars((string) $url_plaza_asignar, ENT_QUOTES, 'UTF-8') ?>';
        var parametros = 'plaza=' + plaza + '&lista_json=' + lista_json + '&id_activ=<?= $id_pau ?><?= $h4 ?>';
        $(formulario).one("submit", function () {
            $.ajax({
                url: url,
                type: 'post',
                dataType: 'json',
                data: parametros
            }).done(function (rta) {
                if (rta && rta.success) {
                    fnjs_actualizar(formulario);
                } else {
                    var msg = (rta && rta.mensaje) ? rta.mensaje : <?= json_encode(_("error desconocido")) ?>;
                    alert(<?= json_encode(_("respuesta") . ": ") ?> + msg);
                }
                }).fail(function () {
                alert(<?= json_encode(_("error de comunicación con el servidor")) ?>);
            });
            return false;
        });
        $(formulario).trigger("submit");
        $(formulario).off();
    }
