    fnjs_borrar_cargo = function (formulario) {
        var rta = fnjs_solo_uno(formulario);
        if (rta !== 1) {
            return;
        }
        if (!confirm(<?= json_encode(_("¿Está seguro que desea quitar este cargo a esta persona?")) ?>)) {
            return;
        }
        $('#mod').val("eliminar");
        $.ajax({
            url: '<?= htmlspecialchars((string) $url_cargo_eliminar, ENT_QUOTES, 'UTF-8') ?>',
            type: 'post',
            dataType: 'json',
