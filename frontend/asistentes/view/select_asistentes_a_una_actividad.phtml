            if (confirm(<?= json_encode((string)$txt_eliminar) ?>)) {
                $('#mod').val("eliminar");
                $(formulario).attr('action', "<?= htmlspecialchars((string) $url_eliminar, ENT_QUOTES, 'UTF-8') ?>");
