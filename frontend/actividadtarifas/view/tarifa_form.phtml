<?php
/**
 * Form modificar/nuevo de `TipoTarifa` (HTML AJAX).
 *
 * Se inyecta en `#div_modificar` desde `tarifa.phtml`. Los inputs con
 * `name` coinciden con los campos esperados por
 * `/src/actividadtarifas/tipo_tarifa_update` + `tipo_tarifa_eliminar`.
 *
 * @var string           $id_tarifa
 * @var bool             $es_nuevo
 * @var string           $letra
 * @var string           $observ
 * @var frontend\shared\web\Desplegable  $oDesplModo
 */

$id_tarifa_esc = htmlspecialchars($id_tarifa, ENT_QUOTES, 'UTF-8');
$letra_esc = htmlspecialchars($letra, ENT_QUOTES, 'UTF-8');
$observ_esc = htmlspecialchars($observ, ENT_QUOTES, 'UTF-8');
?>
<form id="frm_tarifa">
    <input type="hidden" name="id_tarifa" value="<?= $id_tarifa_esc ?>">
    <h3><?= _("tarifa") ?></h3>
    <?= _("letra") ?> <input type="text" size="3" name="letra" value="<?= $letra_esc ?>">
    &nbsp;&nbsp;
    <?= _("modo") ?> <?= $oDesplModo->desplegable() ?>
    <br><br>
    <?= _("observaciones") ?> <input type="text" size="25" name="observ" value="<?= $observ_esc ?>">
    <br><br>
    <input type="button" value="<?= _("guardar") ?>" onclick="fnjs_guardar('#frm_tarifa','update');">
    <?php if (!$es_nuevo): ?>
        <input type="button" value="<?= _("eliminar") ?>" onclick="fnjs_guardar('#frm_tarifa','eliminar');">
    <?php endif; ?>
    <input type="button" value="<?= _("cancel") ?>" onclick="fnjs_cerrar();">
</form>
