{# Form modificar de `RelacionTarifaTipoActividad` (HTML AJAX).
   Se inyecta en `#div_modificar` desde `tarifa_tipo_actividad.phtml`.
   El `<form id="modifica">` se serializa y se envia a
   `/src/actividadtarifas/relacion_tarifa_update` /
   `/src/actividadtarifas/relacion_tarifa_eliminar` desde el
   `fnjs_guardar` global (definido en la phtml shell). #}
<style>
    table {
        width: 600px;
    }
</style>
<form id="modifica">
    {{ oHash.getCamposHtml()|raw }}
    <div class="flex-container">
        <div>
            {{ "tipo de actividad"|trans|raw }}:
            <br>
            <span style="font-weight: bold">{{ oTipoActiv.getNom()|raw }}</span>
        </div>
        <div style="margin-top: 20px">
            {{ "tarifa"|trans|raw }}:
            {{ oDesplPosiblesTipoTarifas.desplegable()|raw }}
        </div>
    </div>
    <br><br>
    <input type="button" value="{{ "guardar"|trans|raw }}" onclick="fnjs_guardar('#modifica','update');">
    <input type="button" value="{{ "eliminar"|trans|raw }}" onclick="fnjs_guardar('#modifica','eliminar');">
    <input type="button" value="{{ "cancel"|trans|raw }}" onclick="fnjs_cerrar();">
</form>
