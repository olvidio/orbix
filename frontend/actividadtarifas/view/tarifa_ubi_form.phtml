<?php
/**
 * Form modificar/nuevo de `TarifaUbi` (HTML AJAX).
 *
 * Lleva dos cápsulas HashB opacas:
 *   - `ctx_update`:   autoriza `tarifa_ubi_update` sobre el contexto
 *                     firmado (`id_item` si edición, `id_ubi`, `year`).
 *   - `ctx_eliminar`: solo en edición, autoriza `tarifa_ubi_eliminar`
 *                     sobre `id_item`.
 * Los hidden `id_ubi`, `year`, `id_item` se mantienen por
 * compatibilidad de fase transitoria: el backend los ignora y usa
 * los valores de la cápsula.
 *
 * @var bool            $es_nuevo
 * @var string          $id_item
 * @var int             $id_ubi
 * @var int             $year
 * @var string          $letra
 * @var string          $cantidad
 * @var string          $token_update
 * @var string          $token_eliminar
 * @var frontend\shared\web\Desplegable $oDesplSeries
 * @var ?frontend\shared\web\Desplegable $oDesplTarifas  Solo alta.
 */

$id_item_esc = htmlspecialchars($id_item, ENT_QUOTES, 'UTF-8');
$letra_esc = htmlspecialchars($letra, ENT_QUOTES, 'UTF-8');
$cantidad_esc = htmlspecialchars($cantidad, ENT_QUOTES, 'UTF-8');
$token_update_esc = htmlspecialchars($token_update, ENT_QUOTES, 'UTF-8');
$token_eliminar_esc = htmlspecialchars($token_eliminar, ENT_QUOTES, 'UTF-8');
?>
<form id="frm_tarifa_ubi">
    <input type="hidden" name="ctx_update" value="<?= $token_update_esc ?>">
    <?php if (!$es_nuevo && $token_eliminar !== ''): ?>
        <input type="hidden" name="ctx_eliminar" value="<?= $token_eliminar_esc ?>">
    <?php endif; ?>
    <input type="hidden" name="id_ubi" value="<?= (int)$id_ubi ?>">
    <input type="hidden" name="year" value="<?= (int)$year ?>">
    <?php if (!$es_nuevo): ?>
        <input type="hidden" name="id_item" value="<?= $id_item_esc ?>">
    <?php endif; ?>
    <h3><?= sprintf(_("tarifa %s"), $letra_esc) ?></h3>
    <?php if ($es_nuevo && $oDesplTarifas !== null): ?>
        <?= _("tarifa") ?>: <?= $oDesplTarifas->desplegable() ?>
        <br><br>
        <?= _("serie") ?>: <?= $oDesplSeries->desplegable() ?>
        <br><br>
    <?php endif; ?>
    <?= _("nuevo importe") ?>:
    <input type="text" size="6" id="cantidad" name="cantidad" value="<?= $cantidad_esc ?>"
           onblur="fnjs_comprobar_dinero('#cantidad');">
    <?= _("€") ?>
    <br><br>
    <input type="button" value="<?= _("guardar") ?>" onclick="fnjs_guardar('#frm_tarifa_ubi','update');">
    <?php if (!$es_nuevo): ?>
        <input type="button" value="<?= _("eliminar") ?>" onclick="fnjs_guardar('#frm_tarifa_ubi','eliminar');">
    <?php endif; ?>
    <input type="button" value="<?= _("cancel") ?>" onclick="fnjs_cerrar();">
</form>
