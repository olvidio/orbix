<?php
/**
 * Vista principal del catalogo `TipoTarifa`.
 *
 * Renderiza un shell con `#ficha` (listado) + `#div_modificar` (form
 * modificar/nuevo) + `#overlay` (capa oscura). El listado se carga via
 * AJAX HTML desde `tarifa_lista.php`; el formulario desde
 * `tarifa_form.php`. Las mutaciones (`update`/`eliminar`) llaman a
 * `/src/actividadtarifas/tipo_tarifa_*` con JSON.
 *
 * @var string $url_lista     URL absoluta a `tarifa_lista.php`.
 * @var string $h_lista       Hash firmado para la lista.
 * @var string $url_form      URL absoluta a `tarifa_form.php`.
 * @var string $h_form        Hash firmado para el form.
 * @var string $url_update    URL absoluta JSON para guardar.
 * @var string $url_eliminar  URL absoluta JSON para eliminar.
 * @var string $txt_eliminar  Texto del confirm de eliminar.
 */
?>
<script>
    var URL_LISTA = <?= json_encode($url_lista . $h_lista) ?>;
    var URL_FORM = <?= json_encode($url_form . $h_form) ?>;
    var URL_UPDATE = <?= json_encode($url_update) ?>;
    var URL_ELIMINAR = <?= json_encode($url_eliminar) ?>;
    var TXT_ELIMINAR = <?= json_encode($txt_eliminar) ?>;

    fnjs_ver = function () {
        $.ajax({
            url: URL_LISTA,
            type: 'post'
        }).done(function (rta_txt) {
            if (rta_txt) {
                $('#ficha').html(rta_txt);
            }
        });
        document.getElementById("overlay").style.display = "none";
    };

    fnjs_modificar = function (id_tarifa) {
        $('#div_modificar').addClass('ventana');
        $('#div_modificar').width('auto');
        $('#div_modificar').height('auto');
        document.getElementById("overlay").style.display = "block";

        var sep = URL_FORM.indexOf('?') === -1 ? '?' : '&';
        fnjs_update_div('#div_modificar', URL_FORM + sep + 'id_tarifa=' + encodeURIComponent(id_tarifa));
    };

    fnjs_cerrar = function () {
        $('#div_modificar').html('');
        $('#div_modificar').width('0');
        $('#div_modificar').height('0');
        $('#div_modificar').removeClass('ventana');
        document.getElementById("overlay").style.display = "none";
    };

    // accion: 'update' | 'eliminar'. El form tiene los inputs id_tarifa/letra/modo/observ.
    fnjs_guardar = function (formulario, accion) {
        if (accion === "eliminar" && !confirm(TXT_ELIMINAR)) {
            return;
        }
        var url = (accion === "eliminar") ? URL_ELIMINAR : URL_UPDATE;
        $(formulario).attr('action', url);
        $(formulario).one("submit", function () {
            $.ajax({
                url: $(this).attr('action'),
                type: 'post',
                data: $(this).serialize(),
                dataType: 'json'
            }).done(function (rta) {
                if (!rta || rta.success !== true) {
                    var msg = (rta && rta.mensaje) ? rta.mensaje : '';
                    alert(msg);
                    return;
                }
                fnjs_cerrar();
                fnjs_ver();
            }).fail(function () {
                alert('<?= _("error de comunicación con el servidor") ?>');
            });
            return false;
        });
        $(formulario).trigger("submit");
        $(formulario).off();
    };

    $(document).ready(function () { fnjs_ver(); });
</script>
<div id="ficha"></div>
<div id="div_modificar"></div>
<div id="overlay"></div>
