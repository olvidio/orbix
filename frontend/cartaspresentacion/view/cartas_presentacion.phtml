<?php
/**
 * Vista principal del modulo cartaspresentacion.
 *
 * Shell con formulario de seleccion (dl/r + poblacion), zona `#ficha2`
 * donde se pinta el listado de centros, modal `#div_modificar` para el
 * form de modificacion.
 *
 * @var \web\DesplegableArray $oSelCiudades
 * @var string $url_ctr
 * @var string $h_ctr
 * @var string $url_lista
 * @var string $hash_lista_html
 * @var string $url_form
 * @var string $h_form
 * @var string $url_poblaciones
 * @var string $h_poblaciones
 * @var string $url_update
 * @var string $url_eliminar
 * @var string $h_eliminar
 * @var string $txt_confirmar_eliminar
 */
?>
<script>
    var URL_CTR = <?= json_encode($url_ctr) ?> + '?bloque=ficha2';
    var H_CTR = <?= json_encode($h_ctr) ?>;
    var URL_LISTA = <?= json_encode($url_lista) ?>;
    var URL_FORM = <?= json_encode($url_form) ?> + <?= json_encode($h_form) ?>;
    var URL_POBLACIONES = <?= json_encode($url_poblaciones) ?>;
    var H_POBLACIONES = <?= json_encode($h_poblaciones) ?>;
    var URL_UPDATE = <?= json_encode($url_update) ?>;
    var URL_ELIMINAR = <?= json_encode($url_eliminar) ?>;
    var H_ELIMINAR = <?= json_encode($h_eliminar) ?>;
    var TXT_CONFIRMAR_ELIMINAR = <?= json_encode($txt_confirmar_eliminar) ?>;

    fnjs_construir_desplegable = function (data) {
        if (!data) { return ''; }
        var $sel = $('<select></select>').attr({ id: data.id, name: data.id, 'class': 'contenido' });
        if (data.action) { $sel.attr('onchange', data.action); }
        if (data.blanco) {
            var vb = (data.val_blanco !== undefined && data.val_blanco !== null) ? data.val_blanco : '';
            $sel.append($('<option></option>').val(vb).text(''));
        }
        $.each(data.opciones || {}, function (value, label) {
            var $opt = $('<option></option>').val(value).text(label);
            if (data.selected !== undefined && data.selected !== '' && String(data.selected) === String(value)) {
                $opt.prop('selected', true);
            }
            $sel.append($opt);
        });
        return $sel.prop('outerHTML');
    };

    fnjs_ver_ubi = function (id_ubi) {
        var parametros = 'pau=u&id_ubi=' + id_ubi + H_CTR;
        fnjs_ajax_json_html({ url: URL_CTR, data: parametros, target: '#ficha2' });
    };

    fnjs_poblacion = function () {
        $('#ficha2').html('');
        var filtro = $('#tipo_lista').val();
        if (filtro === 'get_r') {
            $('#td_poblacion').hide();
            $('#lst_lugar').hide();
            return;
        }
        $('#td_poblacion').show();
        $('#lst_lugar').show();
        var parametros = 'filtro=' + encodeURIComponent(filtro) + H_POBLACIONES;
        $.ajax({
            url: URL_POBLACIONES,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (json) {
            if (!json || json.success !== true) {
                $('#lst_lugar').html('');
                return;
            }
            try {
                var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                $('#lst_lugar').html(fnjs_construir_desplegable(data));
            } catch (e) {
                $('#lst_lugar').html('');
            }
        });
    };

    fnjs_cerrar = function () {
        $('#div_modificar').html('');
        $('#div_modificar').width('0');
        $('#div_modificar').height('0');
        $('#div_modificar').removeClass('ventana');
        document.getElementById('overlay').style.display = 'none';
    };

    fnjs_modificar = function (id_direccion, id_ubi) {
        $('#div_modificar').addClass('ventana');
        $('#div_modificar').width('auto');
        $('#div_modificar').height('auto');
        document.getElementById('overlay').style.display = 'block';

        var sep = URL_FORM.indexOf('?') === -1 ? '?' : '&';
        var parametros = 'id_direccion=' + encodeURIComponent(id_direccion) + '&id_ubi=' + encodeURIComponent(id_ubi);
        fnjs_update_div('#div_modificar', URL_FORM + sep + parametros);
    };

    fnjs_ver = function () {
        var pata = $('#seleccion').serialize();
        fnjs_ajax_json({
            url: URL_LISTA,
            data: pata,
            onSuccess: function (data) {
                if (data.html) { $('#ficha2').html(data.html); }
            }
        });
        document.getElementById('overlay').style.display = 'none';
    };

    fnjs_eliminar_cp = function (id_direccion, id_ubi) {
        if (!confirm(TXT_CONFIRMAR_ELIMINAR)) { return; }
        var parametros = 'id_direccion=' + encodeURIComponent(id_direccion) + '&id_ubi=' + encodeURIComponent(id_ubi) + H_ELIMINAR;
        $.ajax({
            url: URL_ELIMINAR,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (rta) {
            if (!rta || rta.success !== true) {
                alert((rta && rta.mensaje) ? rta.mensaje : '');
            }
            fnjs_ver();
        });
    };

    fnjs_guardar_cp = function (formulario) {
        $.ajax({
            url: URL_UPDATE,
            type: 'post',
            data: $(formulario).serialize(),
            dataType: 'json'
        }).done(function (rta) {
            if (!rta || rta.success !== true) {
                alert((rta && rta.mensaje) ? rta.mensaje : '');
                return;
            }
            fnjs_cerrar();
            fnjs_ver();
        });
    };

    fnjs_left_side_hide();
</script>
<form id="seleccion" name="seleccion" action="">
<?= $hash_lista_html ?>
    <table>
        <tr><th colspan="7" class="titulo_inv"><?= _("seleccionar centros con cartas de presentación") ?></th></tr>
        <tr>
            <td class="etiqueta"><?= _("según dl") ?>:</td>
            <td colspan="3">
                <?= $oSelCiudades->desplegable() ?>
            </td>
            <td class="etiqueta" id="td_poblacion"><?= _("población") ?></td>
            <td id="lst_lugar" colspan="1"></td>
            <td>
                <input type="button" name="buscar" value="<?= _("buscar") ?>" onclick="fnjs_ver();">
            </td>
        </tr>
    </table>
</form>
<div id="ficha2"></div>
<div id="div_modificar"></div>
<div id="overlay"></div>
