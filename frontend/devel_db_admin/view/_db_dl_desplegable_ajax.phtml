<?php


use frontend\shared\config\AppUrlConfig;
use frontend\shared\config\OrbixRuntime;

/** @var string $h hash de seguridad para POST a db_lugar */
?>
<script>
<?php require __DIR__ . '/../../shared/view/_fnjs_construir_desplegable.inc.phtml'; ?>

    fnjs_dl = function () {
        var filtro_region = $('#region').val();
        var url = '<?= AppUrlConfig::srcBrowserUrl('/src/devel_db_admin/db_lugar') ?>';
        var parametros = 'region=' + encodeURIComponent(filtro_region) + '<?= $h ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (json) {
            if (!json || json.success !== true) {
                $('#lst_dl').html('');
                return;
            }
            try {
                var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                $('#lst_dl').html(fnjs_construir_desplegable(data));
            } catch (e) {
                $('#lst_dl').html('');
            }
        });
    };
</script>
