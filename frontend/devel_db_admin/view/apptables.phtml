<script>
    fnjs_db = function (que) {
        id_app = $('#id_app').val();
        app = $("#id_app option:selected").text();
        if (id_app < 19) {
            alert(<?= json_encode((string)$alerta) ?>);
            return;
        }
        esquema = $('#esquema').val();
        if (que === 'crear_global' || que === 'eliminar_global') {
            esquema = 'global';
        }
        txt = <?= json_encode(_("Esto cambiará la aplicación")) ?> + ': ' + app + '\n' + <?= json_encode(_("para el esquema")) ?> + ': ' + esquema;
        if (!confirm(txt)) {
            return;
        }
        $('#frm input[name="accion"]').val(que);
        $.ajax({
            url: 'frontend/devel_db_admin/controller/apptables_update.php',
            type: 'post',
            data: $('#frm').serialize(),
            dataType: 'json'
        }).done(function (json) {
            if (!json || json.success !== true) {
                alert(json && json.mensaje ? json.mensaje : <?= json_encode((string) _('Error al procesar la solicitud.')) ?>);
                return;
            }
            <?php
            $jsAtras = $oPosicion->js_atras(1);
            if ($jsAtras !== '') {
                echo $jsAtras;
            } else {
                echo "fnjs_enviar_formulario('#frm_recargar', '#main');";
            }
            ?>
        }).fail(function (xhr) {
            var msg = <?= json_encode((string) _('Error al procesar la solicitud.')) ?>;
            if (xhr.responseText) {
                try {
                    var json = JSON.parse(xhr.responseText);
                    if (json && json.mensaje) {
                        msg = json.mensaje;
                    }
                } catch (e) {
                    if (xhr.responseText.indexOf('<') === -1) {
                        msg = xhr.responseText.trim();
                    }
                }
            }
            alert(msg);
        });
    }
</script>
