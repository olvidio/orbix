<script>
    fnjs_dl = function () {
        var filtro_region = $('#region').val();
        var url = '<?= OrbixRuntime::getWeb() . '/src/devel_db_admin/db_lugar' ?>';
        var parametros = 'region=' + encodeURIComponent(filtro_region) + '<?= $h ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'html'
        })
            .done(function (rta_txt) {
                $('#lst_dl').html(rta_txt);
            });
    }
    fnjs_db_eliminar = function () {
        var dl = $('#dl').val();
        if (!dl) {
            alert(<?= json_encode((string)$msg_falta_dl) ?>);
            return;
        }
        if (!confirm(<?= json_encode((string)$msg_confirmar) ?>)) {
            return;
        }
        $('#frm').attr('action', 'frontend/devel_db_admin/controller/db_eliminar.php');
        fnjs_enviar_formulario('#frm', '#main');
    }
</script>

<h1><?= htmlspecialchars(_('Eliminar esquema (región–dl)')) ?></h1>
<p style="text-align:left;max-width:900px;margin:0 0 1em 0">
    <?= htmlspecialchars(_('Traslada actividades, CDC y centros al esquema resto, vacía tablas locales, elimina esquemas en las bases marcadas y borra los roles asociados.')) ?>
</p>

<form id="frm" action="" method="post">
    <?= $oHash->getCamposHtml(); ?>
