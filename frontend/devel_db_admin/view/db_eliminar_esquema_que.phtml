            <td colspan="4"><?= htmlspecialchars(_('Bases de datos a procesar')) ?>:</td>
        </tr>
        <tr>
            <td><?= htmlspecialchars(_('comun')) ?>: <input type="checkbox" value="1" checked name="comun"></td>
            <td><?= htmlspecialchars(_('sv')) ?>: <input type="checkbox" value="1" checked name="sv"></td>
            <td><?= htmlspecialchars(_('sf')) ?>: <input type="checkbox" value="1" name="sf"></td>
