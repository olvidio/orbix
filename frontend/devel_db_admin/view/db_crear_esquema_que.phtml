<?php

use frontend\shared\config\OrbixRuntime;

?>
<script>
    fnjs_dl = function () {
        var filtro_region = $('#region').val();
        var url = '<?= OrbixRuntime::getWeb() . '/src/devel_db_admin/db_lugar' ?>';
        var parametros = 'region=' + encodeURIComponent(filtro_region) + '<?= $h ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'html'
        })
            .done(function (rta_txt) {
                $('#lst_dl').html(rta_txt);
            });
    }
    fnjs_db_crear_usuarios = function () {
        dl = $('#dl').val();
        if (!dl) {
            alert(<?= json_encode((string)$msg_falta_dl) ?>);
        } else {
            $('#frm').attr('action', 'frontend/devel_db_admin/controller/db_crear_usuarios.php');
            fnjs_enviar_formulario('#frm', '#main');
        }
    }
    fnjs_db_crear_esquemas = function () {
        err = '';
        dl = $('#dl').val();
        esquema = $('#esquema').val();

        if (!dl) {
            alert(<?= json_encode((string)$msg_falta_dl) ?>);
            err = 1;
        }
        if (!esquema) {
            alert(<?= json_encode((string)$msg_falta_esquema) ?>);
            err = 1;
        }

        if (!err) {
            $('#frm').attr('action', 'frontend/devel_db_admin/controller/db_crear_esquema.php');
            fnjs_enviar_formulario('#frm', '#main');
        }
    }
    fnjs_db_copiar = function () {
        err = '';
        dl = $('#dl').val();
        esquema = $('#esquema').val();

        if (!dl) {
            alert(<?= json_encode((string)$msg_falta_dl) ?>);
            err = 1;
        }
        if (!esquema) {
            alert(<?= json_encode((string)$msg_falta_esquema) ?>);
            err = 1;
        }

        if (!err) {
            $('#frm').attr('action', 'frontend/devel_db_admin/controller/db_copiar.php');
            fnjs_enviar_formulario('#frm', '#main');
        }
    }
</script>

<h1><?= htmlspecialchars(_('Crear esquema (región–dl)')) ?></h1>
<p style="text-align:left;max-width:900px;margin:0 0 1em 0"><?= htmlspecialchars(_('Alta de una delegación nueva: usuarios, estructura de tablas (desde un esquema de referencia) e importación de datos desde resto.')) ?></p>

