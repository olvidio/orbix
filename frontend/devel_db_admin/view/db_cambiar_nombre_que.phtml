<script>
    fnjs_db_renombrar_esquema = function () {
        err = '';
        dl = $('#dl').val();
        region = $('#region').val();
        esquema_origen = $('#esquema_origen').val();

        if (!esquema_origen) {
            alert(<?= json_encode((string)($msg_falta_origen ?? '')) ?>);
            err = 1;
        }
        if (!region) {
            alert(<?= json_encode((string)($msg_falta_region ?? '')) ?>);
            err = 1;
        }
        if (!dl) {
            alert(<?= json_encode((string)$msg_falta_dl) ?>);
            err = 1;
        }

        if (!err) {
            $('#frm').attr('action', 'frontend/devel_db_admin/controller/db_renombrar_esquema.php');
            fnjs_enviar_formulario('#frm', '#main');
        }
    }
    fnjs_sincronizar_frm_verif = function () {
        $('#vf_esquema_origen').val($('#esquema_origen').val());
        $('#vf_region').val($('#region').val());
        $('#vf_dl').val($('#dl').val());
        $('#vf_comun').val($('input[name=comun]').is(':checked') ? '1' : '0');
        $('#vf_sv').val($('input[name=sv]').is(':checked') ? '1' : '0');
        $('#vf_sf').val($('input[name=sf]').is(':checked') ? '1' : '0');
        $('#cf_esquema_origen').val($('#esquema_origen').val());
        $('#cf_region').val($('#region').val());
        $('#cf_dl').val($('#dl').val());
        $('#cf_comun').val($('input[name=comun]').is(':checked') ? '1' : '0');
        $('#cf_sv').val($('input[name=sv]').is(':checked') ? '1' : '0');
        $('#cf_sf').val($('input[name=sf]').is(':checked') ? '1' : '0');
    }
    fnjs_html_verificacion = function (d) {
        var html = '<h4>' + <?= json_encode(_('Resultado de la comprobación')) ?> + '</h4>';
        html += '<p><strong>' + <?= json_encode(_('Resumen')) ?> + ':</strong> ' + (d.resumen || '') + '</p>';
        html += '<p><strong>' + <?= json_encode(_('Estado')) ?> + ':</strong> ' + (d.listo ? <?= json_encode(_('coherente con el objetivo')) ?> : <?= json_encode(_('hay pendientes o errores')) ?>) + '</p>';
        if (d.meta) {
            if (d.meta.comprobacion_solo_destino) {
                html += '<p><small><em>' + <?= json_encode(_('Comprobación solo destino (sin nombre de origen): no se valida la desaparición de un esquema antiguo.')) ?> + '</em></small></p>';
            }
            html += '<p><small>' + <?= json_encode(_('Origen (base)')) ?> + ': ' + (d.meta.comprobacion_solo_destino ? '—' : (d.meta.origen_base || '')) +
                ' → ' + <?= json_encode(_('Objetivo (base)')) ?> + ': ' + (d.meta.objetivo_base || '') + '</small></p>';
            if (d.meta.region_efectiva !== undefined && d.meta.dl_efectiva !== undefined) {
                html += '<p><small>' + <?= json_encode(_('Región / delegación usadas en la comprobación')) ?> + ': ' +
                    (d.meta.region_efectiva || '') + ' / ' + (d.meta.dl_efectiva || '') + '</small></p>';
            }
        }
        if (d.bloques && d.bloques.length) {
            html += '<ul style="text-align:left">';
            for (var i = 0; i < d.bloques.length; i++) {
                var b = d.bloques[i];
                html += '<li><strong>' + (b.nombre || '') + '</strong><ul>';
                var items = b.items || [];
                for (var j = 0; j < items.length; j++) {
                    var it = items[j];
                    var st = it.estado || '';
                    html += '<li>[' + st + '] ' + (it.texto || '') + '</li>';
                }
                html += '</ul></li>';
            }
            html += '</ul>';
        }
        return html;
    }
    fnjs_db_verificar_renombrar_esquema = function () {
        err = '';
        region = $('#region').val();
        dl = $('#dl').val();
        if (!region) {
            alert(<?= json_encode((string)($msg_falta_region ?? '')) ?>);
            err = 1;
        }
        if (!dl) {
            alert(<?= json_encode((string)$msg_falta_dl) ?>);
            err = 1;
        }
        if (err) {
            return;
        }
        fnjs_sincronizar_frm_verif();
        var url = <?= json_encode((string)($url_db_verificar_renombrar ?? '')) ?>;
        $.ajax({
            url: url,
            type: 'post',
            data: $('#frm_verif').serialize(),
            dataType: 'json'
        })
            .done(function (rta) {
                if (!rta || !rta.success || !rta.data) {
                    alert(<?= json_encode(_('Respuesta inesperada del servidor.')) ?>);
                    return;
                }
                var d = rta.data;
                $('#verif_result').html(fnjs_html_verificacion(d));
            })
            .fail(function (xhr) {
                var msg = <?= json_encode(_('Error al comprobar.')) ?>;
                if (xhr.responseText) {
                    msg += '\n' + xhr.responseText.substring(0, 500);
                }
                alert(msg);
            });
    }
    fnjs_db_corregir_renombrar_esquema = function () {
        err = '';
        region = $('#region').val();
        dl = $('#dl').val();
        if (!region) {
            alert(<?= json_encode((string)($msg_falta_region ?? '')) ?>);
            err = 1;
        }
        if (!dl) {
            alert(<?= json_encode((string)$msg_falta_dl) ?>);
            err = 1;
        }
        if (err) {
            return;
        }
        fnjs_sincronizar_frm_verif();
        var url = <?= json_encode((string)($url_db_corregir_renombrar ?? '')) ?>;
        $.ajax({
            url: url,
            type: 'post',
            data: $('#frm_corregir').serialize(),
            dataType: 'json'
        })
            .done(function (rta) {
                if (!rta || !rta.success || !rta.data) {
                    alert(<?= json_encode(_('Respuesta inesperada del servidor.')) ?>);
                    return;
                }
                var p = rta.data;
                var html = '<h4>' + <?= json_encode(_('Corrección automática')) ?> + '</h4>';
                if (p.acciones && p.acciones.length) {
                    html += '<p><strong>' + <?= json_encode(_('Acciones realizadas')) ?> + ':</strong></p><ul style="text-align:left">';
                    for (var i = 0; i < p.acciones.length; i++) {
                        html += '<li>' + (p.acciones[i] || '') + '</li>';
                    }
                    html += '</ul>';
                } else {
                    html += '<p><em>' + <?= json_encode(_('No se ejecutó ninguna acción de corrección (condiciones no cumplidas o ya estaba alineado).')) ?> + '</em></p>';
                }
                if (p.avisos && p.avisos.length) {
                    html += '<p><strong>' + <?= json_encode(_('Avisos / errores parciales')) ?> + ':</strong></p><ul style="text-align:left;color:#a00">';
                    for (var k = 0; k < p.avisos.length; k++) {
                        html += '<li>' + (p.avisos[k] || '') + '</li>';
                    }
                    html += '</ul>';
                }
                if (p.verificacion) {
                    html += '<hr style="margin:1em 0">';
                    html += fnjs_html_verificacion(p.verificacion);
                }
                $('#verif_result').html(html);
            })
            .fail(function (xhr) {
                var msg = <?= json_encode(_('Error al corregir.')) ?>;
                if (xhr.responseText) {
                    msg += '\n' + xhr.responseText.substring(0, 500);
                }
                alert(msg);
            });
    }
</script>

