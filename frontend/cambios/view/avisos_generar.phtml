<script>
    window.fnjs_avisos_generar_cfg = Object.assign(
        window.fnjs_avisos_generar_cfg || {},
        <?= json_encode([
            'url_eliminar' => $url_eliminar ?? '',
            'h_eliminar' => $h_eliminar ?? '',
            'url_eliminar_fecha' => $url_eliminar_fecha ?? '',
            'h_eliminar_fecha' => $h_eliminar_fecha ?? '',
        ], JSON_UNESCAPED_UNICODE) ?>
    );

    $(function () {
        $("#f_fin").datepicker({
            numberOfMonths: 1,
            showButtonPanel: true
        });
    });

    fnjs_avisos_eliminar_serialize = function (formulario) {
        var parts = [];
        $(formulario).find('input.sel:checked').each(function () {
            parts.push('sel[]=' + encodeURIComponent($(this).val() == null ? '' : String($(this).val())));
        });
        return parts.join('&');
    };

    fnjs_borrar_hasta_fecha = function (formulario) {
        var cfg = window.fnjs_avisos_generar_cfg || {};
        var f_fin = $('#f_fin').val();
        if (!f_fin) {
            alert(<?= json_encode(_("debe indicar la fecha")) ?>);
            return;
        }
        $.ajax({
            url: cfg.url_eliminar_fecha || '',
            type: 'post',
            dataType: 'json',
            data: 'f_fin=' + encodeURIComponent(f_fin) + (cfg.h_eliminar_fecha || '')
        }).done(function (rta) {
            if (!rta || rta.success !== true) {
                alert(<?= json_encode(_("respuesta") . ": ") ?> + (rta && rta.mensaje ? rta.mensaje : ''));
                return;
            }
            fnjs_actualizar(formulario);
        });
    }

    fnjs_actualizar = function (formulario) {
        $(formulario).find('input[name="refresh"], input[name="solo_lista"]').remove();
        $(formulario).attr('action', "frontend/cambios/controller/avisos_generar.php");
        $(formulario).append('<input type="hidden" name="refresh" value="1">');
        $(formulario).append('<input type="hidden" name="solo_lista" value="1">');
        fnjs_enviar_formulario(formulario, '#exportar');
    }

    fnjs_borrar = function (formulario) {
        var cfg = window.fnjs_avisos_generar_cfg || {};
        var data_sel = fnjs_avisos_eliminar_serialize(formulario);
        $.ajax({
            url: cfg.url_eliminar || '',
            type: 'post',
            dataType: 'json',
            data: data_sel + (cfg.h_eliminar || '')
        }).done(function (rta) {
            if (!rta || rta.success !== true) {
                alert(rta && rta.mensaje ? rta.mensaje : '');
            }
        });
        // Tacho los marcados y les quito el checkbox.
        $(formulario + ' input.sel').each(function () {
            if ($(this).prop('checked') === true) {
                $(this).parent().siblings().addClass('tachado');
                $(this).prop('checked', false);
            }
        });
    }
</script>
