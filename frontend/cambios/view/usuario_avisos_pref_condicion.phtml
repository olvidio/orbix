<form id='frm_cond'>
    <h3><?= sprintf(_("condición para %s de %s"), htmlspecialchars($Qpropiedad, ENT_QUOTES, 'UTF-8'), htmlspecialchars($Qobjeto, ENT_QUOTES, 'UTF-8')) ?></h3>
    <input type="hidden" id='salida_cond' name='salida' value="update">
    <input type="hidden" id='objeto_cond' name='objeto' value="<?= htmlspecialchars($Qobjeto, ENT_QUOTES, 'UTF-8') ?>">
    <input type="hidden" id='propiedad_cond' name='propiedad' value="<?= htmlspecialchars($Qpropiedad, ENT_QUOTES, 'UTF-8') ?>">
    <input type="hidden" name="id_item" value="<?= (int)$Qid_item ?>">
    <table style="width:490">
        <tr>
            <td><?= _("avisar si el valor") ?>:
                <input type="checkbox" <?= $chk_new ?> name="valor_new"> <?= _("nuevo") ?>
                <input type="checkbox" <?= $chk_old ?> name="valor_old"> <?= _("actual") ?>
            </td>
        </tr>
        <tr>
            <td><?= _("es") ?>:
                <?php foreach ($a_operadores as $op => $nom_op):
                    if ($operador === '') {
                        $chk_radio = ($op === '=') ? 'checked' : '';
                    } else {
                        $chk_radio = ($op === $operador) ? 'checked' : '';
                    }
                    ?>
                    <input type="radio" <?= $chk_radio ?> name="operador" value="<?= htmlspecialchars($op, ENT_QUOTES, 'UTF-8') ?>"> <?= htmlspecialchars((string)$nom_op, ENT_QUOTES, 'UTF-8') ?>
                <?php endforeach; ?>
            </td>
        </tr>
        <tr>
            <td><?= _("a") ?>:
                <?php if ($oSelects !== null): ?>
                    <script>
                        fnjs_mas_casas = function (e) {
                            var code = (e.keyCode ? e.keyCode : e.which);
                            var valor;
                            if (e === 'x') {
                                valor = 1;
                            } else {
                                var id_propiedad = '#' + e.currentTarget.id;
                                valor = $(id_propiedad).val();
                                if (code !== 9) {
                                    e.preventDefault();
                                    e.stopPropagation();
                                }
                            }
                            if (code === 9 || e.type === 'change' || e === 'x') {
                                if (valor !== 0) {
                                    <?= $oSelects->ListaSelectsJs() ?>
                                }
                            }
                        };
                        <?= $oSelects->ComprobarSelectJs() ?>
                    </script>
                    <?= $oSelects->ListaSelects() ?>
                    <input type="hidden" name="valor" value="<?= htmlspecialchars($valor, ENT_QUOTES, 'UTF-8') ?>">
                <?php else: ?>
                    <input type="input" name="valor" value="<?= htmlspecialchars($valor, ENT_QUOTES, 'UTF-8') ?>">
                <?php endif; ?>
                &nbsp;<?= _("fecha en formato ISO (YYYY-MM-dd)") ?>
            </td>
        </tr>
    </table>
    <br><br>
    <input type='button' value='<?= _("guardar") ?>' onclick="fnjs_guardar_cond('guardar_cond');">
    <input type='button' value='<?= _("eliminar") ?>' onclick="fnjs_guardar_cond('eliminar_cond');">
    <input type='button' value='<?= _("cancel") ?>' onclick="fnjs_cerrar();">
    <?= $oHash->getCamposHtml() ?>
</form>
