<script>
fnjs_actualizar_propiedades = function (id_item_usuario_objeto, objeto) {
    if (isNaN(id_item_usuario_objeto)) id_item_usuario_objeto = 0;
    if (objeto === undefined || objeto === null || objeto === '') {
        objeto = $('#objeto').val() || '';
    }
    fnjs_ajax_json_html({
        url: '<?= $url_get_propiedades ?>',
        data: 'salida=propiedades&objeto=' + objeto + '&id_item_usuario_objeto=' + id_item_usuario_objeto + '<?= $h_propiedades ?>',
        target: '#tr_tabla'
    });
};

fnjs_actualizar_fases = function () {
    var dl_propia = $('input[name="dl_propia"]:checked').val();
    var isfsv = $('#isfsv_val').val();
    var iasistentes = $('#iasistentes_val').val();
    var iactividad = $('#iactividad_val').val();
    var inom_tipo = $('#inom_tipo_val').val();
    if (!iasistentes) iasistentes = '.';
    if (!iactividad) iactividad = '.';
    if (!inom_tipo) inom_tipo = '...';
    var id_tipo_activ = isfsv + iasistentes + iactividad + inom_tipo;
    var id_usuario = $('#id_usuario').val();
    var objeto = $('#objeto').val();

    fnjs_ajax_json_html({
        url: '<?= $url_get_fases ?>',
        data: 'salida=av_fases&dl_propia=' + dl_propia + '&id_tipo_activ=' + id_tipo_activ + '&id_usuario=' + id_usuario + '&objeto=' + objeto + '<?= $h_actualizar ?>',
        target: '#fases'
    });
};

fnjs_grabar_todo = function () {
    var err = 0;
    var isfsv = $('#isfsv_val').val();
    var iasistentes = $('#iasistentes_val').val();
    var iactividad = $('#iactividad_val').val();
    var inom_tipo = $('#inom_tipo_val').val();
    if (!iasistentes) iasistentes = '.';
    if (!iactividad) iactividad = '.';
    if (!inom_tipo) inom_tipo = '...';
    var id_tipo_activ = isfsv + iasistentes + iactividad + inom_tipo;
    $('#id_tipo_activ').val(id_tipo_activ);

    var obj = $('#objeto').val();
    if (!obj) {
        alert(<?= json_encode(_("debe indicar dónde mirar los cambios")) ?>);
        $('#objeto').trigger("focus");
        err = 1;
    }
    var id_fase_ref = $('#id_fase_ref').val();
    if (!id_fase_ref) {
        alert(<?= json_encode($mensaje_error_fase_ref ?? _("debe indicar la fase de referencia")) ?>);
        err = 1;
    }
    var tipo = $('#aviso_tipo').val();
    if (!tipo) {
        alert(<?= json_encode(_("debe indicar por dónde avisar")) ?>);
        $('#aviso_tipo').trigger("focus");
        err = 1;
    }
    if (err === 1) {
        return;
    }

    // Guardar objeto (mutacion JSON).
    var form_objeto = $('#usuario_pref');
    $('#salida').val('guardar_objeto');
    $.ajax({
        url: '<?= $url_guardar_objeto ?>',
        type: 'post',
        dataType: 'json',
        data: form_objeto.serializeArray()
    }).done(function (rta) {
        if (!rta || rta.success !== true) {
            alert(rta && rta.mensaje ? rta.mensaje : '<?= _("Hay un error, no se ha guardado") ?>');
            return;
        }
        var parsed = {};
        try { parsed = JSON.parse(rta.data); } catch (e) { parsed = {}; }
        var id_item_obj = parsed.id_item_usuario_objeto || 0;
        // Guardar propiedades.
        var form_propiedades = $('#propiedades_obj');
        $('#id_item_usuario_objeto_prop').val(id_item_obj);
        $.ajax({
            url: '<?= $url_guardar_propiedades ?>',
            type: 'post',
            dataType: 'json',
            data: form_propiedades.serializeArray()
        }).done(function (rta2) {
            if (!rta2 || rta2.success !== true) {
                alert(rta2 && rta2.mensaje ? rta2.mensaje : '<?= _("Hay un error, no se ha guardado") ?>');
                return;
            }
            <?= $oPosicion->jsNavAtras(1) ?>
        });
    });
};

fnjs_cerrar = function () {
    $('#div_modificar').html('');
    $('#div_modificar').width('0');
    $('#div_modificar').height('0');
    $('#div_modificar').removeClass('ventana');
    document.getElementById("overlay").style.display = "none";
    $('#inom_tipo_val').val('');
};

fnjs_modificar = function (objeto, propiedad, id_item) {
    if (isNaN(id_item)) id_item = 0;
    $('#div_modificar').addClass('ventana');
    $('#div_modificar').width('auto');
    $('#div_modificar').height('auto');
    document.getElementById("overlay").style.display = "block";
    var parametros = 'salida=condicion&objeto=' + objeto + '&propiedad=' + propiedad + '&id_item=' + id_item + '<?= $h_mod ?>';
    fnjs_update_div('#div_modificar', '<?= $url_get_condicion ?>' + '?' + parametros);
};

fnjs_guardar_cond = function (que) {
    var err = 0;
    $('#salida_cond').val(que);
    if (que === 'eliminar_cond') {
        var seguro = confirm(<?= json_encode(_("¿Está seguro de borrar esta condición?")) ?>);
        err = seguro ? 0 : 1;
    }
    if (err === 1) {
        return;
    }
    var objeto = $('#objeto_cond').val();
    var propiedad = $('#propiedad_cond').val();
    var td_cond = '#td_' + objeto + '_' + propiedad + '_cond';
    var form_cond = $('#frm_cond');
    $.ajax({
        url: '<?= $url_preview_cond ?>',
        type: 'post',
        dataType: 'json',
        data: form_cond.serialize()
    }).done(function (rta) {
        if (!rta || rta.success !== true) {
            alert(rta && rta.mensaje ? rta.mensaje : '');
            return;
        }
        var parsed = {};
        try { parsed = JSON.parse(rta.data); } catch (e) { parsed = {}; }
        var id_cond_dom = objeto + '_' + propiedad + '_cond';
        var html = '<input type="hidden" id="' + id_cond_dom + '" name="' + id_cond_dom + '" value=\'' + (parsed.cambio_prop || '') + '\' >' + (parsed.condicion || '');
        $(td_cond).html(html);
        fnjs_cerrar();
    });
};

fnjs_mas_casas = function (e) {
    var code = (e.keyCode ? e.keyCode : e.which);
    var valor;
    if (e === 'x') {
        valor = 1;
    } else {
        var id_campo = '#' + e.currentTarget.id;
        valor = $(id_campo).val();
        if (code !== 9) {
            e.preventDefault();
            e.stopPropagation();
        }
    }
    if (code === 9 || e.type === 'change' || e === 'x') {
        if (valor !== 0) {
            <?= $oDesplArrayCasas->ListaSelectsJs() ?>
        }
    }
};
<?= $oDesplArrayCasas->ComprobarSelectJs() ?>
</script>

