<script>
    $(document).ready(function () {
        let camaSeleccionada = null; // This will now store the grid item
        let asistenteSeleccionado = null;

        $('#chk_solo_vip').on('change', function () {
            let solo_vip = $(this).is(':checked');
            updateSoloVip(solo_vip);
        });

        function updateSoloVip(solo_vip) {
            let url = '<?= htmlspecialchars($update_solo_vip_full_url, ENT_QUOTES) ?>';
            let parameters = {
                solo_vip: solo_vip ? 'true' : 'false',
                ctx: <?= json_encode($ctx_update_solo_vip, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT) ?>
            };

            $.ajax({
                url: url,
                type: 'post',
                data: parameters,
                dataType: 'json'
            })
            .done(function (respuesta) {
                if (respuesta.success) {
                    fnjs_actualizar();
                } else {
                    alert(respuesta.mensaje || 'Error desconocido');
                }
            })
            .fail(function (xhr, status, error) {
                alert('Error en la conexión con el servidor: ' + error);
            });
        }

        if (typeof grid_grupo_lista !== 'undefined') {
            grid_grupo_lista.onSelectedRowsChanged.subscribe(function (e, args) {
                let selectedRows = grid_grupo_lista.getSelectedRows();
                if (selectedRows.length > 0) {
                    camaSeleccionada = grid_grupo_lista.getDataItem(selectedRows[0]);
                } else {
                    camaSeleccionada = null;
                }
            });
        }
        
        // Listener para la selección en la tabla de camas (Modo HTML)
        $('#lista-camas').on('rowSelected', 'table', function(e, rowData) {
            camaSeleccionada = rowData;
        });

        $('.asistente-row').on('click', function () {
            $('.asistente-row').removeClass('selected');
            $(this).addClass('selected');
            asistenteSeleccionado = $(this);
        });

        $('#btn-asignar').on('click', function () {
            if (!camaSeleccionada) {
                alert("Seleccione una cama primero.");
                return;
            }
            if (!asistenteSeleccionado) {
                alert("Seleccione un asistente sin cama.");
                return;
            }

            let id_cama = camaSeleccionada.id_cama;
            let id_nom = asistenteSeleccionado.data('id-nom');
            let nombreAsistente = asistenteSeleccionado.text().trim();

            if (camaSeleccionada.id_nom) {
                alert("Esta cama ya tiene un asistente asignado. Desasigne primero.");
                return;
            }

            asignarCamaBD(id_cama, id_nom, function (success) {
                if (success) {
                    // Recargar la página para ver los cambios reflejados en ambos lados
                    // Es lo más seguro dado que la tabla se genera en el backend
                    fnjs_actualizar();
                }
            });
        });

        $('#btn-desasignar').on('click', function () {
            if (!camaSeleccionada) {
                alert("Seleccione una cama con asistente asignado.");
                return;
            }

            let id_nom = camaSeleccionada.id_nom;
            if (!id_nom) {
                alert("Esta cama no tiene asistente.");
                return;
            }

            asignarCamaBD('', id_nom, function (success) {
                if (success) {
                    fnjs_actualizar();
                }
            });
        });

        window.fnjs_lista_distribucion = function () {
            window.open('<?= htmlspecialchars($distribucion_open_url, ENT_QUOTES) ?>', 'reporte');
        }

        window.fnjs_lista_nombres = function () {
            window.open('<?= htmlspecialchars($nombres_open_url, ENT_QUOTES) ?>', 'reporte_nombres');
        }

        function fnjs_actualizar() {
            fnjs_update_div('#main', '<?= htmlspecialchars($reload_main_url, ENT_QUOTES) ?>');
        }

        function asignarCamaBD(id_cama, id_nom, callback) {
            let url = '<?= htmlspecialchars($url_update_cama_full, ENT_QUOTES) ?>';
            let parameters = {
                id_nom: id_nom,
                id_cama: id_cama,
                ctx: <?= json_encode($ctx_update_cama, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT) ?>
        };

        $.ajax({
            url: url,
            type: 'post',
            data: parameters,
            dataType: 'json'
        })
            .done(function (respuesta) {
                if (respuesta.success) {
                    callback(true);
                } else {
                    alert(respuesta.mensaje || 'Error desconocido');
                    callback(false);
                }
            })
            .fail(function (xhr, status, error) {
                alert('Error en la conexión con el servidor: ' + error);
                callback(false);
            });
    }
});
</script>