</div>

<script>
$(document).ready(function() {
    let camaSeleccionada = null;
    let asistenteSeleccionado = null;

    $('.cama-row').on('click', function() {
        $('.cama-row').removeClass('selected');
        $(this).addClass('selected');
        camaSeleccionada = $(this);
    });

    $('.asistente-row').on('click', function() {
        $('.asistente-row').removeClass('selected');
        $(this).addClass('selected');
        asistenteSeleccionado = $(this);
    });

    $('#btn-asignar').on('click', function() {
        if (!camaSeleccionada) {
            alert("Seleccione una cama primero.");
            return;
        }
        if (!asistenteSeleccionado) {
            alert("Seleccione un asistente sin cama.");
            return;
        }
        
        let id_cama = camaSeleccionada.data('id-cama');
        let id_nom = asistenteSeleccionado.data('id-nom');
        let nombreAsistente = asistenteSeleccionado.text().trim();
        
        if (camaSeleccionada.data('id-nom')) {
            alert("Esta cama ya tiene un asistente asignado. Desasigne primero.");
            return;
        }

        asignarCamaBD(id_cama, id_nom, function(success) {
            if (success) {
                camaSeleccionada.data('id-nom', id_nom);
                camaSeleccionada.find('.asistente-asignado').text(nombreAsistente);
                asistenteSeleccionado.remove();
                asistenteSeleccionado = null;
                camaSeleccionada.removeClass('selected');
                camaSeleccionada = null;
            }
        });
    });

    $('#btn-desasignar').on('click', function() {
        if (!camaSeleccionada) {
            alert("Seleccione una cama con asistente asignado.");
            return;
        }
        
        let id_nom = camaSeleccionada.data('id-nom');
        if (!id_nom) {
            alert("Esta cama no tiene asistente.");
            return;
        }
        
        let nombreAsistente = camaSeleccionada.find('.asistente-asignado').text().trim();

        asignarCamaBD('', id_nom, function(success) {
            if (success) {
                camaSeleccionada.data('id-nom', '');
                camaSeleccionada.find('.asistente-asignado').text('');
                
                // Add back to unassigned list
                let newRow = $('<div class="asistente-row"></div>')
                    .attr('data-id-nom', id_nom)
                    .text(nombreAsistente)
                    .on('click', function() {
                        $('.asistente-row').removeClass('selected');
                        $(this).addClass('selected');
                        asistenteSeleccionado = $(this);
                    });
                
                $('#lista-asistentes').append(newRow);
                
                camaSeleccionada.removeClass('selected');
                camaSeleccionada = null;
            }
        });
    });

    function asignarCamaBD(id_cama, id_nom, callback) {
        let url = '<?= ConfigGlobal::getWeb() ?>/<?= $url_update_cama ?>';
        let parameters = {
            id_activ: <?= $id_activ ?>,
            id_nom: id_nom,
            id_cama: id_cama,
            <?= $oHashUpdateCama->getParamAjaxEnArray() ?>
        };

        $.ajax({
            url: url,
            type: 'post',
            data: parameters,
            dataType: 'json'
        })
        .done(function (respuesta) {
            if (respuesta.success) {
                callback(true);
            } else {
                alert(respuesta.mensaje || 'Error desconocido');
                callback(false);
            }
        })
        .fail(function (xhr, status, error) {
            alert('Error en la conexión con el servidor: ' + error);
            callback(false);
        });
    }
});
</script>
