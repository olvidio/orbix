<script>
    fnjs_guardar = function (formulario) {
        let datos = $(formulario).serialize();
        let request = $.ajax({
            data: datos,
            url: 'src/ubiscamas/infrastructure/controllers/habitacion_update.php',
            type: 'POST',
            dataType: 'json'
        });
        request.done(function (json) {
           if (json.success !== true) {
               alert("<?= _("respuesta") ?>" + ': ' + json.mensaje);
           } else {
               <?= $oPosicion->js_atras(1); ?>
           }
        });
    }

    fnjs_actualizar = function (formulario) {
        var campo = '<input type="hidden" name="refresh" value=1>';
        $(formulario).attr('action', 'frontend/ubiscamas/controller/habitacion_form.php');
        $(formulario).append(campo);
        fnjs_enviar_formulario(formulario, '#main');
    }

    fnjs_nueva_cama = function () {
        var id_habitacion = $('#frm2 [name="id_habitacion"]').val();
        var id_ubi = $('#frm2 [name="id_ubi"]').val();
        if (!id_habitacion) {
            alert('<?= _("Debe guardar primero la habitación antes de añadir camas") ?>');
            return;
        }
        fnjs_update_div('#main', 'frontend/ubiscamas/controller/cama_form.php', {
            mod: 'nuevo',
            id_habitacion: id_habitacion,
            id_ubi: id_ubi
        });
    }

    fnjs_editar_cama = function (id_cama) {
        var id_ubi = $('#frm2 [name="id_ubi"]').val();
        fnjs_update_div('#main', 'frontend/ubiscamas/controller/cama_form.php', {
            id_cama: id_cama,
            id_ubi: id_ubi
        });
    }

    fnjs_eliminar_cama = function (id_cama) {
        if (confirm("<?= _("¿Seguro que desea borrar esta cama?") ?>")) {
            $.ajax({
                url: 'src/ubiscamas/infrastructure/controllers/cama_delete.php',
                type: 'post',
                data: {id_cama: id_cama}
            })
                .done(function (rta_txt) {
                    if (rta_txt !== '' && rta_txt !== '\\n') {
                        alert('<?= _("respuesta") ?>: ' + rta_txt);
                    } else {
                        fnjs_actualizar('#frm_actualizar');
                    }
                });
        }
    }
    fnjs_cancelar = function() {
        <?= $oPosicion->js_atras(1) ?>
    }
</script>
<?= $oPosicion->mostrar_left_slide(1); ?>
<form id='frm_actualizar'>
