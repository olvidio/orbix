<script>
    fnjs_guardar = function (formulario) {
        let datos = $(formulario).serialize();
        let request = $.ajax({
            data: datos,
            url: 'src/ubiscamas/habitacion_update',
            type: 'POST',
            dataType: 'json'
        });
        request.done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta") . ": ") ?> + json.mensaje);
            } else {
                <?= $oPosicion->jsNavAtras(1) ?>
            }
        });
    }

    fnjs_actualizar = function (formulario) {
        let campo = '<input type="hidden" name="refresh" value=1>';
        $(formulario).attr('action', 'frontend/ubiscamas/controller/habitacion_form.php');
        $(formulario).append(campo);
        fnjs_enviar_formulario(formulario, '#main');
    }

    fnjs_nueva_cama = function () {
        let id_habitacion = $('#frm2 [name="id_habitacion"]').val();
        if (!id_habitacion) {
            alert(<?= json_encode(_("Debe guardar primero la habitación antes de añadir camas")) ?>);
            return;
        }
        let url = '<?= htmlspecialchars($url_cama_form, ENT_QUOTES) ?>';
        let parametros = 'id_ubi=' + <?= json_encode((string)$id_ubi) ?> + '&id_habitacion=' + encodeURIComponent(id_habitacion) + '<?= $h_cama_form_params ?>';
        fnjs_update_div('#ficha2006', url + '?' + parametros);
    }

    fnjs_anadir_cama_dinamica = function () {
        let rowIdx = $('#tabla_nuevas_camas tbody tr').length;
        let html = `<tr>
            <td><input type="text" name="new_camas_desc[${rowIdx}]" required></td>
            <td><input type="checkbox" name="new_camas_larga[${rowIdx}]" value="1"></td>
            <td><input type="checkbox" name="new_camas_vip[${rowIdx}]" value="1"></td>
            <td><button type="button" onclick="$(this).closest('tr').remove()"><?= _('Quitar') ?></button></td>
        </tr>`;
        $('#tabla_nuevas_camas tbody').append(html);
        $('#contenedor_nuevas_camas').show();
    }

    fnjs_editar_cama = function (id_cama) {
        let id_habitacion = $('#frm2 [name="id_habitacion"]').val();
        let url = '<?= htmlspecialchars($url_cama_form, ENT_QUOTES) ?>';
        let parametros = 'id_ubi=' + <?= json_encode((string)$id_ubi) ?> + '&id_habitacion=' + encodeURIComponent(id_habitacion) + '&id_cama=' + encodeURIComponent(id_cama) + '<?= $h_cama_form_params ?>';
        fnjs_update_div('#ficha2006', url + '?' + parametros);
    }

    fnjs_eliminar_cama = function (id_cama) {
        if (confirm(<?= json_encode(_("¿Seguro que desea borrar esta cama?")) ?>)) {
            let id_habitacion = $('#frm2 [name="id_habitacion"]').val();
            let parametros = 'id_ubi=' + <?= json_encode((string)$id_ubi) ?> + '&id_habitacion=' + encodeURIComponent(id_habitacion) + '&id_cama=' + encodeURIComponent(id_cama) + '<?= $h_cama_delete_params ?>';
            let request = $.ajax({
                data: parametros,
                url: <?= json_encode($url_cama_delete) ?>,
                type: 'POST',
                dataType: 'json'
            });
            request.done(function (json) {
                if (json.success !== true) {
                    alert(<?= json_encode(_("respuesta") . ": ") ?> + json.mensaje);
                } else {
                    fnjs_actualizar('#frm_actualizar');
                }
            });
        }
    }
    fnjs_cancelar = function () {
        <?= $oPosicion->jsNavAtras(1) ?>
    }
</script>
<?= $oPosicion->mostrarNavAtras(1) ?>
<form id='frm_actualizar'>
