    <table>
        <thead>
            <tr>
                <th class="planta"><?= _("Planta") ?></th>
                <th class="habitacion"><?= _("Habitación") ?></th>
                <th class="nombre"><?= _("Nombre") ?></th>
            </tr>
        </thead>
        <tbody>
            <?php 
            foreach ($habitaciones_con_camas as $roomData) {
                $aHabitacion = $roomData['habitacion'];
                $planta = $aHabitacion['planta'];
                $nombre_hab = $aHabitacion['nombre'];
                
                foreach ($roomData['camas'] as $aCama) {
                    $id_cama = $aCama['id_cama'];
                    $nombre_persona = '';
                    if (isset($camas_con_asistentes[$id_cama])) {
                        $nombre_persona = $camas_con_asistentes[$id_cama]['apellidos'];
                    }
                    
                    // Only show rows with an assigned person, or maybe all beds?
                    // The user's image shows "Hab. sacerdote" without a name (wait, no, it has one).
                    // Usually these lists only show occupied beds or all beds.
                    // Let's show all beds but if they are empty, we leave the name blank.
                    ?>
                    <tr>
                        <td class="planta"><?= htmlspecialchars($planta?? '') ?></td>
                        <td class="habitacion"><?= htmlspecialchars($nombre_hab?? '') ?></td>
                        <td class="nombre"><?= htmlspecialchars($nombre_persona?? '') ?></td>
                    </tr>
                    <?php
                }
            }
            ?>
        </tbody>
    </table>

    <div class="no-print" style="margin-top: 30px;">
        <button onclick="window.print()"><?= _("Imprimir") ?></button>
    </div>
