<?php
/**
 * Cabecera (`top`) de `dossiers_ver`. Recibe URLs ya firmadas desde el controlador.
 *
 * @var string $web_icons
 * @var string $alt_dossiers
 * @var string $txt_dossiers
 * @var string $nom_cabecera
 * @var string $go_dossiers   URL ya firmada (HashFront) para volver a la relación de dossiers.
 * @var string $go_home       URL ya firmada (HashFront) para volver al "home" del sujeto (p/u/a).
 */
?>
<div id="top">
    <table>
        <tr>
            <td>
                <span class="link" onclick="fnjs_update_div('#main','<?= $go_dossiers ?>')">
                    <img src="<?= $web_icons ?>/dossiers.gif" width="40" height="40"
                         alt="<?= htmlspecialchars($alt_dossiers, ENT_QUOTES, 'UTF-8') ?>">(
                    <?= $txt_dossiers ?> )
                </span>
            </td>
            <td class="titulo">
                <?php if ($go_home !== ''): ?>
                    <span class="link" onclick="fnjs_update_div('#main','<?= $go_home ?>')"><?= $nom_cabecera ?></span>
                <?php else: ?>
                    <?= $nom_cabecera ?>
                <?php endif; ?>
            </td>
        </tr>
    </table>
</div>
