<?php
/**
 * Barra de botones para añadir registros desde un dossier.
 *
 * @var array<string, string> $links_insert_bar_links
 * @var string $links_insert_bar_bloque
 * @var string $links_insert_bar_label Etiqueta traducida (opcional)
 * @var string $links_insert_bar_tooltip Patrón sprintf para title (opcional)
 * @var bool $links_insert_bar_prefix_plus Anteponer + al texto del botón (default true)
 */
if (empty($links_insert_bar_links)) {
    return;
}
$links_insert_bar_prefix_plus = $links_insert_bar_prefix_plus ?? true;
?>
<p class="links-insert-bar contenido">
    <?php if (!empty($links_insert_bar_label)) { ?>
        <span class="etiqueta"><?= htmlspecialchars((string) $links_insert_bar_label, ENT_QUOTES, 'UTF-8') ?>:</span>
    <?php } ?>
    <?php foreach ($links_insert_bar_links as $nom => $pagina) {
        $txt = ($links_insert_bar_prefix_plus ? '+ ' : '') . $nom;
        $title = !empty($links_insert_bar_tooltip)
            ? sprintf($links_insert_bar_tooltip, $nom)
            : (string) $nom;
        ?>
        <span class="links-insert-btn"
              title="<?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?>"
              onclick="fnjs_update_div('<?= $links_insert_bar_bloque ?>','<?= $pagina ?>');"><?= htmlspecialchars((string) $txt, ENT_QUOTES, 'UTF-8') ?></span>
    <?php } ?>
</p>
