<script>
    $(function () {
        $("#f_ini").datepicker({ numberOfMonths: 3, showButtonPanel: true });
    });
    $(function () {
        $("#f_fin").datepicker({ numberOfMonths: 3, showButtonPanel: true });
    });
    fnjs_construir_desplegable = function (json) {
        if (!json || json.success !== true) { return ''; }
        try {
            var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
            if (!data) { return ''; }
            var $sel = $('<select></select>').attr({ id: data.id, name: data.id });
            if (data.action) { $sel.attr('onchange', data.action); }
            if (data.blanco) {
                var vb = (data.val_blanco !== undefined && data.val_blanco !== null) ? data.val_blanco : '';
                $sel.append($('<option></option>').val(vb).text(''));
            }
            $.each(data.opciones || {}, function (value, label) {
                var $opt = $('<option></option>').val(value).text(label);
                if (data.selected !== undefined && data.selected !== '' && String(data.selected) === String(value)) {
                    $opt.prop('selected', true);
                }
                $sel.append($opt);
            });
            return $sel.prop('outerHTML');
        } catch (e) {
            return '';
        }
    }
    fnjs_mas_profes = function (filtro) {
        var url = '<?= $url_profesores ?>';
        switch (filtro) {
            case 'asignatura':
                id_asignatura = $("#id_asignatura").val();
                var parametros = 'salida=asignatura&id_asignatura=' + id_asignatura + '&id_activ=<?= $id_activ ?><?= $h2 ?>';
                break;
            case 'dl':
                var parametros = 'salida=dl&id_activ=<?= $id_activ ?><?= $h1 ?>';
                break;
            case 'all':
                var parametros = 'salida=todos<?= $h ?>';
                break;
        }
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (json) {
            $('#lst_profes').html(fnjs_construir_desplegable(json));
        });
    }

    fnjs_guardar = function (formulario) {
        var rr = fnjs_comprobar_campos(formulario, '<?= addslashes($obj) ?>');

        if (rr === 'ok') {
            var mod = $(formulario).find('[name=mod]').val();
            var url = (mod === 'editar') ? '<?= $url_actividad_asignatura_editar ?>' : '<?= $url_actividad_asignatura_nueva ?>';
            var datos = $(formulario).serialize();
            $.ajax({
                data: datos,
                url: url,
                method: 'POST',
                dataType: 'json'
            }).done(function (json) {
                if (json.success !== true) {
                    alert(<?= json_encode(_("respuesta")) ?> + ': ' + json.mensaje);
                } else {
                    <?= $oPosicion->js_atras(1); ?>
                }
            });
        }
    }
</script>
