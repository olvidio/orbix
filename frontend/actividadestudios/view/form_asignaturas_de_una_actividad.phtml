<script>
<?php require __DIR__ . '/../../shared/view/_fnjs_construir_desplegable.inc.phtml'; ?>
    $(function () {
        $("#f_ini").datepicker({ numberOfMonths: 3, showButtonPanel: true });
    });
    $(function () {
        $("#f_fin").datepicker({ numberOfMonths: 3, showButtonPanel: true });
    });
    fnjs_mas_profes = function (filtro) {
        var url = '<?= $url_profesores ?>';
        var sufijoProfesor = '';
        <?php if ((int) ($id_profesor_sel ?? -1) !== -1) { ?>
        sufijoProfesor = '&id_profesor=<?= (int) $id_profesor_sel ?>';
        <?php } ?>
        switch (filtro) {
            case 'asignatura':
                id_asignatura = $("#id_asignatura").val();
                var parametros = 'salida=asignatura&id_asignatura=' + id_asignatura + '&id_activ=<?= (int) $id_activ ?><?= $h2 ?>' + sufijoProfesor;
                break;
            case 'dl':
                var parametros = 'salida=dl&id_activ=<?= (int) $id_activ ?><?= $h1 ?>' + sufijoProfesor;
                break;
            case 'all':
                var parametros = 'salida=todos<?= $h ?>' + sufijoProfesor;
                break;
        }
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        }).done(function (json) {
            $('#lst_profes').html(fnjs_construir_desplegable(json));
        });
    }

    fnjs_guardar = function (formulario) {
        var mod = $(formulario).find('[name=mod]').val();
        var url = (mod === 'editar') ? '<?= $url_actividad_asignatura_editar ?>' : '<?= $url_actividad_asignatura_nueva ?>';
        var datos = $(formulario).serialize();
        $.ajax({
            data: datos,
            url: url,
            method: 'POST',
            dataType: 'json'
        }).done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta")) ?> + ': ' + json.mensaje);
            } else {
                <?= list_nav_js_atras_to_dossiers_parent($oPosicion); ?>
            }
        });
    }
</script>
<?= list_nav_mostrar_left_slide_to_dossiers_parent($oPosicion); ?>
