<script>
    fnjs_grabar_observ = function (formulario, n) {
        var datos = $(formulario).serialize();
        $.ajax({
            data: datos,
            url: '<?= $url_asistente_observ_est ?>',
            method: 'POST',
            dataType: 'json'
        }).done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta") . ": ") ?> + json.mensaje);
            } else {
                fnjs_actualizar(formulario);
            }
        });
    }
    fnjs_grabar_est = function (formulario, n) {
        var datos = $(formulario).serialize();
        $.ajax({
            data: datos,
            url: '<?= $url_asistente_plan_est_ok ?>',
            method: 'POST',
            dataType: 'json'
        }).done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta") . ": ") ?> + json.mensaje);
            } else {
                fnjs_actualizar(formulario);
            }
        });
    }
    fnjs_modificar = function (formulario, n) {
        rta = fnjs_solo_uno(formulario);
        if (rta == 1) {
            var mod = "#mod" + n;
            $(mod).val("editar");
            $(formulario).attr('action', "<?= $url_form ?>");
            fnjs_enviar_formulario(formulario, '<?= $bloque ?>');
        }
    }
    fnjs_borrar = function (formulario, n) {
        rta = fnjs_solo_uno(formulario);
        if (rta == 1) {
            if (confirm(<?= json_encode((string)$txt_eliminar) ?>)) {
                var datos = $(formulario).serialize();
                $.ajax({
                    data: datos,
                    url: '<?= $url_matricula_eliminar ?>',
                    method: 'POST',
                    dataType: 'json'
                }).done(function (json) {
                    if (json.success !== true) {
                        alert(<?= json_encode(_("respuesta") . ": ") ?> + json.mensaje);
                    } else {
                        fnjs_actualizar(formulario);
                    }
                });
            }
        }
    }
    fnjs_matricular = function (formulario, n) {
        var mod = "#mod" + n;
        $(mod).val("matricular");
        $.ajax({
            url: '<?= $url_matricular ?>',
            type: 'post',
            data: $(formulario).serialize(),
            dataType: 'json'
        }).done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta") . ": ") ?> + json.mensaje);
            } else {
                var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                if (data && data.msg && data.msg.trim() !== '') {
                    alert(<?= json_encode(_("respuesta") . ": ") ?> + data.msg);
                }
                fnjs_actualizar(formulario);
            }
        });
    }
    fnjs_actualizar = function (formulario) {
        var campo = '<input type="hidden" name="refresh" value=1>';
        $(formulario).attr('action', "frontend/dossiers/controller/dossiers_ver.php");
        $(formulario).append(campo);
        fnjs_enviar_formulario(formulario, '#main');
    }
</script>
<?= $aviso ?? '' ?>
