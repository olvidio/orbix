<script>
    fnjs_buscar = function () {
        var campo = '<input type="hidden" name="refresh" value="1">';
        $('#periodo_form').attr('action', "frontend/actividadestudios/controller/matriculas_lista.php");
        $('#periodo_form').append(campo);
        fnjs_enviar_formulario('#periodo_form', '#main');
    }

    fnjs_ver_ca = function (formulario, n) {
        rta = fnjs_solo_uno(formulario);
        if (rta == 1) {
            var mod = "#mod";
            //$(mod).val("editar");
            $("#pau").val("a");
            $(formulario).attr('action', "frontend/dossiers/controller/dossiers_ver.php");
            fnjs_enviar_formulario(formulario, '#main');
        }
    }

    fnjs_borrar = function (formulario) {
        let mensaje = <?= json_encode($txt_eliminar, JSON_UNESCAPED_UNICODE) ?>;

        if (confirm(mensaje)) {
            $("#mod").val("eliminar");
            let url = <?= json_encode($jsUrlMatriculaEliminar, JSON_UNESCAPED_UNICODE) ?>;
            let datos = $(formulario).serialize();
            let request = $.ajax({
                data: datos,
                url: url,
                method: 'POST',
                dataType: 'json'
            });
            request.done(function (json) {
                if (json.success !== true) {
                    alert(<?= json_encode(_("respuesta"), JSON_UNESCAPED_UNICODE) ?> + ': ' + (json.mensaje || ''));
                } else {
                    fnjs_actualizar();
                }
            });
        }
    }
    fnjs_actualizar = function () {
        var url = <?= json_encode($jsUrlMatriculasListaRefresh, JSON_UNESCAPED_UNICODE) ?>;
        fnjs_update_div('#main', url);
    }
    fnjs_left_side_hide();
</script>
