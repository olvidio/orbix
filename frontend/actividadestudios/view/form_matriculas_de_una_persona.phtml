<script>
    fnjs_construir_desplegable = function (json) {
        if (!json || json.success !== true) { return ''; }
        try {
            var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
            if (!data) { return ''; }
            var $sel = $('<select></select>').attr({ id: data.id, name: data.id });
            if (data.action) { $sel.attr('onchange', data.action); }
            if (data.blanco) {
                var vb = (data.val_blanco !== undefined && data.val_blanco !== null) ? data.val_blanco : '';
                $sel.append($('<option></option>').val(vb).text(''));
            }
            $.each(data.opciones || {}, function (value, label) {
                var $opt = $('<option></option>').val(value).text(label);
                if (data.selected !== undefined && data.selected !== '' && String(data.selected) === String(value)) {
                    $opt.prop('selected', true);
                }
                $sel.append($opt);
            });
            return $sel.prop('outerHTML');
        } catch (e) {
            return '';
        }
    }

    /**
     * se ejecuta al cambiar el desplegable $oDesplegaAsignaturas
     * @returns desplegable de posibles asignaturas opcionales
     */
    fnjs_cmb_opcional = function () {
        var id = $('#id_nivel').val();
        if (<?= $condicion_js; ?>) { //solo si es opcional
            var id_nom = $('#id_pau').val();
            $.ajax({
                url: '<?= $url_posibles_opcionales ?>',
                type: 'post',
                data: 'id_nom=' + id_nom + '<?= $h_posibles_opcionales ?>',
                dataType: 'json'
            })
                .done(function (json) {
                    $('#lst_opcionales').html(fnjs_construir_desplegable(json));
                });
        } else { // al cambiar a NO opcional
            $('#lst_opcionales').html('<input type="hidden" id="id_asignatura" name="id_asignatura" value="1">');
        }
    }
    fnjs_cmb_preceptor = function () {
        if ($('#preceptor').prop('checked')) {
            $.ajax({
                url: '<?= $url_posibles_preceptores . $h_posibles_preceptores ?>',
                type: 'post',
                dataType: 'json'
            })
                .done(function (json) {
                    $('#lst_preceptores').html(fnjs_construir_desplegable(json));
                });
        } else { // al cambiar a NO preceptor
            $('#lst_preceptores').html('');
        }
    }
    fnjs_guardar = function (formulario) {
        if (!($('#id_asignatura_real').length > 0)) {
            if ($('#id_nivel').val() < 1000) {
                alert("<?= _("debe poner una asignatura") ?>");
                return;
            }
        }
        var rr = fnjs_comprobar_campos(formulario, '<?= addslashes($obj) ?>');
        if (rr === 'ok') {
            var mod = $(formulario).find('[name=mod]').val();
            var url = (mod === 'editar') ? '<?= $url_matricula_editar ?>' : '<?= $url_matricula_nueva ?>';
            var datos = $(formulario).serialize();
            $.ajax({
                data: datos,
                url: url,
                method: 'POST',
                dataType: 'json'
            }).done(function (json) {
                if (json.success !== true) {
                    alert("<?= _("respuesta") ?>" + ': ' + json.mensaje);
                } else {
                    <?= $oPosicion->js_atras(1); ?>
                }
            });
        }
    }
</script>
