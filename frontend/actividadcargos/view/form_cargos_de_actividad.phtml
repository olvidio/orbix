<script>
    /**
     * Refleja ActividadCargoNuevo/Editar::execute (ids obligatorios positivos).
     * validamos en cliente para no enviar el POST y recibir el error del servidor.
     */
    fnjs_cargo_de_actividad_datos_ok = function ($f) {
        var n = function (v) {
            var i = parseInt(String(v == null ? '' : v), 10);
            return (isNaN(i) || i < 1) ? 0 : i;
        };
        var idActiv = n($f.find('[name="id_activ"]').first().val());
        var idNom = n($f.find('[name="id_nom"]').first().val());
        var idCargo = n($f.find('[name="id_cargo"]').val());
        if (idActiv < 1 || idNom < 1 || idCargo < 1) {
            alert(<?= json_encode(_("faltan datos obligatorios: actividad, asistente y tipo de cargo."), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>);
            return false;
        }
        return true;
    };
    fnjs_guardar_cargo_act = function (formulario) {
        var $f = $(formulario);
        if (!fnjs_cargo_de_actividad_datos_ok($f)) {
            return;
        }
        var mod = $f.find('[name="mod"]').val();
        var url = (mod === 'editar')
            ? '<?= htmlspecialchars((string) $url_cargo_editar, ENT_QUOTES, 'UTF-8') ?>'
            : '<?= htmlspecialchars((string) $url_cargo_nuevo, ENT_QUOTES, 'UTF-8') ?>';
        // `asis_presente` marca al backend que el checkbox `asis` estaba en el
        // form (evita ambiguedad al deseleccionarlo): asi mantenemos la
        // semantica del legacy `isset($_POST['asis'])`.
        if ($f.find('#asis').length > 0) {
            if ($f.find('input[name="asis_presente"]').length === 0) {
                $f.append('<input type="hidden" name="asis_presente" value="1">');
            }
        }
        $.ajax({
            url: url,
            type: 'post',
            dataType: 'json',
            data: $f.serialize()
        }).done(function (rta) {
            if (rta && rta.success) {
                <?= list_nav_js_atras_to_dossiers_parent($oPosicion); ?>
            } else {
                var msg = (rta && rta.mensaje) ? rta.mensaje : <?= json_encode(_("error desconocido")) ?>;
                alert(<?= json_encode(_("respuesta") . ": ") ?> + msg);
            }
        }).fail(function () {
            alert(<?= json_encode(_("error de comunicación con el servidor")) ?>);
        });
    };
    fnjs_cancelar = function() {
        <?= list_nav_js_atras_to_dossiers_parent($oPosicion) ?>
    }
</script>
<?= list_nav_mostrar_left_slide_to_dossiers_parent($oPosicion); ?>
