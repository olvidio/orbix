<script>
    fnjs_mod_cargo = function (formulario) {
        var rta = fnjs_solo_uno(formulario);
        if (rta !== 1) {
            return;
        }
        $('#mod').val('editar');
        $(formulario).attr('action', "<?= htmlspecialchars((string) $url_form, ENT_QUOTES, 'UTF-8') ?>");
        fnjs_enviar_formulario(formulario, '<?= $bloque ?>');
    };
    fnjs_borrar_cargo = function (formulario) {
        var rta = fnjs_solo_uno(formulario);
        if (rta !== 1) {
            return;
        }
        if (!confirm("<?= $txt_eliminar ?>")) {
            return;
        }
        $('#mod').val('eliminar');
        $.ajax({
            url: '<?= htmlspecialchars((string) $url_cargo_eliminar, ENT_QUOTES, 'UTF-8') ?>',
            type: 'post',
            dataType: 'json',
            data: $(formulario).serialize()
        }).done(function (rta) {
            if (rta && rta.success) {
                fnjs_actualizar(formulario);
            } else {
                var msg = (rta && rta.mensaje) ? rta.mensaje : '<?= _("error desconocido") ?>';
                alert('<?= _("respuesta") ?>: ' + msg);
            }
        }).fail(function () {
            alert('<?= _("error de comunicación con el servidor") ?>');
        });
    };
    fnjs_actualizar = function (formulario) {
        var campo = '<input type="hidden" name="refresh" value=1>';
        $(formulario).attr('action', "apps/dossiers/controller/dossiers_ver.php");
        $(formulario).append(campo);
        fnjs_enviar_formulario(formulario, '#main');
    };
</script>
<h2 class="titulo"><?= ucfirst(_("relación de cargos")) ?></h2>
<form id="frm_cargos_personas_en_actividad" name="frm_cargos_personas_en_actividad" action="" method="post">
    <?= $oHashSelect->getCamposHtml(); ?>
    <input type="hidden" id="mod" name="mod" value="">

    <table>
