<script>
    fnjs_strip_hash_params = function (serialized) {
        return serialized.split('&').filter(function (p) {
            return p !== '' && !/^(h|hh|hhc|horig|hhorig|hc|hchk|hno|hnov)=/.test(p);
        }).join('&');
    };

    fnjs_guardar_serialize = function (formulario, que) {
        var allowEditar = {
            desc_enc: 1,
            desc_lugar: 1,
            idioma_enc: 1,
            filtro_ctr: 1,
            grupo: 1,
            id_tipo_enc: 1,
            id_zona: 1,
            lst_ctrs: 1,
            que: 1,
            id_enc: 1,
        };
        var allowNuevo = {
            desc_enc: 1,
            desc_lugar: 1,
            idioma_enc: 1,
            filtro_ctr: 1,
            grupo: 1,
            id_tipo_enc: 1,
            id_zona: 1,
            lst_ctrs: 1,
            que: 1,
        };
        var allow = (que === 'nuevo') ? allowNuevo : allowEditar;
        return $(formulario).serializeArray()
            .filter(function (field) {
                return Object.prototype.hasOwnProperty.call(allow, field.name);
            })
            .map(function (field) {
                return encodeURIComponent(field.name) + '=' + encodeURIComponent(field.value == null ? '' : String(field.value));
            })
            .join('&');
    };

    fnjs_lista_ctrs_por_zona = function () {
        var id_zona_sel = $('#id_zona_sel').val();
        var id_ubi = $('#lst_ctrs').val() || '';
        $('#id_zona').val(id_zona_sel);

        var url = '<?= $url_ctr ?>';
        var parametros = 'id_zona=' + encodeURIComponent(id_zona_sel)
            + '&id_ubi=' + encodeURIComponent(id_ubi)
            + '&action='
            + '<?= $h_ctr_zona ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        })
            .done(function (json) {
                if (!json || json.success !== true) {
                    return;
                }
                try {
                    var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                    $('#centros').html(fnjs_construir_desplegable(data));
                } catch (e) {
                }
            });
    }

    fnjs_lista_zonas = function () {
        var id_zona = $('#id_zona').val();
        var url = '<?= $url_zona ?>';
        var parametros = 'id_zona=' + id_zona + '<?= $h_zona ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        })
            .done(function (json) {
                if (!json || json.success !== true) {
                    return;
                }
                try {
                    var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                    var prefix = data.label_prefix || '';
                    $('#zonas').html(prefix + fnjs_construir_desplegable(data));
                } catch (e) {
                }
            });
    }

    fnjs_lista_ctrs = function () {
        var filtro_ctr = $('#filtro_ctr').val();
        var id_ubi = $('#lst_ctrs').val() || '';

        if (filtro_ctr === '8') { // zonas
            fnjs_lista_zonas();
        } else {
            // borrar las zonas
            $('#zonas').html('');

            var url = '<?= $url_ctr ?>';
            var parametros = 'filtro_ctr=' + encodeURIComponent(filtro_ctr)
                + '&id_ubi=' + encodeURIComponent(id_ubi)
                + '&action='
                + '<?= $h_ctr ?>';
            $.ajax({
                url: url,
                type: 'post',
                data: parametros,
                dataType: 'json'
            })
                .done(function (json) {
                    if (!json || json.success !== true) {
                        return;
                    }
                    try {
                        var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                        $('#centros').html(fnjs_construir_desplegable(data));
                    } catch (e) {
                    }
                });
        }
    }

    fnjs_guardar = function (formulario) {
        var err = 0;
        var desc_enc = $('#desc_enc').val();

        if (!desc_enc) {
            alert("Debe llenar el campo de Descripción del encargo");
            err = 1;
        }

        if (err != 1) {
            var que = $('input[name="que"]').val() || '';
            var url = (que === 'nuevo') ? '<?= $url_encargo_ver_nuevo ?>' : '<?= $url_encargo_ver_editar ?>';
            var hExtra = (que === 'nuevo') ? '<?= $h_encargo_ver_nuevo ?>' : '<?= $h_encargo_ver_editar ?>';
            var parametros = fnjs_guardar_serialize(formulario, que) + hExtra;
            $.ajax({
                url: url,
                type: 'post',
                data: parametros,
                dataType: 'json'
            })
                .done(function (json) {
                    if (!json || json.success !== true) {
                        alert(<?= json_encode(_("respuesta") . ": ") ?> + (json && json.mensaje ? json.mensaje : ''));
                        return;
                    }
                    <?= $oPosicion->js_atras(1) ?>
                });
        }

    }

    fnjs_generarNomEnc = function (formulario) {
        var sf = $('#filtro_ctr').val();
        var id_ubi = $('#lst_ctrs').val();
        var nom_tipo = '';

        nom_tipo = $('#lst_tipo_enc :selected').text();
        lloc = $('#lst_ctrs :selected').text();
        if (sf == 2) {
            sf = 'sf ';
        } else {
            sf = '';
        }
        tipus = sf + nom_tipo;
        if (lloc == '') {
            $('#desc_enc').val(tipus);
        } else {
            $('#desc_enc').val(tipus + ' (' + lloc + ')');
        }
    }

    fnjs_lst_tipo_enc = function () {
        var grupo = $('#grupo').val();
        var idTipo = $('#lst_tipo_enc select').first().val() || '';
        var parametros = 'grupo=' + encodeURIComponent(grupo) + '&id_tipo_enc=' + encodeURIComponent(idTipo) + '<?= $h_lst_tipo ?>';
        var url = '<?= $url_lst_tipo_data ?>';
        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'json'
        })
            .done(function (json) {
                if (!json || json.success !== true) {
                    return;
                }
                try {
                    var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                    $('#lst_tipo_enc').html(fnjs_construir_desplegable(data));
                } catch (e) {
                }
            });
    }
</script>
