<script>
    fnjs_strip_hash_sel = function (serialized) {
        return serialized.split('&').filter(function (p) {
            return p !== '' && !/^h=/.test(p) && !/^hnov=/.test(p);
        }).join('&');
    };

    fnjs_horario = function (formulario) {
        var url = '<?= $url_horario ?>';
        rta = fnjs_solo_uno(formulario);
        if (rta == 1) {
            $(formulario).attr('action', url);
            fnjs_enviar_formulario(formulario);
        }
    }
    fnjs_modificar = function (formulario) {
        var url = '<?= $url_modificar ?>';
        rta = fnjs_solo_uno(formulario);
        if (rta == 1) {
            $('#que').val("editar");
            $(formulario).attr('action', url);
            fnjs_enviar_formulario(formulario);
        }
    }
    fnjs_borrar = function (formulario) {
        rta = fnjs_solo_uno(formulario);
        var seguro;
        if (rta == 1) {
            seguro = confirm("<?= htmlspecialchars((string)$txt_eliminar, ENT_QUOTES, 'UTF-8') ?>");
            if (seguro) {
                $('#que').val("eliminar");
                $(formulario).one("submit", function () {
                    var url = '<?= $url_borrar ?>';
                    var hExtra = '<?= $h_borrar ?>';
                    var parametros = fnjs_strip_hash_sel($(this).serialize()) + hExtra;
                    $.ajax({
                        url: url,
                        type: 'post',
                        data: parametros,
                        dataType: 'json'
                    })
                        .done(function (json) {
                            if (!json || json.success !== true) {
                                alert('<?= _("respuesta") ?>: ' + (json && json.mensaje ? json.mensaje : ''));
                                return;
                            }
                            <?= $oPosicion->js_atras() ?>
                        });
                    return false;
                });
                $(formulario).trigger("submit");
                $(formulario).off();
            }
        }
    }
</script>
