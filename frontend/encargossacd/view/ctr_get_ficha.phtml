                <td><span class="link"
                          onclick="fnjs_añadir_sacd(<?= $e ?>);"><?= _("añadir sacd colaborador") ?></span></td>
            </tr>
            <tr>
                <td colspan=4><?= _("observaciones") ?>: <textarea rows=3 cols=50
                                                                         name=observ><?= htmlspecialchars((string)$a_observ[$e], ENT_QUOTES, 'UTF-8') ?></textarea></td>
            </tr>
            <tr>
                <td class=etiqueta><?= _("exigencias del ctr") ?></td>
                <?php if ($mod_horario[$e] == 3): ?>
                <td colspan=3><span class="link" onclick="fnjs_crear_horario(<?= $e ?>);"><?= $dedic_ctr[$e] ?></span></td>
                <?php else: ?>
                <td><input type=text size=1 name=dedic_ctr_m value=<?= htmlspecialchars((string)$dedic_ctr_m[$e], ENT_QUOTES, 'UTF-8') ?>> <?= _("mañanas") ?></td>
                <td><input type=text size=1 name=dedic_ctr_t value=<?= htmlspecialchars((string)$dedic_ctr_t[$e], ENT_QUOTES, 'UTF-8') ?>> <?= _("tarde 1ª hora") ?>
                </td>
                <td><input type=text size=1 name=dedic_ctr_v value=<?= htmlspecialchars((string)$dedic_ctr_v[$e], ENT_QUOTES, 'UTF-8') ?>> <?= _("tarde 2ª hora") ?>
                </td>
            </tr>
            <?php endif; ?>

            <?php if (!empty($perm_des)): ?>
