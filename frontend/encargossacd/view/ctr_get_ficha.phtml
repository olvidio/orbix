<script>
    fnjs_cerrar = function () {
        $('#div_modificar').html('');
        $('#div_modificar').width('0');
        $('#div_modificar').height('0');
        $('#div_modificar').removeClass('ventana');
        document.getElementById("overlay").style.display = "none";
    }

    fnjs_crear_horario = function (enc) {
        var id_enc = $('#id_enc_' + enc).val();

        var url = 'des/tareas/encargo_horario';
        var parametros = 'origen=ctr&nuevo=1&id_enc=' + id_enc;
        fnjs_update_div('#main', url + '?' + parametros);
    }

    fnjs_añadir_sacd = function (enc) {
        var n = $('#sacd_num_' + enc).val();
        var horario = $('#mod_horario_' + enc).val();
        var dedicacion;
        var lista_sacd = <?= json_encode($oDesplSacd->options(), JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;

        dedicacion = '<tr><td class=etiqueta ><?= _("dedicación") ?></td>';
        if (horario == 3) {
            dedicacion += '<td><span class="link" onclick="fnjs_crear_horario(' + enc + ');"><?= _("crear horario") ?></span></td></tr><tr>';
        } else {
            dedicacion += '<td><input type=text size=1 name=dedic_m[' + n + ']> <?= _("mañanas") ?></td><td><input type=text size=1 name=dedic_t[' + n + ']> <?= _("tarde 1ª hora") ?></td><td><input type=text size=1 name=dedic_v[' + n + ']> <?= _("tarde 2ª hora") ?></td></tr><tr>';
        }

        $('#fin_sacd_' + enc).before('<tr><td>sacd ' + n + ':</td><td colspan=3 class=contenido><select name=id_sacd[' + n + ']>' + lista_sacd + '</td></tr>' + dedicacion);

        $('[name="id_sacd[' + n + ']"]').val(0);
        $('#sacd_num_' + enc).val(++n);
    }


    fnjs_cambiar_lista_sacd = function () {
        var na = $('#sacd_na').prop('checked');
        var p = $('#sacd_p').prop('checked');
        var sss = $('#sacd_sss').prop('checked');
        var cp = $('#sacd_cp').prop('checked');
        var seleccion_sacd = 0;
        if (na) seleccion_sacd += 2;
        if (p) seleccion_sacd += 4;
        if (sss) seleccion_sacd += 8;
        if (cp) seleccion_sacd += 16;
        var url = '<?= $url_ficha ?>';
        var parametros = 'id_ubi=<?= (int)$id_ubi ?>&seleccion_sacd=' + seleccion_sacd + '<?= $h_ficha ?>';

        $.ajax({
            url: url,
            type: 'post',
            data: parametros,
            dataType: 'html'
        })
            .done(function (rta_txt) {
                $('#ficha').html(rta_txt);
            });
    }
</script>
<p><?= _("Selección de sacd") ?>:
    <input id="sacd_na" type="checkbox" value="2" onchange="fnjs_cambiar_lista_sacd()"
           <?= $chk_prelatura ?>><?= _("prelatura") ?>
    <input id="sacd_sss" type="checkbox" value="8" onchange="fnjs_cambiar_lista_sacd()"
           <?= $chk_sssc ?>><?= _("sss+") ?>
</p>
<?php for ($e = 1; $e <= $num_enc; $e++): ?>
    <form id="datos_ctr_<?= $e ?>" action="" method="post">
        <input type="hidden" id="sacd_num_<?= $e ?>" name="sacd_num" value="<?= htmlspecialchars((string)$sacd_num[$e], ENT_QUOTES, 'UTF-8') ?>">
        <?= $a_Hash[$e]->getCamposHtml() ?>
        <table border=1>
            <tr>
                <td class=titulo colspan=5><?= htmlspecialchars((string)$a_desc_enc[$e], ENT_QUOTES, 'UTF-8') ?></td>
