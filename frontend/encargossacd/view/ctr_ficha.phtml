<script>
fnjs_construir_desplegable = function (data) {
	if (!data) { return ''; }
	var id = data.id || 'lst_ctrs';
	var name = data.name || data.id || 'lst_ctrs';
	var $sel = $('<select></select>').attr({ id: id, name: name });
	if (data.action) {
		$sel.attr('onchange', data.action);
	}
	if (data.blanco) {
		var vb = (data.val_blanco !== undefined && data.val_blanco !== null) ? data.val_blanco : '';
		$sel.append($('<option></option>').val(vb).text(''));
	}
	var opciones = data.opciones || {};
	$.each(opciones, function (value, label) {
		var $opt = $('<option></option>').val(value).text(label);
		if (data.selected !== undefined && data.selected !== '' && String(data.selected) === String(value)) {
			$opt.prop('selected', true);
		}
		$sel.append($opt);
	});
	return $sel.prop('outerHTML');
};

fnjs_lista_ctrs=function(id_ubi){
	var filtro_ctr=$('#filtro_ctr').val();

	var url='<?= $url_ctr ?>';
	var parametros='filtro_ctr='+filtro_ctr+'&id_ubi='+id_ubi+'<?= $h_ctr ?>';
	$.ajax({
		url: url,
		type: 'post',
		data: parametros,
		dataType: 'json'
	})
	.done(function (json) {
		if (!json || json.success !== true) {
			return;
		}
		try {
			var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
			$('#centros').html(fnjs_construir_desplegable(data));
			$('#ficha').html('');
		} catch (e) {
		}
	});

}
fnjs_guardar=function(enc){
	var error=0;
	var formulario=$('#datos_ctr_'+enc);
	//var formulario='#datos_ctr_'+enc;
	var tipo_centro=$('#tipo_centro_'+enc).val();
	if (tipo_centro != 'of') {
		var titular=$('#id_sacd_titular_'+enc).val();
		var suplente=$('#id_sacd_suplente_'+enc).val();
		if (titular == suplente && titular != '') {
			alert("El sacd titular y suplente deben ser distintos");
			error=1;
		} 
	}
	if (!error) {
		$(formulario).attr('action','frontend/encargossacd/controller/ctr_ficha_update.php');
		$(formulario).one("submit", function() {
			fnjs_ajax_json({
				url: $(this).attr('action'),
				data: $(this).serialize(),
				onSuccess: function (data) {
					var txt = data.text || data.mensaje || '';
					if (txt !== '' && txt !== '\n') {
						alert(txt);
					}
				}
			});
			return false;
		});
		$(formulario).trigger("submit");
		$(formulario).off();
		fnjs_ver_ficha();
	}
}

fnjs_ver_ficha=function(){
   var id_ubi=$('#lst_ctrs').val();
	if (id_ubi) {
        var url='<?= $url_ficha ?>';
        var parametros='id_ubi='+id_ubi+'<?= $h_ficha ?>';
		fnjs_ajax_json_html({ url: url, data: parametros, target: '#ficha' });
	} else {
        $('#ficha').html(''); // limpio lo que pueda haber en la pantalla
	}
}
// cargar al iniciar, cuando se viene de la ficha sacd.
fnjs_ver_ficha();
</script>
