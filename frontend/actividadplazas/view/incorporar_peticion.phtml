<script>
    fnjs_left_side_hide();
    fnjs_incorporar_peticiones = function () {
        $('#btn_incorporar').prop('disabled', true);
        $.ajax({
            url: <?= json_encode($url_incorporar) ?>,
            type: 'post',
            data: {
                sactividad: <?= json_encode($sactividad) ?>,
                sasistentes: <?= json_encode($sasistentes) ?>
            },
            dataType: 'json'
        }).done(function (json) {
            var msg = '';
            if (json && json.success === true) {
                var incorporadas = (json.data && json.data.incorporadas) || 0;
                var mensaje_final = (json.data && json.data.mensaje_final) || '';
                msg = <?= json_encode(_("incorporadas")) ?> + ': ' + incorporadas + '<br>' + mensaje_final;
            } else {
                msg = (json && json.mensaje) ? json.mensaje : <?= json_encode(_("error")) ?>;
            }
            $('#resultado').html(msg);
        }).always(function () {
            $('#btn_incorporar').prop('disabled', false);
        });
    }
</script>
<h3><?= _("Incorporar peticiones de plazas") ?></h3>
<p><?= sprintf(_("Incorporar las primeras peticiones de %s como asistencia con plaza asignada/pedida."), $sasistentes) ?></p>
<button id="btn_incorporar" type="button" onclick="fnjs_incorporar_peticiones()"><?= _("continuar") ?></button>
<div id="resultado" style="margin-top:1em;"></div>
