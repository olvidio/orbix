<?php
/**
 * Vista compartida para los 3 informes STGR (numerarios, agregados, profesores).
 *
 * Variables esperadas:
 *   string $titulo       titulo ya mayusculizado para mostrar en el header.
 *   string $curso_txt    periodo del curso (ej. `2024-2025`).
 *   array  $res          array indexado `[n => ['num' => ..., 'lista' => ...]]`.
 *   array  $textos       array indexado `[n => 'texto']` con el mismo keyset.
 *   string $avisos_html  (opcional) avisos de incorporación previos a la tabla.
 *   \web\Posicion $oPosicion
 *
 * @var \web\Posicion $oPosicion
 * @var string $titulo
 * @var string $curso_txt
 * @var array $res
 * @var array $textos
 * @var string $avisos_html
 */
?>
<?= $oPosicion->mostrarNavAtras(1) ?>
<?php if (!empty($avisos_html)): ?>
<?= $avisos_html ?>
<?php endif; ?>
<p><?= $titulo ?>   <?= $curso_txt ?></p>
<table border="1">
    <?php foreach ($res as $n => $datos): ?>
        <?php
        $pos = strpos((string)$n, '.');
        $tab = $pos !== false
            ? "<td></td><td>$n. "
            : "<th>$n. </th><td>";
        ?>
        <tr><?= $tab ?><?= $textos[$n] ?? '' ?></td>
            <td><?= $datos['num'] ?? '' ?></td>
        </tr>
        <?php if (!empty($datos['lista'])): ?>
            <tr>
                <td colspan="3"><?= $datos['lista'] ?></td>
            </tr>
        <?php endif; ?>
    <?php endforeach; ?>
</table>
