 * igual que para el PHP del controlador: la vista frontend no debe `use src` sobre VOs del dominio.
 */
$taVo = (array)($vo['TipoActa'] ?? []);
$neVo = (array)($vo['NotaEpoca'] ?? []);
$formato_acta = (int)($taVo['FORMATO_ACTA'] ?? 0);
$formato_certificado = (int)($taVo['FORMATO_CERTIFICADO'] ?? 0);
$epoca_otro = (int)($neVo['EPOCA_OTRO'] ?? 0);
$epoca_ca = (int)($neVo['EPOCA_CA'] ?? 0);
$epoca_invierno = (int)($neVo['EPOCA_INVIERNO'] ?? 0);

