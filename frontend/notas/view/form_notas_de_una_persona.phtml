<script>
    $(function () {
        $("#f_acta").datepicker();
    });

    fnjs_construir_desplegable = function (json) {
        if (!json || json.success !== true) { return ''; }
        try {
            var data = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
            if (!data) { return ''; }
            var $sel = $('<select></select>').attr({ id: data.id, name: data.id });
            if (data.action) { $sel.attr('onchange', data.action); }
            if (data.blanco) {
                var vb = (data.val_blanco !== undefined && data.val_blanco !== null) ? data.val_blanco : '';
                $sel.append($('<option></option>').val(vb).text(''));
            }
            $.each(data.opciones || {}, function (value, label) {
                var $opt = $('<option></option>').val(value).text(label);
                if (data.selected !== undefined && data.selected !== '' && String(data.selected) === String(value)) {
                    $opt.prop('selected', true);
                }
                $sel.append($opt);
            });
            return $sel.prop('outerHTML');
        } catch (e) {
            return '';
        }
    }

    fnjs_buscar_acta = function () {
        var tipo_acta = $('input[name=tipo_acta]:checked').val();
        var mod = $('#mod').val();
        if (mod == 'nuevo' && tipo_acta == <?= $formato_acta ?>) {
            var acta = $('#acta').val();

            $.ajax({
                url: '<?= $url_buscar_acta ?>',
                type: 'post',
                data: 'acta=' + acta + '<?= $h_buscar_acta ?>',
                dataType: 'json'
            })
                .done(function (json) {
                    if (!json || json.success !== true) {
                        alert(<?= json_encode(_("respuesta") . ": ") ?> + (json && json.mensaje ? json.mensaje : ''));
                        return;
                    }
                    var rta_json = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
                    id_asignatura = rta_json.id_asignatura;
                    if (id_asignatura == 'no') {
                        //borrar
                        $('#id_nivel').val('');
                        $('#f_acta').val('');
                        $('#id_activ').val('');
                        $('#nom_activ').text('');
                        $("#epoca1").prop("checked", true);

                        fnjs_cmb_opcional();
                    } else {
                        fecha = rta_json.f_acta;
                        id_activ = rta_json.id_activ;
                        nom_activ = rta_json.nom_activ;
                        acta = rta_json.acta;
                        epoca = rta_json.epoca;
                        id_epoca = '#epoca' + epoca;
                        $('#acta').val(acta);
                        $('#f_acta').val(fecha);
                        $('#id_activ').val(id_activ);
                        $('#nom_activ').text(nom_activ);
                        $(id_epoca).prop("checked", true);
                        if (id_asignatura > 3000) {
                            // opcionales posibles
                            op_todas = <?= $op_genericas ?>;
                            // asig no aprobadas
                            niveles = $('#id_nivel option');
                            niveles.each(function (index, element) {
                                idNivel = $(this).val();
                                if (op_todas.includes(idNivel)) {
                                    //alert (idNivel);
                                    //seleccionarla y finalizar bucle
                                    $('#id_nivel').val(idNivel);
                                    fnjs_cmb_opcional(id_asignatura);
                                    return false; // breaks
                                }
                            });
                        } else {
                            id_nivel = rta_json.id_nivel;
                            $('#id_nivel').val(id_nivel);
                        }
                    }
                });

        }

    }

    fnjs_cerrar = function () {
        $('#div_modificar').html('');
        $('#div_modificar').width('0');
        $('#div_modificar').height('0');
        $('#div_modificar').removeClass('ventana');
        document.getElementById("overlay").style.display = "none";
    }

    fnjs_modificar = function (id_item) {
        $('#div_modificar').addClass('ventana');
        $('#div_modificar').width('auto');
        $('#div_modificar').height('auto');
        document.getElementById("overlay").style.display = "block";

        var url = '<?= $url_actividad_buscar ?>';
        var parametros = 'dl_org=&f_acta_iso=<?= $f_acta_iso ?><?= $h_actividad_buscar ?>';
        fnjs_update_div('#div_modificar', url + '?' + parametros);
    }

    fnjs_buscar_ca = function () {
        var dl_org = $('#dl_org').val();
