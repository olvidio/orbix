    <div style="margin-top: 20px;"><label for="dw3"><?= _("Miércoles") ?>:</label><input id="dw3" name="dw3" type="checkbox"></div>
    <div style="margin-top: 20px;"><label for="dw4"><?= _("Jueves") ?>:</label><input id="dw4" name="dw4" type="checkbox"></div>
    <div style="margin-top: 20px;"><label for="dw5"><?= _("Viernes") ?>:</label><input id="dw5" name="dw5" type="checkbox"></div>
    <div style="margin-top: 20px;"><label for="dw6"><?= _("Sábado") ?>:</label><input id="dw6" name="dw6" type="checkbox"></div>
    <div style="margin-top: 20px;"><label for="dw7"><?= _("Domingo") ?>:</label><input id="dw7" name="dw7" type="checkbox"></div>
    <hr/>
    <div class='item-details-form-buttons'>
        <button data-action='save' class='slick-btn slick-btn-primary'>Grabar</button>
        <button data-action='cancel' class='slick-btn slick-btn-default'>Cancel</button>
    </div>
</div>

<script>
    fnjs_busca_sacds = function () {
        let id_zona = $('#lst_zonas').val();
        if (id_zona) {
            let parametros = 'que=get_lista&id_zona=' + id_zona + '<?= $h_sacd ?>';
            $.ajax({ url: '<?= $url_ajax ?>', type: 'post', data: parametros, dataType: 'html' }).done(function (rta_txt) { $('#lst_sacds').html(rta_txt); });
        }
    }
    fnjs_guardar = function (formulario, n) {
        $('#acumular').val(n);
        $(formulario).attr('action', '<?= $url_ajax ?>');
        $(formulario).one("submit", function () {
            $.ajax({ url: $(this).attr('action'), type: 'post', data: $(this).serialize() }).done(function (rta_txt) {
                if (rta_txt !== '' && rta_txt !== '\n') { alert('<?= _("respuesta") ?>: ' + rta_txt); }
            });
            return false;
        });
        $(formulario).trigger("submit");
        $(formulario).off();
        fnjs_busca_sacds();
    }
    fnjs_modificar = function (formulario) {
        let rta = fnjs_solo_uno(formulario);
        if (rta === 1) {
            $('#'+$(formulario).attr('id')+' input').each(function (i, item) {
                if ($(item).prop('checked') === true) { fnjs_modal_zona_sacd_ver($(item).val()); }
            });
        }
    }
    var modal = $(".item-details-form");
    $(document).keydown(function (e) {
        if (modal.css('display') !== 'none') {
            if (e.which === Slick.keyCode.ENTER) { commitCurrentEdit(); e.stopPropagation(); e.preventDefault(); }
            else if (e.which === Slick.keyCode.ESCAPE) { modal.hide(); e.stopPropagation(); e.preventDefault(); }
        }
    });
    modal.find("[data-action=save]").click(function () { commitCurrentEdit(); });
    modal.find("[data-action=cancel]").click(function () { modal.hide(); });

    fnjs_modal_zona_sacd_ver = function (id_sacd) {
        let id_zona = $('#lst_zonas').val();
        let parametros = 'id_zona=' + id_zona + '&id_sacd=' + id_sacd + '<?= $h_url_get ?>';
        $.ajax({ url: 'apps/misas/controller/zona_sacd_datos_get.php', method: 'POST', data: parametros, dataType: 'json' }).done(function (json) {
            if (json.success !== true) { alert("<?= _("respuesta") ?>: " + json.mensaje); return; }
            $('#id_sacd').val(id_sacd); $('#id_zona').val(id_zona); $('#titulo_modal').html(json.nombre_sacd);
            $('#dw1').prop('checked', json.dw1 === true); $('#dw2').prop('checked', json.dw2 === true); $('#dw3').prop('checked', json.dw3 === true);
            $('#dw4').prop('checked', json.dw4 === true); $('#dw5').prop('checked', json.dw5 === true); $('#dw6').prop('checked', json.dw6 === true); $('#dw7').prop('checked', json.dw7 === true);
            modal.show();
        });
    }

    function commitCurrentEdit() {
        let parametros = 'id_zona=' + $('#id_zona').val() + '&id_sacd=' + $('#id_sacd').val();
        parametros += '&dw1=' + $('#dw1').is(":checked") + '&dw2=' + $('#dw2').is(":checked") + '&dw3=' + $('#dw3').is(":checked");
        parametros += '&dw4=' + $('#dw4').is(":checked") + '&dw5=' + $('#dw5').is(":checked") + '&dw6=' + $('#dw6').is(":checked") + '&dw7=' + $('#dw7').is(":checked");
        parametros += '<?= $h_url_put ?>';
        $.ajax({ url: 'apps/misas/controller/zona_sacd_datos_put.php', method: 'POST', data: parametros, dataType: 'json' }).done(function (json) {
            if (json.success !== true) { alert("<?= _("respuesta") ?>: " + json.mensaje); }
            else { modal.hide(); fnjs_busca_sacds(); }
        });
    }
    fnjs_left_side_hide();
    modal.hide();
</script>
