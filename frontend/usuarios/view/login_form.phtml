<script type="text/javascript">
    fnjs_showRefreshOverlay = function () {
        const overlay = document.getElementById('refresh-mv-overlay-login');
        if (overlay) {
            overlay.style.display = 'flex';
        }
    };

    fnjs_esEsquemaRegionStgr = function (esquema) {
        return /^[A-Za-z]+-[A-Za-z0-9]+[vf]$/.test(esquema);
    };

    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('frm_login');
        if (!form) {
            return;
        }
        form.addEventListener('submit', function () {
            const select = form.querySelector('[name="esquema"]');
            const esquema = select ? String(select.value || '') : '<?= htmlspecialchars((string) $esquema_web, ENT_QUOTES, 'UTF-8') ?>';
            if (fnjs_esEsquemaRegionStgr(esquema)) {
                fnjs_showRefreshOverlay();
            }
        });
    });

    fnjs_goHelp = async function () {
        const form = document.getElementById('frm_login');
        const formData = new FormData(form);
        const url = 'frontend/usuarios/controller/ayuda_acceso.php';

        try {
            const response = await fetch(url, {
                method: 'POST',
                body: formData
            });

            if (!response.ok) {
                const errorText = await response.text();
                throw new Error(`HTTP error! status: ${response.status} - ${errorText}`);
            }

            const responseData = await response.text();
            document.body.innerHTML = responseData;

        } catch (error) {
            console.error('Error al enviar el formulario con Fetch:', error);
            alert('Error al enviar el formulario: ' + error.message);
        }
    }

    fnjs_hideErrors = function () {
        let alerta = document.getElementById('div_error_login');
        if (alerta) {
            alerta.style.display = 'none';
        }
    }

    fnjs_goTop = function () {
        menu = document.getElementById("menu");
        if (menu) {
            window.location.href = "<?= $url ?>";
        }
    }
    document.onload = fnjs_goTop();
</script>
