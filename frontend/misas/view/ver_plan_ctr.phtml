<?php
/**
 * @var array<int, array{letra: string, num_dia: string, num_mes: string, id_dia: string}> $columns
 * @var array<int, array{desc_enc: string, cells: array<int, string>}>                    $rows
 * @var array<int, array{iniciales: string, nombre: string}>                              $legend
 */
?>
<table class="plan-ctr-misas" style="width:100%">
    <thead>
        <tr>
            <th class="cell-title" style="width:10%"><?= htmlspecialchars(_('Encargo'), ENT_QUOTES, 'UTF-8') ?></th>
            <?php foreach ($columns as $col): ?>
                <th class="cell-title" style="width:60px"><?= htmlspecialchars($col['letra'], ENT_QUOTES, 'UTF-8') ?><br><?= htmlspecialchars($col['num_dia'] . '.' . $col['num_mes'], ENT_QUOTES, 'UTF-8') ?></th>
            <?php endforeach; ?>
        </tr>
    </thead>
    <tbody>
    <?php foreach ($rows as $row): ?>
        <tr>
            <td><?= htmlspecialchars($row['desc_enc'], ENT_QUOTES, 'UTF-8') ?></td>
            <?php foreach ($row['cells'] as $cell): ?>
                <td><?= htmlspecialchars($cell, ENT_QUOTES, 'UTF-8') ?></td>
            <?php endforeach; ?>
        </tr>
    <?php endforeach; ?>
    </tbody>
</table>

<table class="plan-ctr-leyenda">
    <tr>
        <td>
            <?php
            $parts = [];
            foreach ($legend as $item) {
                $parts[] = htmlspecialchars($item['iniciales'], ENT_QUOTES, 'UTF-8')
                    . ': ' . htmlspecialchars($item['nombre'], ENT_QUOTES, 'UTF-8');
            }
            echo implode(' &nbsp; ', $parts);
            ?>
        </td>
    </tr>
</table>
