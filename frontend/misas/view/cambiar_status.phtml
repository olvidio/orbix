<div id="div_cuadricula">
</div>

<script>
    $("#empiezamin").datepicker();
    $("#empiezamax").datepicker();

    fnjs_ver_cuadricula_zona = function () {
        let id_zona = $('#id_zona').val();
        if (id_zona) {
            let url = '<?= $url_ver_cuadricula_zona ?>';
            var periodo = $('#periodo').val();
            var empiezamax = $('#empiezamax').val();
            var empiezamin = $('#empiezamin').val();
            let orden = $('#orden').val();

            let parametros = 'id_zona=' + encodeURIComponent(id_zona)
                + '&periodo=' + encodeURIComponent(periodo)
                + '&empiezamin=' + encodeURIComponent(empiezamin)
                + '&empiezamax=' + encodeURIComponent(empiezamax)
                + '&orden=' + encodeURIComponent(orden)
                + '&tipo_plantilla=p'
                + '<?= $h_zona_status ?>';

            fnjs_ajax_json_html({ url: url, data: parametros, target: '#div_cuadricula' });
        }
    };

    fnjs_nuevo_estado = function () {
        let id_zona = $('#id_zona').val();
        let estado = $('#estado').val();
        if (id_zona) {
            let url = '<?= $url_nuevo_status ?>';

            var periodo = $('#periodo').val();
            var empiezamax = $('#empiezamax').val();
            var empiezamin = $('#empiezamin').val();
            let parametros = 'id_zona=' + encodeURIComponent(id_zona)
                + '&estado=' + encodeURIComponent(estado)
                + '&periodo=' + encodeURIComponent(periodo)
                + '&empiezamax=' + encodeURIComponent(empiezamax)
                + '&empiezamin=' + encodeURIComponent(empiezamin)
                + '<?= $h_nuevo_status ?>';
            $.ajax({
                url: url,
                type: 'post',
                data: parametros,
                dataType: 'json'
            })
                .done(function (json) {
                    if (json && json.success === false) {
                        alert(json.mensaje || '');
                        return;
                    }
                    fnjs_ver_cuadricula_zona();
                });
        }
    };
    $(document).ready($('#periodo').change(function () {
        funjs_activar_fecha();
        fnjs_ver_cuadricula_zona();
    }));
    $(document).ready($('#empiezamin').change(function () {
        funjs_activar_fecha();
        fnjs_ver_cuadricula_zona();
    }));
    $(document).ready($('#empiezamax').change(function () {
        funjs_activar_fecha();
        fnjs_ver_cuadricula_zona();
    }));
    fnjs_ver_cuadricula_zona();
</script>
