<script>
    fnjs_ver_plan_sacd = function () {
        let id_sacd = $('#id_sacd').val();
        if (id_sacd) {
            let url = '<?= htmlspecialchars($url_ver_plan_sacd, ENT_QUOTES, 'UTF-8') ?>';
            var periodo = $('#periodo').val();
            var empiezamax = $('#empiezamax').val();
            var empiezamin = $('#empiezamin').val();
            let parametros = 'id_sacd=' + encodeURIComponent(id_sacd) + '&periodo=' + encodeURIComponent(periodo)
                + '&empiezamin=' + encodeURIComponent(empiezamin) + '&empiezamax=' + encodeURIComponent(empiezamax)
                + '<?= $h_plan_sacd ?>';
            fnjs_ajax_json_html({ url: url, data: parametros, target: '#div_cuadricula' });
        }
    };
    $(document).ready($('#periodo').change(function () {
        funjs_activar_fecha();
        fnjs_ver_plan_sacd();
    }));
    $(document).ready($('#empiezamin').change(function () {
        funjs_activar_fecha();
        fnjs_ver_plan_sacd();
    }));
    $(document).ready($('#empiezamax').change(function () {
        funjs_activar_fecha();
        fnjs_ver_plan_sacd();
    }));
    fnjs_ver_plan_sacd();
</script>
