</div>

<script src="node_modules/slickgrid/dist/browser/slick.core.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.interactions.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.grid.js"></script>
<script src="node_modules/slickgrid/dist/browser/plugins/slick.cellrangeselector.js"></script>
<script src="node_modules/slickgrid/dist/browser/plugins/slick.cellselectionmodel.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.formatters.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.editors.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.compositeeditor.js"></script>
<script src="frontend/misas/support/item_details_form_drag.js"></script>

<script>

    var modal = $(".item-details-form");
    fnjs_initItemDetailsFormDrag(modal, 'inicialesZonaModal');
    var colorOriginal = '';
    var colorDirty = false;

    function normalizeHexForPicker(s) {
        if (s == null || s === '') {
            return '#000000';
        }
        s = String(s).trim();
        if (s.charAt(0) !== '#') {
            s = '#' + s;
        }
        if (/^#[0-9A-Fa-f]{6}$/i.test(s)) {
            return s.toLowerCase();
        }
        if (/^#[0-9A-Fa-f]{3}$/i.test(s)) {
            var m = s.match(/^#([0-9A-Fa-f])([0-9A-Fa-f])([0-9A-Fa-f])$/i);
            return ('#' + m[1] + m[1] + m[2] + m[2] + m[3] + m[3]).toLowerCase();
        }
        return '#000000';
    }

    /** Hex de 6 caracteres sin '#', como en la base de datos. */
    function hexToStorage6(s) {
        if (s == null || s === '') {
            return '';
        }
        s = String(s).trim();
        if (s.charAt(0) === '#') {
            s = s.slice(1);
        }
        if (/^[0-9A-Fa-f]{6}$/i.test(s)) {
            return s.toLowerCase();
        }
        if (/^[0-9A-Fa-f]{3}$/i.test(s)) {
            return (s[0] + s[0] + s[1] + s[1] + s[2] + s[2]).toLowerCase();
        }
        return '';
    }

    function isValidStoredHex(s) {
        if (s == null || s === '') {
            return false;
        }
        return hexToStorage6(s) !== '';
    }

    var MSG_SIN_COLOR = <?= json_encode(_('Sin color')) ?>;

    function escapeHtmlAttr(s) {
        if (s == null || s === '') {
            return '';
        }
        return String(s)
            .replace(/&/g, '&amp;')
            .replace(/"/g, '&quot;')
            .replace(/</g, '&lt;')
            .replace(/'/g, '&#39;');
    }

    function colorSwatchFormatter(row, cell, value, columnDef, dataContext) {
        var hex6 = hexToStorage6(value == null ? '' : String(value));
        if (hex6 === '') {
            return '<span class="slick-color-cell slick-color-cell--empty" title="' + escapeHtmlAttr(MSG_SIN_COLOR) + '">—</span>';
        }
        var full = '#' + hex6;
        return '<span class="slick-color-cell slick-color-cell--filled" title="' + escapeHtmlAttr(full) + '">'
            + '<span class="slick-color-swatch" style="background-color:' + full + '"></span>'
            + '</span>';
    }

    function updateSwatchSelection(hex) {
        var norm = normalizeHexForPicker(hex);
        $('.color-swatch').removeClass('is-selected');
        $('.color-swatch').each(function () {
            var c = normalizeHexForPicker($(this).attr('data-color'));
            if (c === norm) {
                $(this).addClass('is-selected');
            }
        });
    }

    $('#color_swatches').on('click', '.color-swatch', function () {
        var hex = $(this).attr('data-color');
        $('#color_picker').val(hex);
        colorDirty = true;
        updateSwatchSelection(hex);
    });

    $('#color_picker').on('input change', function () {
        colorDirty = true;
        updateSwatchSelection($(this).val());
    });

    modal.keydown(function (e) {
        if (e.which == Slick.keyCode.ENTER) {
            commitCurrentEdit();
            e.stopPropagation();
            e.preventDefault();
        } else if (e.which == Slick.keyCode.ESCAPE) {
            cancelCurrentEdit();
            e.stopPropagation();
            e.preventDefault();
        }
    });

    modal.find("[data-action=save]").click(function () {
        commitCurrentEdit();
    });

    modal.find("[data-action=cancel]").click(function () {
        cancelCurrentEdit();
    });

    function cancelCurrentEdit() {
        modal.hide();
    }

    function commitCurrentEdit(cell) {
        cell = $('#cell_selected').val();
        row = $('#row_selected').val();
        let id_sacd = $('#id_sacd').val();
        let iniciales = $('#iniciales').val();
        var colorRaw = colorDirty ? $('#color_picker').val() : colorOriginal;
        let color = hexToStorage6(colorRaw);

        parametros = 'id_sacd=' + id_sacd + '&iniciales=' + iniciales + '&color=' + encodeURIComponent(color) + '<?= $h_iniciales ?>';

        // guardar cambios en DB
        var request = $.ajax({
            url: '<?= $url_update_iniciales ?>',
            method: 'POST',
            data: parametros,
            dataType: 'json'
        });
        request.done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta")) ?> + ': ' + json.mensaje);
            } else {
                data[row]['id_sacd'] = id_sacd;
                data[row]['iniciales'] = iniciales;
                data[row]['color'] = color;
                grid.updateRow(row);
                modal.hide();
                reset_campos_modal();
            }
        });
    }

    function reset_campos_modal() {
        $('#titulo_modal').html('');
        $('#id_sacd').val('');
        $('#iniciales').val('');
        colorOriginal = '';
        colorDirty = false;
        $('#color_picker').val('#000000');
        $('.color-swatch').removeClass('is-selected');
    }


    function openDetails(cell) {
        const url = URL.createObjectURL(new Blob());
        $('#cell_selected').val(cell.cell);
        $('#row_selected').val(cell.row);

        let sacd = data[cell.row].nombre_sacd;
        let id_sacd = data[cell.row].id_sacd;
        let iniciales = data[cell.row].iniciales;
        let color = data[cell.row].color;

        $('#titulo_modal').html(sacd);
        $('#id_sacd').val(id_sacd);
        $('#iniciales').val(iniciales);

        colorOriginal = (color == null || color === undefined) ? '' : String(color);
        colorDirty = false;
        if (isValidStoredHex(colorOriginal)) {
            var ph = normalizeHexForPicker(hexToStorage6(colorOriginal));
            $('#color_picker').val(ph);
            updateSwatchSelection(ph);
        } else {
            $('#color_picker').val('#000000');
            $('.color-swatch').removeClass('is-selected');
        }

        modal.show();
    }

    function requiredFieldValidator(value) {
        if (value == null || value == undefined || !value.length) {
            return {valid: false, msg: "This is a required field"};
        } else {
            return {valid: true, msg: null};
        }
    }

    var grid;
    var data = <?= $json_data_cuadricula ?>;
    var columns = <?= $json_columns_cuadricula ?>;
    columns.forEach(function (col) {
        if (col.field === 'color') {
            col.formatter = colorSwatchFormatter;
        }
    });
    var options = {
        editable: false,
        enableAddRow: true,
        enableCellNavigation: true,
        asyncEditorLoading: false,
        autoEdit: false
    };


    $(function () {
        grid = new Slick.Grid("#myGrid", data, columns, options);

        grid.onClick.subscribe(function (e) {
            var cell = grid.getCellFromEvent(e);
            openDetails(cell);
            e.stopPropagation();
        });

        grid.setActiveCell(0, 0);
    })


    $('.clockpicker').clockpicker({
            placement: 'bottom',
            align: 'right',
            donetext: 'Correcto!'
        }
    );

    fnjs_generarNomEnc = function (formulario) {
        var nom_tipo = '';
        nom_tipo = $('#id_tipo_enc :selected').text();
        lloc = $('#id_ubi :selected').text();
        tipus = nom_tipo;
        if (lloc == '') {
            $('#encargo').val(tipus);
        } else {
            $('#encargo').val(tipus + ' (' + lloc + ')');
        }
    }

</script>
