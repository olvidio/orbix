<script>
    fnjs_modificar_cuadricula_zona = function () {
        let id_zona = $('#id_zona').val();
        if (id_zona) {
            let url = '<?= htmlspecialchars($url_modificar_cuadricula_zona, ENT_QUOTES, 'UTF-8') ?>';
            var periodo = $('#periodo').val();
            var empiezamax = $('#empiezamax').val();
            var empiezamin = $('#empiezamin').val();
            let orden = $('#orden').val();
            let parametros = 'id_zona=' + encodeURIComponent(id_zona) + '&periodo=' + encodeURIComponent(periodo)
                + '&empiezamin=' + encodeURIComponent(empiezamin) + '&empiezamax=' + encodeURIComponent(empiezamax)
                + '&orden=' + encodeURIComponent(orden) + '&tipo_plantilla=p<?= $h_zona_periodo ?>';
            fnjs_ajax_json_html({ url: url, data: parametros, target: '#div_cuadricula' });
        }
    };

    $(document).ready($('#periodo').change(function () {
        funjs_activar_fecha();
        fnjs_modificar_cuadricula_zona();
    }));
    $(document).ready($('#empiezamin').change(function () {
        funjs_activar_fecha();
        fnjs_modificar_cuadricula_zona();
    }));
    $(document).ready($('#empiezamax').change(function () {
        funjs_activar_fecha();
        fnjs_modificar_cuadricula_zona();
    }));
    fnjs_modificar_cuadricula_zona();
</script>
