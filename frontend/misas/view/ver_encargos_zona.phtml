        <div style="margin-top: 20px;">
            <label for="id_ubi"> <?= _('Lugar') ?>: </label>
            <?= $oDesplCentros->desplegable() ?>&nbsp;&nbsp;&nbsp;&nbsp;
            <label for="descripcion_lugar"> <?= _('Descripción lugar') ?>: </label>
            <input id="descripcion_lugar" type="text" class="form-control" size="20" value="">
        </div>

        <div style="margin-top: 20px;">
            <label for="orden"> <?= _('Orden') ?>: </label>
            <input id="orden" type="text" class="form-control" size="20" value="">
        </div>

        <div style="margin-top: 20px;">
            <label for="prioridad"> <?= _('Prioridad') ?>: </label>
            <input id="prioridad" type="text" class="form-control" size="20" value="">&nbsp;&nbsp;&nbsp;&nbsp;
        </div>

        <div style="margin-top: 20px;">
            <label for="observ"> <?= _('Observaciones') ?>: </label>
            <input id="observ" type="text" class="form-control" size="20" value="">&nbsp;&nbsp;&nbsp;&nbsp;
            <label for="idioma"> <?= _('Idioma') ?>: </label>
            <?= $oDesplIdiomas->desplegable() ?>
        </div>
