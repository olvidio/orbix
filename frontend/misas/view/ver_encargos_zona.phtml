</div>

<script src="node_modules/slickgrid/dist/browser/slick.core.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.interactions.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.grid.js"></script>
<script src="node_modules/slickgrid/dist/browser/plugins/slick.cellrangeselector.js"></script>
<script src="node_modules/slickgrid/dist/browser/plugins/slick.cellselectionmodel.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.formatters.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.editors.js"></script>
<script src="node_modules/slickgrid/dist/browser/slick.compositeeditor.js"></script>
<script src="frontend/misas/support/item_details_form_drag.js"></script>

<script>

    var modal = $('#modal_encargos_zona');
    fnjs_initItemDetailsFormDrag(modal, 'encargosZonaModal');

    function showEncargosModal() {
        $('.item-details-form').not(modal).hide();
        modal.show();
    }

    modal.keydown(function (e) {
        if (e.which == Slick.keyCode.ENTER) {
            commitCurrentEdit();
            e.stopPropagation();
            e.preventDefault();
        } else if (e.which == Slick.keyCode.ESCAPE) {
            cancelCurrentEdit();
            e.stopPropagation();
            e.preventDefault();
        }
    });

    modal.find("[data-action=save]").click(function () {
        commitCurrentEdit();
    });

    modal.find("[data-action=eliminar_encargo]").click(function () {
        eliminarCurrentEdit();
    });

    modal.find("[data-action=cancel]").click(function () {
        cancelCurrentEdit();
    });

    function cancelCurrentEdit() {
        modal.hide();
    }

    function commitCurrentEdit() {
        let id_enc_selected = $('#id_enc_selected').val();
        let observ = $('#observ').val();
        let encargo = $('#encargo').val();
        let id_tipo_enc = $('#id_tipo_enc').val();
        let id_ubi = $('#id_ubi').val();
        let orden = $('#orden').val();
        let prioridad = $('#prioridad').val();
        let id_zona = <?= (int)$id_zona ?>;
        let idioma_enc = $('#idioma_enc').val();
        let descripcion_lugar = $('#descripcion_lugar').val();

        let parametros = 'id_enc=' + id_enc_selected
            + '&id_tipo_enc=' + id_tipo_enc
            + '&id_ubi=' + id_ubi
            + '&id_zona=' + id_zona
            + '&descripcion_lugar=' + encodeURIComponent(descripcion_lugar)
            + '&encargo=' + encodeURIComponent(encargo)
            + '&idioma_enc=' + encodeURIComponent(idioma_enc)
            + '&observ=' + encodeURIComponent(observ)
            + '&orden=' + orden
            + '&prioridad=' + prioridad
            + '<?= $h_guardar_encargo_zona ?>';

        var request = $.ajax({
            url: '<?= $url_guardar_encargo_zona ?>',
            method: 'POST',
            data: parametros,
            dataType: 'json'
        });
        request.done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta")) ?> + ': ' + json.mensaje);
            } else {
                fnjs_refresh_grid();
            }
        });
    }

    function eliminarCurrentEdit() {
        let id_enc_selected = $('#id_enc_selected').val();
        let parametros = 'id_enc=' + id_enc_selected + '<?= $h_eliminar_encargo_zona ?>';

        var request = $.ajax({
            url: '<?= $url_eliminar_encargo_zona ?>',
            method: 'POST',
            data: parametros,
            dataType: 'json'
        });
        request.done(function (json) {
            if (json.success !== true) {
                alert(<?= json_encode(_("respuesta")) ?> + ': ' + json.mensaje);
            } else {
                fnjs_refresh_grid();
            }
        });
    }

    function fnjs_refresh_grid() {
        let id_zona = <?= (int)$id_zona ?>;
        let orden_select = $('#orden_select').val() || 'orden';
        let parametros = 'id_zona=' + id_zona + '&orden=' + orden_select + '<?= $h_ver_encargos_zona ?>';
        fnjs_ajax_json_html({
            url: '<?= $url_ver_encargos_zona ?>',
            data: parametros,
            target: '#div_encargos'
        });
    }

    function fnjs_nuevo() {
        $('#que').val('nuevo');
        reset_campos_modal();
        $('#titulo_modal').html(<?= json_encode(_('nuevo encargo')) ?>);
        showEncargosModal();
    }

    function reset_campos_modal() {
        $('#titulo_modal').html('');
        $('#observ').val('');
        $('#encargo').val('');
        $('#orden').val('');
        $('#prioridad').val('');
        $('#id_ubi').val('');
        $('#id_enc_selected').val('');
        $('#id_tipo_enc').val('');
        $('#descripcion_lugar').val('');
        $('#idioma_enc').val('');
    }


    function openDetails(cell) {
        $('#cell_selected').val(cell.cell);
        $('#row_selected').val(cell.row);
        $('#que').val('modificar');

        let encargo = data[cell.row].encargo;
        let id_tipo_enc = data[cell.row].id_tipo_enc;
        let observ = data[cell.row].observ;
        let id_enc = data[cell.row].id_enc;
        let id_ubi = data[cell.row].id_ubi;
        let orden = data[cell.row].orden;
        let prioridad = data[cell.row].prioridad;
        let idioma = data[cell.row].idioma_enc;
        let descripcion_lugar = data[cell.row].descripcion_lugar;

        $('#titulo_modal').html(encargo);
        $('#observ').val(observ);
        $('#orden').val(orden);
        $('#prioridad').val(prioridad);
        $('#encargo').val(encargo);
        $('#id_enc_selected').val(id_enc);
        $('#id_tipo_enc').val(id_tipo_enc);
        $('#id_ubi').val(id_ubi);
        $('#descripcion_lugar').val(descripcion_lugar);
        $('#idioma_enc').val(idioma);

        showEncargosModal();
    }

    function requiredFieldValidator(value) {
        if (value == null || value == undefined || !value.length) {
            return {valid: false, msg: "This is a required field"};
        } else {
            return {valid: true, msg: null};
        }
    }

    var grid;
    var data = <?= $json_data_cuadricula ?>;
    var columns = <?= $json_columns_cuadricula ?>;
    var options = {
        editable: false,
        enableAddRow: true,
        enableCellNavigation: true,
        asyncEditorLoading: false,
        autoEdit: false
    };


    $(function () {
        grid = new Slick.Grid("#myGrid", data, columns, options);

        grid.onClick.subscribe(function (e) {
            var cell = grid.getCellFromEvent(e);
            openDetails(cell);
            e.stopPropagation();
        });

        grid.setActiveCell(0, 0);
    });

    $('.clockpicker').clockpicker({
        placement: 'bottom',
        align: 'right',
        donetext: 'Correcto!'
    });

    fnjs_generarNomEnc = function () {
        var nom_tipo = $('#id_tipo_enc :selected').text();
        var lloc = $('#id_ubi :selected').text();
        if (lloc == '') {
            $('#encargo').val(nom_tipo);
        } else {
            $('#encargo').val(nom_tipo + ' (' + lloc + ')');
        }
    };

</script>
