            + '&id_sacd=' + encodeURIComponent(ii2)
            + '&seleccion=' + encodeURIComponent(seleccion)
            + '&dia=' + encodeURIComponent(dia)
            + '<?= $h_desplegable_sacd ?>';
        $('#desplegable').html('<span>' + <?= json_encode(_('Cargando...')) ?> + '</span>');
          let request = $.ajax({
		    url: url_desplegable_sacd,
		    data: parametros,
		    type: 'post',
            dataType: 'json'
        });

        request.done(function (json) {
            if (!json || json.success !== true) {
                var msg = (json && json.mensaje) ? json.mensaje : <?= json_encode(_('No se pudo cargar el desplegable de sacerdotes')) ?>;
                $('#desplegable').html($('<span></span>').text(msg).prop('outerHTML'));
                return;
            }
            var payload;
            try {
                payload = (typeof json.data === 'string') ? JSON.parse(json.data) : json.data;
            } catch (e) {
                $('#desplegable').html($('<span></span>').text(<?= json_encode(_('Respuesta inválida del servidor')) ?>).prop('outerHTML'));
                return;
            }
            var pre = ($('#id_sacd_key_preselect').val() || '').trim();
            var chosen = resolveSacdSelectedKey(pre, payload.opciones || {});
            if (chosen) {
                payload.selected = chosen;
            }
            $('#desplegable').html(fnjs_construir_desplegable(payload));
            chosen = String($('#id_sacd').val() != null && $('#id_sacd').val() !== undefined ? $('#id_sacd').val() : '');
            $('#id_sacd_key_preselect').val(chosen);
        });
        request.fail(function () {
            $('#desplegable').html($('<span></span>').text(<?= json_encode(_('Error de comunicación al cargar sacerdotes')) ?>).prop('outerHTML'));
        });

        showItemDetailsModal();
    }

    function openDetails(cell) {
        if (cell == null || cell.row == null || cell.cell == null) {
            return;
        }
        var row = data[cell.row];
        var col = columns[cell.cell];
        if (!row || !col) {
            return;
        }
        var id_campo = col.field;
        // La columna encargo no tiene meta por fecha; titulo/sacd no llevan key de asignación.
        if (id_campo === 'encargo') {
            return;
        }
        var rowMeta = row.meta;
        if (!rowMeta || !rowMeta[id_campo]) {
            return;
        }
        var meta = rowMeta[id_campo];
        if (meta.tipo !== 'misas') {
            return;
        }

        const url = URL.createObjectURL(new Blob());
        $('#cell_selected').val(cell.cell);
        $('#row_selected').val(cell.row);
        // recuperar los datos del meta e introducirlos en los campos
        let encargo = row.encargo;

        let key = meta.key != null ? String(meta.key) : '';
        let tstart = meta.tstart;
        let tend = meta.tend;
        let observ = meta.observ;
        let id_enc = meta.id_enc;
        let dia = meta.dia;
        let uuid_item = meta.uuid_item;
        if (uuid_item === "") {
            uuid_item = url.substring(url.lastIndexOf('/') + 1)
        }

        $('#titulo_modal').html(encargo);
        $('#id_sacd_key_preselect').val(key);
        $('#id_sacd').val(key);
        $('#tstart').val(tstart);
        $('#tend').val(tend);
        $('#dia').val(dia);
        $('#observ').val(observ);
        $('#uuid_selected').val(uuid_item);
        $('#id_enc_selected').val(id_enc);

        if (seleccion==0) {
            seleccion=2;
        }
        if (seleccion==1) {
            $('#sacd_libre').prop('checked', true);
        }
        if (seleccion==2) {
            $('#sacd_zona').prop('checked', true);
        }
        if (seleccion==4) {
            $('#sacd_dl').prop('checked', true);
        }
        if (seleccion==8) {
            $('#sacd_depaso').prop('checked', true);
        }
        var id_sacd_inicial = sacdKeyToIdNom(key);
        $('#id_sacd_inicial').val(id_sacd_inicial);
        prepara_select_sacd();
    }

    function requiredFieldValidator(value) {
        if (value == null || value == undefined || !value.length) {
            return {valid: false, msg: "This is a required field"};
        } else {
            return {valid: true, msg: null};
        }
    }

