<script>
    (function () {
        var contenido = document.getElementById('contenido_sin_menus');
        var main = document.getElementById('main');
        if (!contenido || !main) {
            return;
        }
        var top = contenido.getBoundingClientRect().top;
        contenido.style.height = (window.innerHeight - top - 40) + 'px';
        contenido.style.width = (window.innerWidth - 20) + 'px';
        main.style.height = (window.innerHeight - top - 80) + 'px';
        main.style.width = (window.innerWidth - 20) + 'px';
        main.style.overflowX = 'hidden';
    })();
</script>
