<script>

    var modal = $('#modal_cuadricula_sacd');
    var modalHost = $('#cuadriculas');

    function showItemDetailsModal() {
        $('.item-details-form').not(modal).hide();
        if (!modal.parent().is('body')) {
            modal.appendTo(document.body);
        }
        modal.show();
    }

    function hideItemDetailsModal() {
        modal.hide();
        if (modalHost.length && !modal.parent().is(modalHost)) {
            modal.appendTo(modalHost);
        }
    }

    fnjs_construir_desplegable = function (data) {
        if (!data) {
            return '';
        }
        var $sel = $('<select></select>').attr({id: data.id, name: data.id});
        if (data.action) {
            $sel.attr('onchange', data.action);
        }
        if (data.blanco) {
            var vb = (data.val_blanco !== undefined && data.val_blanco !== null) ? data.val_blanco : '';
            $sel.append($('<option></option>').val(vb).text(''));
        }
        var opciones = data.opciones || {};
        if ($.isEmptyObject(opciones) && Array.isArray(data.rows)) {
            for (var r = 0; r < data.rows.length; r++) {
                var row = data.rows[r];
                opciones[String(row.value != null ? row.value : '')] = String(row.label != null ? row.label : '');
            }
        }
        $.each(opciones, function (value, label) {
            var $opt = $('<option></option>').val(value).text(label);
            if (data.selected && String(data.selected) === String(value)) {
                $opt.prop('selected', true);
            }
            $sel.append($opt);
        });
        return $sel.prop('outerHTML');
    };

    function sacdKeyToIdNom(key) {
        var parts = String(key || '').split('#');
        if (parts.length !== 2) {
            return '';
        }
        if (/^\d+$/.test(parts[0])) {
            return parts[0];
        }
        if (/^\d+$/.test(parts[1])) {
            return parts[1];
        }

        return '';
    }

    function resolveSacdSelectedKey(pre, opciones) {
        if (!pre || !opciones) {
            return '';
        }
        if (Object.prototype.hasOwnProperty.call(opciones, pre)) {
            return pre;
        }
        var parts = pre.split('#');
        if (parts.length === 2) {
            var rev = parts[1] + '#' + parts[0];
            if (Object.prototype.hasOwnProperty.call(opciones, rev)) {
                return rev;
            }
        }

        return '';
    }

    modal.keydown(function (e) {
        if (e.which == Slick.keyCode.ENTER) {
            commitCurrentEdit();
            e.stopPropagation();
            e.preventDefault();
        } else if (e.which == Slick.keyCode.ESCAPE) {
            cancelCurrentEdit();
            e.stopPropagation();
            e.preventDefault();
        }
    });

    modal.find("[data-action=save]").click(function () {
        commitCurrentEdit();
    });

    modal.find("[data-action=cancel]").click(function () {
        cancelCurrentEdit();
    });

    function cancelCurrentEdit() {
        hideItemDetailsModal();
    }

    function commitCurrentEdit(cell) {
        cell = $('#cell_selected').val();
        row = $('#row_selected').val();
//        alert('edit'+cell+'.'+row);
        var id_campo = columns[cell].field;

        let key = $('#id_sacd').val();
        const myArray = key.split("#");
        let iniciales = myArray[0];
        let id_nom = myArray[1];

        let tstart = $('#tstart').val();
        let tend = $('#tend').val();
        let dia = $('#dia').val();
        let observ = $('#observ').val();
        let uuid_item = $('#uuid_selected').val();
        let id_enc = $('#id_enc_selected').val();

        var texto = ' -- ';
        if (iniciales !== undefined) {
            texto = iniciales;
            if (tstart !== "") {
                texto += ' '+tstart;
            }
            if (observ !== "") {
                texto += '*';
            }
        }

        data[row].meta[id_campo].uuid_item = uuid_item;
        data[row].meta[id_campo].key = key;
        data[row].meta[id_campo].tstart = tstart;
        data[row].meta[id_campo].tend = tend;
        data[row].meta[id_campo].observ = observ;
        data[row].meta[id_campo].id_enc = id_enc;
//        data[row][id_campo]=iniciales;

//        grid.invalidateAllRows();
//        grid.render();

        let meta = data[row].meta[id_campo];
        let id_zona = '<?= (int)($id_zona ?? 0) ?>';
        meta.dia = dia;
        // añadir el hash (se puede cambiar todo menos el encargo)
//        const arr_h = { {{ array_h|raw }} };
//        const mergedJSON = { ...meta, ...arr_h };
        let parametros_update = 'id_enc=' + encodeURIComponent(id_enc)
            + '&uuid_item=' + encodeURIComponent(uuid_item)
            + '&key=' + encodeURIComponent(key)
            + '&observ=' + encodeURIComponent(observ)
            + '&dia=' + encodeURIComponent(dia)
            + '&tipo_plantilla=' + encodeURIComponent(tipo_plantilla)
            + '&tend=' + encodeURIComponent(tend)
            + '&tstart=' + encodeURIComponent(tstart)
            + '&id_zona=' + encodeURIComponent(id_zona)
            + '<?= $h_cuadricula_update ?>';

        $.ajax({
            url: '<?= htmlspecialchars($url_cuadricula_update, ENT_QUOTES, 'UTF-8') ?>',
            type: 'post',
            data: parametros_update,
            dataType: 'json'
        }).done(function (respuesta) {
            if (respuesta.success !== true) {
                alert(<?= json_encode(_("respuesta")) ?> + ': ' + (respuesta.mensaje || ''));
                return;
            }
            var inner = (typeof respuesta.data === 'string') ? JSON.parse(respuesta.data) : respuesta.data;
            var rmeta = inner.meta || {};
            hideItemDetailsModal();
            id_sacd_anterior = rmeta.id_sacd_anterior;
            i = 0;
            while ((i < data.length) && (data[i]['id_nom'] != id_sacd_anterior)) {
                i++;
            }
            if (i < data.length) {
                data[i].meta[id_campo].color = rmeta.color_fondo_anterior;
                data[i].meta[id_campo].texto = rmeta.texto_anterior;
            }
            i = 0;
            while ((i < data.length) && (data[i]['id_nom'] != id_nom)) {
                i++;
            }
            if (i < data.length) {
                data[i].meta[id_campo].color = rmeta.color_fondo;
                data[i].meta[id_campo].texto = rmeta.texto;
            }
            data[row].meta[id_campo].color = rmeta.color_misa;
            data[row].meta[id_campo].key = id_nom + '#' + iniciales;
            if (iniciales != '') {
                data[row][id_campo] = iniciales;
            } else {
                data[row][id_campo] = '--';
            }
            grid.invalidateAllRows();
            grid.render();
        });
    }

