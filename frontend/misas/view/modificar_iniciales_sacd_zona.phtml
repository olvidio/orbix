<br>
<div id="div_iniciales">
</div>

<script>
    fnjs_ver_iniciales_sacd_zona = function () {
        let id_zona = $('#id_zona').val();
        if (id_zona) {
            let url = '<?= $url_ver_iniciales_zona ?>';
            let parametros = 'id_zona=' + id_zona + '<?= $h_zona ?>';

            $.ajax({
                url: url,
                type: 'post',
                data: parametros,
                dataType: 'html'
            })
                .done(function (rta_txt) {
                    $('#div_iniciales').html(rta_txt);
                });
        }
    }
</script>
