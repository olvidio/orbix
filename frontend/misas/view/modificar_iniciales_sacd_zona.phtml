<div id="div_select_zona">
    <form id="frm_zona_ctr" name="frm_zona_ctr" action="" method="post">
        <table>
            <thead>
                <tr>
                    <th class="titulo_inv" colspan="4">
                        <?= ucfirst(_("Iniciales sacerdotes de la zona")) ?>:&nbsp;&nbsp;&nbsp;
                        <?= $oDesplZonas->desplegable() ?>
                    </th>
                </tr>
