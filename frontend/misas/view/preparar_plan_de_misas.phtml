<div id="div_cuadricula">
</div>

<script>
    $("#empiezamin").datepicker();
    $("#empiezamax").datepicker();

    fnjs_ver_cuadricula_zona = function () {
        let id_zona = $('#id_zona').val();
        if (id_zona) {
            let url = '<?= htmlspecialchars($url_ver_cuadricula_zona, ENT_QUOTES, 'UTF-8') ?>';
            var periodo = $('#periodo').val();
            var empiezamax = $('#empiezamax').val();
            var empiezamin = $('#empiezamin').val();
            let orden = $('#orden').val();
            let parametros = 'id_zona=' + encodeURIComponent(id_zona) + '&periodo=' + encodeURIComponent(periodo)
                + '&empiezamin=' + encodeURIComponent(empiezamin) + '&empiezamax=' + encodeURIComponent(empiezamax)
                + '&orden=' + encodeURIComponent(orden) + '&tipo_plantilla=p<?= $h_cuadricula_zona ?>';
            fnjs_ajax_json_html({ url: url, data: parametros, target: '#div_cuadricula' });
        }
    };

    fnjs_nuevo_periodo = function () {
        let id_zona = $('#id_zona').val();
        let tipoplantilla = $('#tipoplantilla').val();
        if (id_zona) {
            let url = '<?= htmlspecialchars($url_crear_nuevo_periodo, ENT_QUOTES, 'UTF-8') ?>';
            var periodo = $('#periodo').val();
            var empiezamax = $('#empiezamax').val();
            var empiezamin = $('#empiezamin').val();
            let parametros = 'id_zona=' + encodeURIComponent(id_zona) + '&tipoplantilla=' + encodeURIComponent(tipoplantilla)
                + '&periodo=' + encodeURIComponent(periodo) + '&empiezamax=' + encodeURIComponent(empiezamax)
                + '&empiezamin=' + encodeURIComponent(empiezamin) + '<?= $h_nuevo_periodo ?>';
            fnjs_ajax_json({
                url: url,
                data: parametros,
                onSuccess: function () {
                    fnjs_ver_cuadricula_zona();
                }
            });
        }
    };
    $(document).ready($('#periodo').change(function () {
        funjs_activar_fecha();
        fnjs_ver_cuadricula_zona();
    }));
    $(document).ready($('#empiezamin').change(function () {
        funjs_activar_fecha();
        fnjs_ver_cuadricula_zona();
    }));
    $(document).ready($('#empiezamax').change(function () {
        funjs_activar_fecha();
        fnjs_ver_cuadricula_zona();
    }));
    fnjs_ver_cuadricula_zona();
</script>
