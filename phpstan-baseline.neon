parameters:
	ignoreErrors:
		-
			message: '#^Method frontend\\planning\\support\\PlanningRenderer\:\:getActividades\(\) should return array\<int\|string, array\<int\|string, list\<array\<string, mixed\>\>\>\> but returns array\<int\|string, array\<int\|string, mixed\>\>\.$#'
			identifier: return.type
			count: 1
			path: frontend/planning/support/PlanningRenderer.php

		-
			message: '#^Parameter \#2 \$actividad of method frontend\\planning\\support\\PlanningRenderer\:\:parsePersonaFila\(\) expects array\<int\|string, mixed\>, mixed given\.$#'
			identifier: argument.type
			count: 1
			path: frontend/planning/support/PlanningRenderer.php

		-
			message: '#^Method src\\actividadestudios\\application\\ActaNotasData\:\:execute\(\) should return array\{msg_err\: string, permiso\: int, nom_activ\: string, matriculados\: int, matriculas_rows\: list\<array\{nom\: string, id_nom\: int, nota_num\: mixed, nota_max\: mixed, preceptor\: bool, acta\: mixed\}\>, notas\: string, despl_actas_opciones\: array\<int\|string, string\>, acta_principal\: string, \.\.\.\} but returns array\{msg_err\: string, permiso\: 1\|3, nom_activ\: string, matriculados\: int\<0, max\>, matriculas_rows\: list\<array\{nom\: string, id_nom\: int, nota_num\: string\|null, nota_max\: string\|null, preceptor\: bool\|null, acta\: string\|null\}\>, notas\: ''acta''\|''nuevo'', despl_actas_opciones\: non\-empty\-array\<0\|2\|string, string\>, acta_principal\: string, \.\.\.\}\.$#'
			identifier: return.type
			count: 1
			path: src/actividadestudios/application/ActaNotasData.php

		-
			message: '#^Parameter \#6 \$inicioIso of method src\\actividadestudios\\application\\CaPosiblesData\:\:mensajeCuadroVacio\(\) expects string, string\|null given\.$#'
			identifier: argument.type
			count: 1
			path: src/actividadestudios/application/CaPosiblesData.php

		-
			message: '#^Parameter \#7 \$finIso of method src\\actividadestudios\\application\\CaPosiblesData\:\:mensajeCuadroVacio\(\) expects string, string\|null given\.$#'
			identifier: argument.type
			count: 1
			path: src/actividadestudios/application/CaPosiblesData.php

		-
			message: '#^Cannot cast mixed to string\.$#'
			identifier: cast.string
			count: 1
			path: src/actividadestudios/application/MatriculasListaOtrasRData.php

		-
			message: '#^Parameter &\$asignaturasCache by\-ref type of method src\\actividadestudios\\application\\MatriculasPendientesData\:\:nombreAsignatura\(\) expects array\<int, string\>, array\<int, string\|null\> given\.$#'
			identifier: parameterByRef.type
			count: 1
			path: src/actividadestudios/application/MatriculasPendientesData.php

		-
			message: '#^Method src\\dossiers\\application\\DossierVerDatosTablaInfoClassResolver\:\:tryResolveFullyQualifiedClassName\(\) should return class\-string\|null but returns string\.$#'
			identifier: return.type
			count: 1
			path: src/dossiers/application/DossierVerDatosTablaInfoClassResolver.php

		-
			message: '#^Call to function is_string\(\) with string will always evaluate to true\.$#'
			identifier: function.alreadyNarrowedType
			count: 1
			path: src/dossiers/application/DossiersVerPantallaData.php

		-
			message: '#^Cannot access an offset on array\<string, mixed\>\|stdClass\.$#'
			identifier: offsetAccess.nonOffsetAccessible
			count: 1
			path: src/notas/infrastructure/persistence/postgresql/PgPersonaNotaOtraRegionStgrRepository.php

		-
			message: '#^Parameter \#1 \$oJSON of method src\\notas\\domain\\entity\\PersonaNotaOtraRegionStgr\:\:setJson_certificados\(\) expects array\<string, mixed\>\|string\|null, array\<int\|string, mixed\>\|\(ArrayAccess&stdClass\) given\.$#'
			identifier: argument.type
			count: 1
			path: src/notas/infrastructure/persistence/postgresql/PgPersonaNotaOtraRegionStgrRepository.php

		-
			message: '#^Parameter \#2 \$problemasRegionStgr of method src\\personas\\domain\\contracts\\PersonaPubRepositoryInterface\:\:findByIdParaListado\(\) expects array\<string, array\<string, string\>\>, array\<string, array\<int\|string, string\>\> given\.$#'
			identifier: argument.type
			count: 1
			path: src/personas/application/services/PersonaFinderService.php

		-
			message: '#^Parameter &\$problemasRegionStgr @param\-out type of method src\\personas\\application\\services\\PersonaFinderService\:\:findPersonaParaListado\(\) expects array\<string, array\<string, string\>\>, array\<string, array\<int\|string, string\>\> given\.$#'
			identifier: paramOut.type
			count: 1
			path: src/personas/application/services/PersonaFinderService.php

		-
			message: '#^Cannot call method fetchAll\(\) on array\<int\|string, string\>\|frontend\\shared\\web\\DesplegableOpcionesIterable\|null\.$#'
			identifier: method.nonObject
			count: 1
			path: src/planning/application/ActividadesPorZonasService.php

		-
			message: '#^Cannot unset offset ''Refresh_error'' on non\-empty\-array\<mixed, mixed\>\.$#'
			identifier: unset.offset
			count: 1
			path: src/shared/application/RefreshCrStgrMaterializedViews.php

		-
			message: '#^Result of && is always true\.$#'
			identifier: booleanAnd.alwaysTrue
			count: 1
			path: src/shared/application/RefreshCrStgrMaterializedViews.php

		-
			message: '#^Strict comparison using \!\=\= between numeric\-string and '''' will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 1
			path: src/shared/application/RefreshCrStgrMaterializedViews.php

		-
			message: '#^Strict comparison using \!\=\= between numeric\-string and false will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 1
			path: src/shared/application/RefreshCrStgrMaterializedViews.php
