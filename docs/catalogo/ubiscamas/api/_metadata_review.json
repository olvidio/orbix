    "update_cama_asistente": {
        "operacion": "mutacion",
        "requiere_hashb": true,
        "respuesta": "raw_response",
        "entrada": {
            "ctx": "string",
            "id_nom": "integer",
            "id_cama": "string"
        },
        "entrada_obligatoria": ["ctx", "id_nom"],
        "errores": [
            "Operación no autorizada",
            "Asistencia no encontrada para id_nom",
            "Error al guardar la asignación de la cama"
        ],
        "salida": {
            "success_data": {
                "success": "boolean",
                "mensaje": "ok o texto error"
            }
        },
        "objetivo_funcional": "Asigna o reasigna la cama de un asistente en una actividad. `id_activ` se extrae de la cápsula `ctx` firmada (`HashB::sign('update_cama_asistente', {id_activ})`); `id_cama` vacío desasigna.",
        "permisos": ["Autorización vía cápsula HashB `ctx`; sin perm_* en caso de uso."],
        "casos_uso": ["UpdateCamaAsistente"],
        "frontend_referencias": ["frontend/ubiscamas/view/lista_habitaciones.phtml"]
    },
