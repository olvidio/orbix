# Copiar a `e2e/.env` y rellenar (sin `export`; una variable por línea).
# `e2e/.env` está en .gitignore.

# Obligatorio: la misma URL base con la que entras en Chrome (sin barra final).
# Si ves 404 con 127.0.0.1, prueba el hostname de Docker (ej. orbix.docker).
PLAYWRIGHT_BASE_URL=http://orbix.docker:8003/orbix

E2E_USER=admin
E2E_PASSWORD=admin
# Opcional:
# Esquema en login: debe coincidir con el <option value> (en sv suele acabar en "v", ej. H-dlbv; en sf en "f").
# Si el servidor fija ESQUEMA por env, el formulario usa input hidden y se rellena igual.
E2E_ESQUEMA=H-dlbv
E2E_LOGIN_TIMEOUT_MS=90000
E2E_2FA_CODE=
E2E_MAX_LINKS=100
# Timeout GET por cada enlace candidato (ms).
# E2E_LINK_GET_TIMEOUT_MS=18000
# Ejecutar GET también en rutas típicamente solo-POST (más tiempo, más timeouts posibles).
# E2E_STRICT_MENU_LINK_GET=1
# Listar en consola cada GET del recorrido de menú y adjuntar menu-links-get.log al informe HTML (show-report).
# E2E_MENU_LINK_GET_LOG=1
# Opcional: probar enlaces tras elegir grupo de menús (tabla ref_grupmenu / barra Orbix).
# E2E_GRUPMENU_ID=5
# E2E_GRUPMENU_LABEL=vsm
# Tras el índice, hacer clic secuencial en ítems de menú (fnjs_link_submenu) y añadir enlaces vistas en #main (POST reales → sólo datos de prueba).
# E2E_MENU_AJAX_DISCOVER=1
# E2E_MAX_MENU_AJAX_CLICKS=30
# E2E_MENU_AJAX_SETTLE_MS=2500
# Docker sin BDU: omite el spec de recorrido de menú si el índice sólo falla por BDU (no lo actives en CI donde quieras validar BDU).
# E2E_SKIP_MENU_LINKS_IF_BDU_UNAVAILABLE=1
