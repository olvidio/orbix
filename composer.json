{
  "config": {
    "vendor-dir": "libs/vendor",
    "platform": {
      "php": "8.2"
    }
  },
  "require": {
    "twig/twig": "^3.0",
    "jblond/twig-trans": "^1.0",
    "mpdf/mpdf": "^8.0",
    "setasign/fpdi": "^2.2",
    "ext-gettext": "*",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-bcmath": "*",
    "ext-calendar": "*",
    "ext-zip": "*",
    "ext-xml": "*",
    "ramsey/uuid": "^4.7",
    "ext-intl": "*",
    "illuminate/http": "^11.41",
    "erusev/parsedown": "^1.7",
    "endroid/qr-code": "^6.0",
    "php-di/php-di": "^7.1",
    "nikic/fast-route": "^1.3"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "phpunit/phpunit": "^11.2",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
        "psr-4": {
          "frontend\\": "frontend/",
          "src\\": "src/",
          "": "apps/"
        },
        "files": [
          "frontend/shared/helpers/func_tablas.php",
          "src/shared/domain/helpers/func_tablas.php"
        ]
   },
  "autoload-dev": {
       "psr-4": { "Tests\\": "tests/" }
   },
  "scripts": {
    "test": "php libs/vendor/bin/phpunit --configuration phpunit.xml",
    "test:integration": "php libs/vendor/bin/phpunit --configuration phpunit.xml tests/integration",
    "test:docker": "scripts/phpunit-docker",
    "test:docker:integration": "scripts/phpunit-docker tests/integration",
    "test:docker:personas": "scripts/phpunit-docker tests/integration/personas",
    "test:report:buckets": "bash shell_scripts/check_test_coverage.sh",
    "test:report:granular": "bash shell_scripts/check_test_granular.sh",
    "test:report": [
      "@composer test:report:buckets",
      "@composer test:report:granular"
    ],
    "test:coverage": "env XDEBUG_MODE=coverage php libs/vendor/bin/phpunit --configuration phpunit.xml --coverage-text",
    "test:coverage:unit": "env XDEBUG_MODE=coverage php libs/vendor/bin/phpunit --configuration phpunit.xml --testsuite unit --coverage-text",
    "test:coverage:html": "env XDEBUG_MODE=coverage php libs/vendor/bin/phpunit --configuration phpunit.xml --testsuite unit --coverage-html build/phpunit-coverage-html"
  }
}
